# Server-side secrets for the on-demand /api/* routes (Netlify Functions).
# Set the real values in the Netlify dashboard (Site settings → Environment
# variables). Never commit real values. Static content pages need none of these.

# --- Lead-magnet guide delivery (/api/send-guide) ---
RESEND_API_KEY=
RESEND_FROM="Sagan <hello@globalandremote.com>"

# --- Universal form capture (hubspot-capture.js, client-side) ---
# Make.com webhook is read from the data-make-webhook attribute in markup, not
# env; listed here for reference of the full secret surface.
# MAKE_WEBHOOK_URL=

# --- Later phases (port as those pages land) ---
# AI agent demos (/api/config, /api/vapi/*)
# VAPI_PUBLIC_KEY=
# VAPI_ASSISTANT_ID=
# ANTHROPIC_API_KEY=
# AI savings scan (/api/ai-savings/*)
# OPENROUTER_API_KEY=
# PUBLIC_SITE_URL=
