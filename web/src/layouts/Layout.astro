---
// Base HTML shell. The document that used to live in index.astro moved here so
// every page shares one <head> and the global font setup.
//
// All shared styling — design tokens, @font-face, the reset, type utilities —
// lives in src/styles/global.css, imported once below. Components reference
// those tokens (var(--glacier), var(--pp), …) and must not redefine them.
import '../styles/global.css';
import { getSiteSettings } from '../lib/siteSettings';
import { imgUrl } from '../lib/sanityImage';
import type { SanityImageSource } from '@sanity/image-url';

interface Props {
  title?: string;
  description?: string;
  /** Page-specific social share image; falls back to the sitewide default from Site settings. */
  ogImage?: SanityImageSource | string;
}
const { title = 'Sagan Passport', description, ogImage } = Astro.props;

// Sitewide SEO defaults (site name/URL, default share image, org logo) are
// edited in Sanity → Site settings; fetched once per build.
const site = await getSiteSettings();
const siteName = site.siteName ?? 'Sagan Passport';
const siteUrl = (site.siteUrl ?? 'https://saganpassport.com').replace(/\/+$/, '');

// Canonical URL: with build.format 'file' the page path can surface as
// "/pricing.html" (or "/index.html" for the root), but Netlify serves the
// clean slash-less URL — normalize to that.
const path = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '')
  .replace(/(.)\/$/, '$1');
const canonical = `${siteUrl}${path}`;

const ogImageUrl =
  typeof ogImage === 'string' ? ogImage : imgUrl(ogImage ?? site.ogImage) || undefined;

const orgJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: siteUrl,
  ...(imgUrl(site.logo) ? { logo: imgUrl(site.logo) } : {}),
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- Sagan favicon (from the live site): light/dark PNG pair + .ico fallback. -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-light.png" />
    <link rel="icon" href="/favicon-light.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon-dark.png" media="(prefers-color-scheme: dark)" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- Keep the whole site out of search engines (staging / private). Belt and
         suspenders: this meta tag + the X-Robots-Tag header in netlify.toml +
         /robots.txt. Remove all three to allow indexing when going public. -->
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />

    <!-- Images are served from Sanity's CDN. -->
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />

    <!-- Space Grotesk: pulled from Google Fonts (it's the genuine article, so
         no self-hosting needed). PP Mori is commercial, so it is self-hosted
         via @font-face below — drop the files into /public/fonts/. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    <!-- Social share cards (Open Graph + Twitter). Values come from each
         page's SEO group in Sanity, falling back to Site settings. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- Organization structured data for search engines (edited in Sanity → Site settings). -->
    <script is:inline type="application/ld+json" set:html={orgJsonLd}></script>
    <slot name="head" />
  </head>
  <body>
    <slot />

    <script>
      // Lenis smooth scroll — matches saganpassport.com (the Framer pages used
      // <SmoothScroll />). Same config as the React build: lerp 0.09.
      import Lenis from 'lenis';
      const reduceMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;
      if (!reduceMotion) {
        const lenis = new Lenis({ lerp: 0.09, smoothWheel: true, wheelMultiplier: 1 });
        const raf = (time: number) => {
          lenis.raf(time);
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);
      }
    </script>

    <script>
      // On-scroll reveal: reveal [data-appear] elements once when they enter the
      // viewport (mirrors the Framer "On Appear" animation). Honors reduced motion.
      const els = document.querySelectorAll<HTMLElement>('[data-appear]');
      const reduce = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;
      if (reduce) {
        els.forEach((el) => el.classList.add('is-in'));
      } else {
        const obs = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                obs.unobserve(e.target);
              }
            }
          },
          { threshold: 0.1, rootMargin: '0px 0px -8% 0px' },
        );
        els.forEach((el) => obs.observe(el));
      }
    </script>
  </body>
</html>
