---
/* CheckmarkCard — Astro port of the Framer `checkmark-card`. A 38px checkmark
 * icon above a short supporting line, in a 276px column. Used in the
 * "Our Unique Approach" grid. */
interface Props {
  text: string;
  icon?: string;
}
const DEFAULT_ICON =
  'https://cdn.sanity.io/images/3ofs1zkm/production/6b50b5128aed04b5bb875c0a1dbc673b8583e4db-40x40.png';
const { text, icon = DEFAULT_ICON } = Astro.props;
---

<div class="su-check">
  <img class="su-check__icon" src={icon} alt="" loading="lazy" />
  <p class="su-check__text">{text}</p>
</div>

<style>
  .su-check {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 24px;
    width: 276px;
    max-width: 100%;
  }
  .su-check__icon {
    width: 38px;
    height: 38px;
    object-fit: contain;
    display: block;
    flex: none;
  }
  .su-check__text {
    margin: 0;
    font-family: var(--pp);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.4;
    color: var(--glacier);
  }
</style>
