---
/* TestimonialSlideshow — Astro port of the Framer `slideshow`, vanilla JS.
 * Centered testimonial carousel (avatar, quote, name/company) with prev/next
 * arrows, dot indicators, and CSS-fade transitions. Autoplay kicks in only with
 * more than one slide. Defaults to the single live saganpassport.com testimonial. */
interface Slide {
  image: string;
  quote: string;
  name: string;
  title: string;
}
interface Props {
  slides?: Slide[];
  autoplay?: number;
}
const DEFAULT_SLIDES: Slide[] = [
  {
    image: 'https://framerusercontent.com/images/MSqCWMpX1xnbTTDzvPcPpc0E6ss.jpeg?width=200&height=200',
    quote:
      '"This gave me a clear playbook for managing people better-not just in theory, but in the day-to-day work of leading a small team."',
    name: 'Wes Kauffman',
    title: 'CEO, Concordia Holdings Lancaster',
  },
];
const { slides = DEFAULT_SLIDES, autoplay = 4 } = Astro.props;
const SLIDES = slides;
---

<div class="su-slidex" data-autoplay={autoplay}>
  <div class="su-slidex__slide" data-slide>
    <img class="su-slidex__img" src={SLIDES[0].image} alt={SLIDES[0].name} loading="lazy" />
    <p class="su-slidex__quote">{SLIDES[0].quote}</p>
    <div class="su-slidex__meta">
      <p class="su-slidex__name">{SLIDES[0].name}</p>
      <p class="su-slidex__title">{SLIDES[0].title}</p>
    </div>
  </div>

  <div class="su-slidex__controls">
    <button class="su-slidex__arrow" data-prev aria-label="Previous slide">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" aria-hidden="true">
        <path d="M18 12H6M6 12L12 6M6 12L12 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
    <div class="su-slidex__dots">
      {SLIDES.map((_, d) => (
        <button class={`su-slidex__dot${d === 0 ? ' is-active' : ''}`} data-dot={d} aria-label={`Go to slide ${d + 1}`}></button>
      ))}
    </div>
    <button class="su-slidex__arrow" data-next aria-label="Next slide">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" aria-hidden="true">
        <path d="M6 12h12M18 12l-6-6M18 12l-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
  </div>

  <script type="application/json" data-slides set:html={JSON.stringify(SLIDES)}></script>
</div>

<style>
  .su-slidex {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 40px 64px;
  }
  .su-slidex__slide {
    width: 100%;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 32px;
    animation: su-slidex-fade 0.35s ease;
  }
  @keyframes su-slidex-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .su-slidex__img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
  }
  .su-slidex__quote {
    max-width: 800px;
    margin: 0;
    text-align: center;
    font-family: var(--pp);
    font-size: 32px;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: -1px;
    color: var(--glacier);
  }
  .su-slidex__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .su-slidex__name {
    margin: 0;
    font-family: var(--pp-semibold);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--glacier);
  }
  .su-slidex__title {
    margin: 0;
    font-family: var(--pp);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: rgb(74, 107, 107);
  }
  .su-slidex__controls {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .su-slidex__arrow {
    width: 48px;
    height: 48px;
    flex: none;
    border-radius: 50%;
    border: 1px solid var(--glacier);
    background: transparent;
    color: var(--glacier);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.3s ease-in-out;
  }
  .su-slidex__arrow:hover {
    background: var(--space-300);
  }
  .su-slidex__dots {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .su-slidex__dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    border-radius: 4px;
    background: var(--glacier);
    opacity: 0.3;
    cursor: pointer;
    transition: width 0.3s ease, opacity 0.3s ease;
  }
  .su-slidex__dot.is-active {
    width: 40px;
    opacity: 1;
  }
  @media (max-width: 810px) {
    .su-slidex { padding: 20px; }
    .su-slidex__quote { font-size: 22px; line-height: 1.3; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.su-slidex').forEach((root) => {
    const json = root.querySelector('[data-slides]')?.textContent;
    if (!json) return;
    const data: { image: string; quote: string; name: string; title: string }[] = JSON.parse(json);
    const slide = root.querySelector<HTMLElement>('[data-slide]')!;
    const img = root.querySelector<HTMLImageElement>('.su-slidex__img')!;
    const quote = root.querySelector<HTMLElement>('.su-slidex__quote')!;
    const name = root.querySelector<HTMLElement>('.su-slidex__name')!;
    const title = root.querySelector<HTMLElement>('.su-slidex__title')!;
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-dot]'));
    const n = data.length;
    const intervalMs = (parseFloat(root.dataset.autoplay || '4') || 4) * 1000;
    let i = 0;
    let timer: number;

    const render = () => {
      const s = data[i];
      img.src = s.image;
      img.alt = s.name;
      quote.textContent = s.quote;
      name.textContent = s.name;
      title.textContent = s.title;
      dots.forEach((d, di) => d.classList.toggle('is-active', di === i));
      slide.style.animation = 'none';
      void slide.offsetWidth;
      slide.style.animation = '';
    };
    const go = (idx: number) => {
      i = ((idx % n) + n) % n;
      render();
    };
    const restart = () => {
      clearInterval(timer);
      timer = window.setInterval(() => go(i + 1), intervalMs);
    };

    root.querySelector('[data-prev]')?.addEventListener('click', () => { go(i - 1); restart(); });
    root.querySelector('[data-next]')?.addEventListener('click', () => { go(i + 1); restart(); });
    dots.forEach((d, di) => d.addEventListener('click', () => { go(di); restart(); }));

    if (n > 1) timer = window.setInterval(() => go(i + 1), intervalMs);
  });
</script>
