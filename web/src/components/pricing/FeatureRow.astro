---
/* FeatureRow — one "WHAT'S INCLUDED" line (Astro port): feature text on the
 * left, a filled accent-colored checkmark circle on the right, with a hairline
 * divider above. Checkmark path (M6 10L9 13L15 7) is the exact glyph from
 * framer/pricing-table. */
interface Props {
  text: string;
  accent: string;
}
const { text, accent } = Astro.props;
---

<div class="pfeat">
  <span class="pfeat__text">{text}</span>
  <span class="pfeat__check" style={`background:${accent}`} aria-hidden="true">
    <svg viewBox="0 0 20 20" width="20" height="20" fill="none">
      <path d="M6 10L9 13L15 7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </span>
</div>

<style>
  .pfeat {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 20px 0;
    border-top: 1px solid rgba(9, 58, 62, 0.1);
  }
  .pfeat__text {
    font-family: var(--pp);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: var(--glacier);
  }
  .pfeat__check {
    flex: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pfeat__check svg {
    display: block;
  }
</style>
