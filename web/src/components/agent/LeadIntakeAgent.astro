---
/* Faithful port of /agent/lead-intake. Follows the agent/ group pattern from
 * FreightAgent.astro: Tailwind CDN + inline config + the page's custom <style>,
 * bespoke body verbatim, with hero copy + CTA URL driven by the `agentDemo`
 * Sanity doc. Isolated via its own route file. */
import type { AgentDemoData } from '../../lib/agentDemos';

interface Props {
  data: AgentDemoData;
}
const { data } = Astro.props;
const cta = data.ctaUrl ?? 'https://www.shipyourweekendproject.com/';
const logo = '/agent/lead-intake/sagan-logo.png';
---

<!-- Start of HubSpot Embed Code -->
<script type="text/javascript" id="hs-script-loader" async defer src="//js.hs-scripts.com/50517161.js" is:inline></script>
<!-- End of HubSpot Embed Code -->

<!-- Tailwind CDN + theme config (kept verbatim from the source page) -->
<script is:inline src="https://cdn.tailwindcss.com"></script>
<script is:inline>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          glacier:    '#093A3E',
          'glacier-d':'#06282B',
          muted:      '#4A6B6B',
          cream:      '#F5F2ED',
          'cream-d':  '#EDE9E5',
          white:      '#FFFFFF',
          dandelion:  '#F5B800',
          'sagan-blue': '#2197FF',
          hairline:   'rgba(9,58,62,0.06)'
        },
        fontFamily: {
          display: ['"Plus Jakarta Sans"', 'ui-sans-serif', 'system-ui', 'sans-serif'],
          sans:    ['"Space Grotesk"', 'system-ui', 'sans-serif'],
          mono:    ['"Fragment Mono"', 'ui-monospace', 'SFMono-Regular', 'monospace']
        }
      }
    }
  }
</script>

<!-- NAV -->
<nav class="sticky top-0 z-50 backdrop-blur bg-cream/85 border-b border-hairline">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="#" class="flex items-center gap-3">
      <img src={logo} alt="Sagan" class="h-8 w-auto" />
      <span class="mono text-sm text-muted">an AI agent · by Sagan<span aria-hidden="true" style="display:inline-block;width:8px;height:8px;background:#2197FF;border-radius:999px;margin-left:4px;vertical-align:baseline;transform:translateY(-1px);box-shadow:0 0 10px rgba(33,151,255,0.35);"></span></span>
    </a>
    <div class="hidden md:flex items-center gap-8 text-sm text-glacier/80">
      <a href="#pain" class="hover:text-glacier">the problem</a>
      <a href="#how" class="hover:text-glacier">how it works</a>
      <a href="#pricing" class="hover:text-glacier">pricing</a>
      <a href="#for" class="hover:text-glacier">is this for you</a>
    </div>
    <a href={cta} class="btn-primary text-sm">
      Join the waitlist
      <span aria-hidden>→</span>
    </a>
  </div>
</nav>

<!-- HERO -->
<header class="border-b border-hairline relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 pt-20 pb-24 md:pt-28 md:pb-32 relative">
    <div class="reveal">
      <div class="eyebrow mb-8"><span class="dot"></span>{data.heroEyebrow}</div>
      <h1 class="display text-5xl md:text-7xl text-glacier" set:html={data.heroHeadlineHtml}></h1>
    </div>

    <div class="reveal mt-10 max-w-2xl text-lg md:text-xl text-glacier/80 leading-relaxed" style="--d:150ms" set:html={data.heroLeadHtml}></div>

    <div class="reveal mt-10 flex flex-col sm:flex-row gap-4" style="--d:300ms">
      <a href={cta} class="btn-primary">
        Claim a beta seat
        <span aria-hidden>→</span>
      </a>
      <a href="#pain" class="btn-ghost">
        See the math
      </a>
    </div>

    <!-- latency diagram -->
    <div class="reveal mt-20 card p-6 md:p-10" style="--d:450ms">
      <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-16">
        <div class="flex-1">
          <div class="eyebrow mb-3">before</div>
          <div class="ticker text-5xl md:text-6xl text-glacier">15:00 <span class="text-muted text-2xl">min</span></div>
          <div class="mt-2 text-muted">median first reply, manual</div>
        </div>
        <div class="hidden md:block mono text-4xl" style="color:#F5B800">→</div>
        <div class="flex-1">
          <div class="eyebrow mb-3" style="color:#B88A00">after</div>
          <div class="ticker text-5xl md:text-6xl" style="color:#093A3E">00:60 <span class="text-muted text-2xl">sec</span></div>
          <div class="mt-2 text-muted">agent-handled first reply</div>
        </div>
        <div class="flex-1 md:border-l md:border-hairline md:pl-10">
          <div class="eyebrow mb-3">recovered</div>
          <div class="ticker text-5xl md:text-6xl text-glacier">14 <span class="text-muted text-2xl">min/lead</span></div>
          <div class="mt-2 text-muted">before the homeowner calls the next shop</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ambient marquee -->
  <div class="border-t border-hairline py-4 overflow-hidden mono text-xs text-muted">
    <div class="marquee whitespace-nowrap">
      <span>paid lead channel message → routed · intake form submit → qualified · listings site lead → replied · voicemail → transcribed · CRM → updated · paid lead channel message → routed · intake form submit → qualified · listings site lead → replied · voicemail → transcribed · CRM → updated ·&nbsp;</span>
      <span>paid lead channel message → routed · intake form submit → qualified · listings site lead → replied · voicemail → transcribed · CRM → updated · paid lead channel message → routed · intake form submit → qualified · listings site lead → replied · voicemail → transcribed · CRM → updated ·&nbsp;</span>
    </div>
  </div>
</header>

<!-- THE PROBLEM -->
<section id="pain" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5 reveal">
        <div class="eyebrow mb-4">the problem</div>
        <h2 class="display text-4xl md:text-5xl text-glacier">
          It's 9:47am.<br />
          You just pulled<br />
          off a job site.
        </h2>
      </div>
      <div class="md:col-span-7 reveal" style="--d:150ms">
        <p class="text-xl md:text-2xl text-glacier/85 leading-relaxed">
          Your phone has four lead pings from three apps. Oldest is from 7:12am. You swipe through them at a red light, flag two for later, and drive to the next stop.
        </p>
        <p class="mt-8 text-lg text-glacier/75 leading-relaxed">
          By noon, two have gone cold and one already booked a competitor. The pattern repeats every week, and you're the only one who sees it.
        </p>
      </div>
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-6 reveal stagger">
      <div class="card p-8 hover-lift" style="--d:0ms">
        <div class="mono text-sm mb-2" style="color:#F5B800">01</div>
        <div class="display text-xl mb-2 text-glacier">Leads arrive on 4+ channels</div>
        <p class="text-muted text-sm leading-relaxed">Paid lead channel, intake form, listings sites, after-hours email. No single inbox. You check all of them, between jobs.</p>
      </div>
      <div class="card p-8 hover-lift" style="--d:100ms">
        <div class="mono text-sm mb-2" style="color:#F5B800">02</div>
        <div class="display text-xl mb-2 text-glacier">15-minute median first reply</div>
        <p class="text-muted text-sm leading-relaxed">The homeowner filed the form from a ladder-adjacent problem. You reply from a ladder yourself. The faster shop wins.</p>
      </div>
      <div class="card p-8 hover-lift" style="--d:200ms">
        <div class="mono text-sm mb-2" style="color:#F5B800">03</div>
        <div class="display text-xl mb-2 text-glacier">12–20 hrs/wk of triage</div>
        <p class="text-muted text-sm leading-relaxed">Copy the name, paste the address, retype the scope, tag the source, push it to your CRM. Every lead. Every day.</p>
      </div>
    </div>
  </div>
</section>

<!-- THE MATH -->
<section class="border-b border-hairline" style="background:#06282B; color:#F5F2ED;">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4" style="color:#F5B800">the math, if you want to look</div>
      <h2 class="display text-4xl md:text-6xl max-w-4xl" style="color:#F5F2ED">
        At twelve leads a week<br />
        going to a faster competitor,<br />
        that's <span style="color:#F5B800">$11,250/wk.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-4 gap-6 reveal stagger">
      <div class="p-8 rounded-3xl" style="background:#093A3E; --d:0ms;">
        <div class="mono text-xs mb-2" style="color:rgba(245,242,237,0.55)">NON-PHONE LEADS /WK</div>
        <div class="ticker text-5xl" style="color:#F5F2ED">12</div>
      </div>
      <div class="p-8 rounded-3xl" style="background:#093A3E; --d:100ms;">
        <div class="mono text-xs mb-2" style="color:rgba(245,242,237,0.55)">MEDIAN REPLY</div>
        <div class="ticker text-5xl" style="color:#F5B800">15 <span class="text-2xl" style="color:rgba(245,242,237,0.55)">min</span></div>
      </div>
      <div class="p-8 rounded-3xl" style="background:#093A3E; --d:200ms;">
        <div class="mono text-xs mb-2" style="color:rgba(245,242,237,0.55)">HRS RECLAIMED /WK</div>
        <div class="ticker text-5xl" style="color:#F5F2ED">15</div>
      </div>
      <div class="p-8 rounded-3xl" style="background:#093A3E; --d:300ms;">
        <div class="mono text-xs mb-2" style="color:rgba(245,242,237,0.55)">$ /WK LEAKING</div>
        <div class="ticker text-5xl" style="color:#F5B800">$11,250<span class="text-2xl" style="color:rgba(245,242,237,0.55)">/wk</span></div>
      </div>
    </div>

    <p class="reveal mt-10 max-w-3xl" style="color:rgba(245,242,237,0.7); --d:450ms;">
      $9,000 in leaked revenue (12 leads × 30% lost to the faster competitor × $2,500 average job) plus $2,250 in owner time (15 hours × $150/hr owner-loaded). $11,250 a week walks out the door, through the one person the business can't replace.
    </p>
  </div>
</section>

<!-- HOW -->
<section id="how" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4">how it works</div>
      <h2 class="display text-4xl md:text-6xl max-w-4xl text-glacier">
        Your tools, already in place.<br />
        <span class="text-muted">One layer that never misses a ping.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-4 gap-6 reveal stagger">
      <div class="card p-8" style="--d:0ms">
        <div class="mono text-sm mb-4" style="color:#F5B800">step 01</div>
        <div class="display text-xl mb-3 text-glacier">Lead lands on any channel</div>
        <p class="text-muted text-sm leading-relaxed">Paid lead channel, intake form, listings sites, or an after-hours email. The agent watches all of them.</p>
      </div>
      <div class="card p-8" style="--d:100ms">
        <div class="mono text-sm mb-4" style="color:#F5B800">step 02</div>
        <div class="display text-xl mb-3 text-glacier">Reads, qualifies, replies in 60 seconds</div>
        <p class="text-muted text-sm leading-relaxed">Parses the request, checks service area and job type, fires back a same-channel reply with two time windows while the homeowner is still on the page.</p>
      </div>
      <div class="card p-8" style="--d:200ms">
        <div class="mono text-sm mb-4" style="color:#F5B800">step 03</div>
        <div class="display text-xl mb-3 text-glacier">Drops into your CRM with context</div>
        <p class="text-muted text-sm leading-relaxed">Deal created, source tagged, conversation logged, photos attached. No copy-paste. The pipeline stays honest on its own.</p>
      </div>
      <div class="card p-8" style="--d:300ms">
        <div class="mono text-sm mb-4" style="color:#F5B800">step 04</div>
        <div class="display text-xl mb-3 text-glacier">You see it between jobs</div>
        <p class="text-muted text-sm leading-relaxed">One view on your phone: who replied, what was promised, what needs you. Glance at it in the truck. That's the whole loop.</p>
      </div>
    </div>

    <!-- terminal visual -->
    <div class="mt-16 reveal" style="--d:400ms">
      <div class="rounded-3xl overflow-hidden" style="background:#06282B; color:#F5F2ED; font-family:'Fragment Mono', ui-monospace, monospace; font-size:14px;">
        <div class="px-5 py-3 flex items-center gap-2 text-xs" style="border-bottom:1px solid rgba(245,242,237,0.1); color:rgba(245,242,237,0.6)">
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="ml-4">ai agent · lead intake console</span>
        </div>
        <div class="p-6 space-y-2 leading-7">
          <div><span style="color:#F5B800">→</span> lead #2041 received · source: paid lead channel · 07:12:04</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> parsing message [roof leak, 1-story, zip 30087]</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> service area · match · job type · repair</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> drafting reply · same channel · two time windows offered</div>
          <div><span style="color:#F5B800">✓</span> <span style="color:#F5F2ED">agent:</span> reply sent · elapsed 00:00:47</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> pushing to CRM · deal created · source tagged</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> logging transcript · attaching intake form payload</div>
          <div style="color:rgba(245,242,237,0.5)">—</div>
          <div><span style="color:#F5B800">→</span> lead #2042 received · source: intake form · 07:14:11</div>
          <div><span style="color:#F5B800">✓</span> <span style="color:#F5F2ED">agent:</span> reply sent · elapsed 00:00:52<span class="blink" style="color:#F5B800">_</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FOR / NOT FOR -->
<section id="for" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4">honest qualification</div>
      <h2 class="display text-4xl md:text-6xl text-glacier">Is this for you?</h2>
    </div>

    <div class="mt-16 grid md:grid-cols-2 gap-6">
      <div class="card p-8 md:p-10 reveal">
        <div class="eyebrow mb-5" style="color:#B88A00">built for you if</div>
        <ul class="space-y-4 text-lg text-glacier">
          <li class="flex gap-3"><span class="mono mt-1" style="color:#F5B800">✓</span><span>You run a residential service business doing $3M+ a year</span></li>
          <li class="flex gap-3"><span class="mono mt-1" style="color:#F5B800">✓</span><span>You already run a CRM, an intake form, and a paid lead channel</span></li>
          <li class="flex gap-3"><span class="mono mt-1" style="color:#F5B800">✓</span><span>You're the one checking lead inboxes between jobs</span></li>
          <li class="flex gap-3"><span class="mono mt-1" style="color:#F5B800">✓</span><span>You've lost jobs to a 30-minute response gap</span></li>
          <li class="flex gap-3"><span class="mono mt-1" style="color:#F5B800">✓</span><span>You want a first reply inside 60 seconds on every channel</span></li>
        </ul>
      </div>
      <div class="card p-8 md:p-10 reveal" style="background:#EDE9E5; --d:100ms">
        <div class="eyebrow mb-5">not for you if</div>
        <ul class="space-y-4 text-lg text-muted">
          <li class="flex gap-3"><span class="mono mt-1">—</span><span>You run phone-only — no forms, no paid lead channels, no web leads</span></li>
          <li class="flex gap-3"><span class="mono mt-1">—</span><span>You run enterprise commercial work with long RFP cycles</span></li>
          <li class="flex gap-3"><span class="mono mt-1">—</span><span>A dedicated inside CSR already triages leads full-time</span></li>
          <li class="flex gap-3"><span class="mono mt-1">—</span><span>Your leads live outside a standard CRM or ops board</span></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4">pricing</div>
      <h2 class="display text-4xl md:text-6xl max-w-4xl text-glacier">
        Straightforward.<br />
        <span class="text-muted">No retainer. No surprises.</span>
      </h2>
    </div>

    <div class="mt-16 card reveal overflow-hidden">
      <div class="grid md:grid-cols-2">
        <div class="p-8 md:p-12 border-b md:border-b-0 md:border-r border-hairline">
          <div class="eyebrow mb-4" style="color:#F5B800">to build</div>
          <div class="font-mono text-6xl ticker text-glacier">$500</div>
          <div class="mt-3 text-muted">One-time. Scoped, built, and deployed in about two weeks.</div>
        </div>
        <div class="p-8 md:p-12">
          <div class="eyebrow mb-4">then</div>
          <div class="font-mono text-6xl ticker text-glacier">usage-based</div>
          <div class="mt-3 text-muted">You pay when the agent runs. No seats, no subscription floor.</div>
        </div>
      </div>
    </div>

    <p class="reveal mt-8 text-sm text-muted" style="--d:150ms">
      Full terms and build program details live on the program site →
      <a class="underline hover:text-glacier" href={cta}>shipyourweekendproject.com</a>
    </p>
  </div>
</section>

<!-- CTA -->
<section style="background:#F5B800; color:#093A3E;">
  <div class="max-w-7xl mx-auto px-6 py-24 md:py-32">
    <div class="grid md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-8 reveal">
        <div class="eyebrow mb-4" style="color:#093A3E; opacity:0.7;">waitlist · private beta</div>
        <h2 class="display text-5xl md:text-7xl" style="color:#093A3E">
          Stop triaging leads<br />
          between jobs.
        </h2>
      </div>
      <div class="md:col-span-4 reveal" style="--d:150ms">
        <p class="text-lg mb-6" style="color:rgba(9,58,62,0.8)">
          15 hrs/wk triaging. $11,250 out the door every week. You're the one checking four inboxes between site visits. A small cohort of residential service owners is onboarding this quarter.
        </p>
        <a href={cta} class="inline-flex items-center gap-2 px-6 py-4 text-base font-semibold rounded-full" style="background:#093A3E; color:#F5F2ED; font-family:'Plus Jakarta Sans', sans-serif;">
          Claim a beta seat
          <span aria-hidden>→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer style="background:#093A3E;">
  <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div class="flex items-center gap-4">
      <img src={logo} alt="Sagan" class="h-8 w-auto" />
      <div>
        <div class="mono text-sm" style="color:#F5F2ED">an AI agent · residential service leads</div>
        <div class="mt-1 text-sm" style="color:rgba(245,242,237,0.55)">a build program from <a class="underline hover:text-white" href={cta} style="color:rgba(245,242,237,0.7)">Sagan</a></div>
      </div>
    </div>
    <div class="flex gap-8 text-sm" style="color:rgba(245,242,237,0.6)">
      <a href={cta} class="hover:text-white">waitlist</a>
      <a href="https://getsagan.com" class="hover:text-white">getsagan.com</a>
    </div>
  </div>
</footer>

<script is:inline>
  const io = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
    }
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  document.querySelectorAll('.stagger').forEach(g => {
    Array.from(g.children).forEach((c, i) => { if (!c.style.getPropertyValue('--d')) c.style.setProperty('--d', (i * 90) + 'ms'); });
  });
</script>
<script is:inline src="/hubspot-capture.js" data-portal-id="50517161" data-form-guid="daac2804-e5c3-48e7-8ab7-a5b41c9e7c38"></script>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=Fragment+Mono&display=swap');
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    background: #F5F2ED;
    color: #093A3E;
    -webkit-font-smoothing: antialiased;
  }
  .display {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    letter-spacing: -0.035em;
    line-height: 1.02;
    font-weight: 700;
  }
  .eyebrow {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-size: 12px;
    font-weight: 500;
    color: #4A6B6B;
  }
  .rule { height: 1px; background: rgba(9,58,62,0.06); width: 100%; }
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 900ms cubic-bezier(.2,.7,.2,1), transform 900ms cubic-bezier(.2,.7,.2,1); }
  .reveal.is-in { opacity: 1; transform: none; }
  .stagger > * { transition-delay: var(--d, 0ms); }
  .card {
    background: #FFFFFF;
    border: 1px solid rgba(9,58,62,0.06);
    border-radius: 24px;
  }
  .hover-lift { transition: transform 200ms ease, border-color 200ms ease; }
  .hover-lift:hover { transform: translateY(-2px); border-color: rgba(9,58,62,0.18); }
  .ticker { font-family: 'Fragment Mono', ui-monospace, monospace; font-variant-numeric: tabular-nums; }
  .mono { font-family: 'Fragment Mono', ui-monospace, monospace; }
  .dot::before {
    content: ''; display: inline-block; width: 6px; height: 6px;
    border-radius: 999px; background: #F5B800;
    margin-right: 10px; vertical-align: middle; transform: translateY(-2px);
