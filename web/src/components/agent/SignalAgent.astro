---
/* Faithful port of /agent/signal. Mirrors the agent/ group pattern (see
 * FreightAgent.astro): Tailwind CDN + inline config + the page's custom
 * <style>, bespoke body verbatim, with hero copy + CTA URL driven by the
 * `agentDemo` Sanity doc. Isolated via its own route file so the generic
 * class names don't collide. */
import type { AgentDemoData } from '../../lib/agentDemos';

interface Props {
  data: AgentDemoData;
}
const { data } = Astro.props;
const cta = data.ctaUrl ?? 'https://www.shipyourweekendproject.com/';
const logo = '/agent/signal/sagan-logo.png';
---

<!-- HubSpot Embed Code -->
<script type="text/javascript" id="hs-script-loader" async defer src="//js.hs-scripts.com/50517161.js" is:inline></script>

<!-- Tailwind CDN + theme config (kept verbatim from the source page) -->
<script is:inline src="https://cdn.tailwindcss.com"></script>
<script is:inline>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          glacier:    '#093A3E',
          'glacier-dark': '#06282B',
          muted:      '#4A6B6B',
          cream:      '#F5F2ED',
          'cream-deep': '#EDE9E5',
          white:      '#FFFFFF',
          dandelion:  '#F5B800',
          'sagan-blue': '#2197FF',
          hairline:   'rgba(9,58,62,0.06)',
          'hairline-strong': 'rgba(9,58,62,0.18)'
        },
        fontFamily: {
          display: ['Plus Jakarta Sans', 'system-ui', 'sans-serif'],
          body:    ['Space Grotesk', 'system-ui', 'sans-serif'],
          mono:    ['Fragment Mono', 'ui-monospace', 'SFMono-Regular', 'monospace']
        }
      }
    }
  }
</script>

<!-- NAV -->
<nav class="sticky top-0 z-50 backdrop-blur bg-cream/85 border-b border-hairline">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="#" class="flex items-center gap-3">
      <img src={logo} alt="Sagan" class="h-7 w-auto" />
      <span class="font-mono text-sm text-muted">an AI agent · by Sagan<span aria-hidden="true" style="display:inline-block;width:8px;height:8px;background:#2197FF;border-radius:999px;margin-left:4px;vertical-align:baseline;transform:translateY(-1px);box-shadow:0 0 10px rgba(33,151,255,0.35);"></span></span>
    </a>
    <div class="hidden md:flex items-center gap-8 text-sm text-glacier/80">
      <a href="#pain" class="hover:text-glacier">the problem</a>
      <a href="#how" class="hover:text-glacier">how it works</a>
      <a href="#pricing" class="hover:text-glacier">pricing</a>
      <a href="#for" class="hover:text-glacier">is this for you</a>
    </div>
    <a href={cta} class="btn-primary text-sm" style="padding:10px 20px;">
      Join the waitlist
      <span aria-hidden>→</span>
    </a>
  </div>
</nav>

<!-- HERO -->
<header class="border-b border-hairline relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 pt-20 pb-24 md:pt-28 md:pb-32 relative">
    <div class="reveal">
      <div class="eyebrow mb-8"><span class="dot"></span>{data.heroEyebrow}</div>
      <h1 class="display text-5xl md:text-7xl text-glacier" set:html={data.heroHeadlineHtml}></h1>
    </div>

    <div class="reveal mt-10 max-w-2xl text-lg md:text-xl text-muted leading-relaxed" style="--d:150ms" set:html={data.heroLeadHtml}></div>

    <div class="reveal mt-10 flex flex-col sm:flex-row gap-4" style="--d:300ms">
      <a href={cta} class="btn-primary">
        Join the waitlist
        <span aria-hidden>→</span>
      </a>
      <a href="#pain" class="btn-secondary">
        See the math
      </a>
    </div>

    <!-- signals-sourced diagram -->
    <div class="reveal mt-20 card p-6 md:p-10" style="--d:450ms">
      <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-16">
        <div class="flex-1">
          <div class="eyebrow mb-3">before</div>
          <div class="font-mono text-5xl md:text-6xl ticker text-glacier">2</div>
          <div class="mt-2 text-muted">signals you saw first this quarter</div>
        </div>
        <div class="hidden md:block text-dandelion text-4xl font-mono">→</div>
        <div class="flex-1">
          <div class="eyebrow mb-3" style="color:#093A3E">after</div>
          <div class="font-mono text-5xl md:text-6xl ticker" style="color:#F5B800">14</div>
          <div class="mt-2 text-muted">signals you saw first this quarter</div>
        </div>
        <div class="flex-1 md:border-l md:border-hairline md:pl-10">
          <div class="eyebrow mb-3">window</div>
          <div class="font-mono text-5xl md:text-6xl ticker text-glacier">6<span class="text-muted text-2xl">wks</span></div>
          <div class="mt-2 text-muted">ahead of the commercial lists</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ambient marquee -->
  <div class="border-t border-hairline py-4 overflow-hidden font-mono text-xs text-muted">
    <div class="marquee whitespace-nowrap">
      <span>licensing database update → parsed · regulatory filing → flagged · platform data churn → scored · local news → clipped · your CRM → routed · obit scan → cross-checked · licensing database update → parsed · regulatory filing → flagged · platform data churn → scored · local news → clipped · your CRM → routed · obit scan → cross-checked ·&nbsp;</span>
      <span>licensing database update → parsed · regulatory filing → flagged · platform data churn → scored · local news → clipped · your CRM → routed · obit scan → cross-checked · licensing database update → parsed · regulatory filing → flagged · platform data churn → scored · local news → clipped · your CRM → routed · obit scan → cross-checked ·&nbsp;</span>
    </div>
  </div>
</header>

<!-- THE PROBLEM -->
<section id="pain" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5 reveal">
        <div class="eyebrow mb-4">the problem</div>
        <h2 class="display text-4xl md:text-5xl text-glacier">
          Every buy-side<br />advisor is reading<br />the same stale list.
        </h2>
      </div>
      <div class="md:col-span-7 reveal" style="--d:150ms">
        <p class="text-xl md:text-2xl text-glacier leading-relaxed">
          A fixed universe of medical-sector businesses — and most never hit a commercial database until it's too late to bring to your clients. The signals that actually predict a sale — a death notice, a license transfer, a platform-data churn event — are public, scattered, and land in your workflow weeks late.
        </p>
        <p class="mt-8 text-lg text-muted leading-relaxed">
          You and one analyst cannot read every licensing update, every regulatory filing, every small-town obit, and every regional trade item. So the feeds get skimmed on Friday afternoons, and the deal that was already in motion Tuesday shows up in a broker email next month — after your best client already got pitched by someone else.
        </p>
      </div>
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-6 reveal stagger">
      <div class="card p-8 hover-lift" style="--d:0ms">
        <div class="font-mono text-dandelion text-sm mb-2">01</div>
        <div class="font-display font-semibold text-lg mb-2 text-glacier">The commercial lists are stale</div>
        <p class="text-muted text-sm leading-relaxed">$20K+ a year for a database that refreshes quarterly — and every other advisory firm in the vertical reads the same one.</p>
      </div>
      <div class="card p-8 hover-lift" style="--d:100ms">
        <div class="font-mono text-dandelion text-sm mb-2">02</div>
        <div class="font-display font-semibold text-lg mb-2 text-glacier">Manual signal-hunting doesn't scale</div>
        <p class="text-muted text-sm leading-relaxed">Fifteen hours a week reading licensing changes and regulatory filings, and you still miss the ones that would move a client conversation.</p>
      </div>
      <div class="card p-8 hover-lift" style="--d:200ms">
        <div class="font-mono text-dandelion text-sm mb-2">03</div>
        <div class="font-display font-semibold text-lg mb-2 text-glacier">By the time you see it, there's an LOI</div>
        <p class="text-muted text-sm leading-relaxed">The death notice, the license transfer, the telemetry churn — once any of it hits a newsletter or a broker blast, someone else has already walked it into your client's inbox.</p>
      </div>
    </div>
  </div>
</section>

<!-- THE MATH -->
<section class="border-b border-hairline" style="background:#06282B; color:#F5F2ED;">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4" style="color:#F5B800">the math, if you want to look</div>
      <h2 class="display text-4xl md:text-6xl max-w-4xl" style="color:#F5F2ED">
        720 deals move<br />
        in your universe each year —<br />
        <span style="color:#F5B800">twenty</span> <span style="opacity:0.6">land on your desk early.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-4 gap-6 reveal stagger">
      <div class="p-8" style="background:#093A3E; border-radius:24px; border:1px solid rgba(245,242,237,0.08);">
        <div class="font-mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">TARGET UNIVERSE</div>
        <div class="font-mono text-5xl ticker" style="color:#F5F2ED">24,000</div>
      </div>
      <div class="p-8" style="background:#093A3E; border-radius:24px; border:1px solid rgba(245,242,237,0.08);">
        <div class="font-mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">SIGNALS / YR</div>
        <div class="font-mono text-5xl ticker" style="color:#F5F2ED">~720</div>
      </div>
      <div class="p-8" style="background:#093A3E; border-radius:24px; border:1px solid rgba(245,242,237,0.08);">
        <div class="font-mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">SIGNALS SEEN EARLY</div>
        <div class="font-mono text-5xl ticker" style="color:#F5B800">20</div>
      </div>
      <div class="p-8" style="background:#093A3E; border-radius:24px; border:1px solid rgba(245,242,237,0.08);">
        <div class="font-mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">$ CREATED / YR</div>
        <div class="font-mono text-5xl ticker" style="color:#F5B800">$12M</div>
      </div>
    </div>

    <p class="reveal mt-10 max-w-3xl" style="--d:450ms; color:rgba(245,242,237,0.7)">
      Roughly 3% annual turnover across your target universe = about 720 ownership events every year. A typical deal is $4M. Walking one to your buyer six weeks earlier than the competition is worth about 15% on terms — call it $600K. Twenty of those in a year is $12M of value the agent puts back on the table for your clients.
    </p>
  </div>
</section>

<!-- HOW -->
<section id="how" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4">how it works</div>
      <h2 class="display text-4xl md:text-6xl max-w-4xl text-glacier">
        Your feeds, already public —<br />
        <span style="color:#F5B800">one</span> <span class="text-muted">agent reading them in real time.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-4 gap-6 reveal stagger">
      <div class="card p-8" style="--d:0ms">
        <div class="font-mono text-sm text-dandelion mb-4">step 01</div>
        <div class="font-display font-semibold text-xl mb-3 text-glacier">Feeds get watched</div>
        <p class="text-muted text-sm leading-relaxed">The agent monitors licensing databases, regulatory filings, regional obits, local news, and platform-data churn — continuously.</p>
      </div>
      <div class="card p-8" style="--d:100ms">
        <div class="font-mono text-sm text-dandelion mb-4">step 02</div>
        <div class="font-display font-semibold text-xl mb-3 text-glacier">Signals get scored</div>
        <p class="text-muted text-sm leading-relaxed">The agent cross-checks each event against your target universe, tags it by signal type, and scores the likelihood of an ownership transition in the next 90 days.</p>
      </div>
      <div class="card p-8" style="--d:200ms">
        <div class="font-mono text-sm text-dandelion mb-4">step 03</div>
        <div class="font-display font-semibold text-xl mb-3 text-glacier">Matches land in your CRM</div>
        <p class="text-muted text-sm leading-relaxed">High-score matches drop into your CRM as new targets — every source link, every cross-reference, and a short written rationale attached.</p>
      </div>
      <div class="card p-8" style="--d:300ms">
        <div class="font-mono text-sm text-dandelion mb-4">step 04</div>
        <div class="font-display font-semibold text-xl mb-3 text-glacier">You reach out first</div>
        <p class="text-muted text-sm leading-relaxed">You see the signal the week it happens — not the quarter a commercial database refreshes. You walk it to your client before a broker packet exists.</p>
      </div>
    </div>

    <!-- terminal visual -->
    <div class="mt-16 reveal" style="--d:400ms">
      <div class="font-mono text-sm" style="background:#06282B; color:#F5F2ED; border-radius:24px; border:1px solid rgba(9,58,62,0.06); overflow:hidden;">
        <div class="px-5 py-3 flex items-center gap-2 text-xs" style="border-bottom:1px solid rgba(245,242,237,0.1); color:rgba(245,242,237,0.6);">
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="ml-4">ai agent · deal-flow console</span>
        </div>
        <div class="p-6 space-y-2 leading-7">
          <div><span style="color:#F5B800">→</span> agent: licensing database update detected · target #1639284716 · medical sector · TX</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> cross-ref regulatory filings · ownership transfer filed 6 days ago</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> cross-ref local news · founder obituary, same county, same month</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> cross-ref operational telemetry · tenant inactive 11 days</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> scoring signal · <span style="color:#F5B800">0.91</span> · ownership transition &lt;90d</div>
          <div><span style="color:#F5B800">✓</span> agent: match routed · <span style="color:#F5F2ED">your CRM · new target created</span></div>
          <div style="color:rgba(245,242,237,0.5)">—</div>
          <div><span style="color:#F5B800">total elapsed</span>: 00:00:38<span class="blink" style="color:#F5B800">_</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FOR / NOT FOR -->
<section id="for" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4">honest qualification</div>
      <h2 class="display text-4xl md:text-6xl text-glacier">Is this for you?</h2>
    </div>

    <div class="mt-16 grid md:grid-cols-2 gap-6">
      <div class="card p-8 md:p-10 reveal">
        <div class="eyebrow mb-5" style="color:#093A3E">built for you if</div>
        <ul class="space-y-4 text-lg">
          <li class="flex gap-3"><span style="color:#F5B800" class="font-mono mt-1">✓</span><span class="text-glacier">You run a buy-side advisory firm sourcing medical-sector deals for PE, family-office, or strategic-buyer clients</span></li>
          <li class="flex gap-3"><span style="color:#F5B800" class="font-mono mt-1">✓</span><span class="text-glacier">You already use licensing databases, regulatory filings, and operational telemetry as inputs</span></li>
          <li class="flex gap-3"><span style="color:#F5B800" class="font-mono mt-1">✓</span><span class="text-glacier">You're a one- to four-person partner team running sourcing yourself, not outsourcing it</span></li>
          <li class="flex gap-3"><span style="color:#F5B800" class="font-mono mt-1">✓</span><span class="text-glacier">You're tired of paying $20K+ for commercial lists every other advisor also reads</span></li>
          <li class="flex gap-3"><span style="color:#F5B800" class="font-mono mt-1">✓</span><span class="text-glacier">You want signals routed into your CRM, not another dashboard to check</span></li>
        </ul>
      </div>
      <div class="card p-8 md:p-10 reveal" style="--d:100ms; background:#EDE9E5;">
        <div class="eyebrow mb-5">not for you if</div>
        <ul class="space-y-4 text-lg text-muted">
          <li class="flex gap-3"><span class="font-mono mt-1">—</span><span>Your deal flow comes entirely from broker packets and intermediaries</span></li>
          <li class="flex gap-3"><span class="font-mono mt-1">—</span><span>Your clients invest in industries with no public regulatory footprint</span></li>
          <li class="flex gap-3"><span class="font-mono mt-1">—</span><span>You want a CRM, not an agent that acts on signals</span></li>
          <li class="flex gap-3"><span class="font-mono mt-1">—</span><span>Your analyst likes the Friday-afternoon reading sessions</span></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4">pricing</div>
      <h2 class="display text-4xl md:text-6xl max-w-4xl text-glacier">
        Straightforward —<br />
        <span style="color:#F5B800">no</span> <span class="text-muted">retainer. No surprises.</span>
      </h2>
    </div>

    <div class="mt-16 card reveal overflow-hidden">
      <div class="grid md:grid-cols-2">
        <div class="p-8 md:p-12 border-b md:border-b-0 md:border-r border-hairline">
          <div class="eyebrow mb-4" style="color:#F5B800">to build</div>
          <div class="font-mono text-6xl ticker text-glacier">$500</div>
          <div class="mt-3 text-muted">One-time. Scoped, built, and deployed in about two weeks.</div>
        </div>
        <div class="p-8 md:p-12">
          <div class="eyebrow mb-4">then</div>
          <div class="font-mono text-6xl ticker text-glacier">usage-based</div>
          <div class="mt-3 text-muted">You pay when the agent runs. No seats, no subscription floor.</div>
        </div>
      </div>
    </div>

    <p class="reveal mt-8 text-sm text-muted" style="--d:150ms">
      Full rate card and terms live on the program site →
      <a class="underline hover:text-glacier" href={cta}>shipyourweekendproject.com</a>
    </p>
  </div>
</section>

<!-- CTA -->
<section class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-24 md:py-32">
    <div class="grid md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-8 reveal">
        <div class="eyebrow mb-4">waitlist · private beta</div>
        <h2 class="display text-5xl md:text-7xl text-glacier">
          See the deals<br />
          before anyone else —<br />
          <span style="color:#F5B800">first</span>.
        </h2>
      </div>
      <div class="md:col-span-4 reveal" style="--d:150ms">
        <p class="text-lg mb-6 text-muted">
          720 ownership events a year in your universe. You see twenty of them six weeks early. One extra deal walked to a client pays for the agent for a decade. A small cohort onboards this quarter.
        </p>
        <a href={cta} class="btn-primary">
          Claim a beta seat
          <span aria-hidden>→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="bg-cream text-muted text-sm">
  <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div class="flex items-center gap-3">
      <img src={logo} alt="Sagan" class="h-7 w-auto" />
      <div>
        <div class="font-mono text-glacier">an AI agent · deal-flow intelligence</div>
        <div class="mt-1 text-muted">a build program from <a class="underline hover:text-glacier" href={cta}>Sagan</a></div>
      </div>
    </div>
    <div class="flex gap-8">
      <a href={cta} class="hover:text-glacier">waitlist</a>
      <a href="https://getsagan.com" class="hover:text-glacier">getsagan.com</a>
    </div>
  </div>
</footer>

<script is:inline>
  const io = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
    }
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  document.querySelectorAll('.stagger').forEach(g => {
    Array.from(g.children).forEach((c, i) => { if (!c.style.getPropertyValue('--d')) c.style.setProperty('--d', (i * 90) + 'ms'); });
  });
</script>
<script is:inline src="/hubspot-capture.js" data-portal-id="50517161" data-form-guid="daac2804-e5c3-48e7-8ab7-a5b41c9e7c38"></script>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=Fragment+Mono&display=swap');
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    background: #F5F2ED;
    color: #093A3E;
    -webkit-font-smoothing: antialiased;
  }
  .font-display { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; }
  .font-mono    { font-family: 'Fragment Mono', ui-monospace, monospace; font-feature-settings: "tnum"; }
  .display { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; letter-spacing: -0.035em; line-height: 1.02; font-weight: 800; }
  .eyebrow { font-family: 'Space Grotesk', system-ui, sans-serif; letter-spacing: 0.2em; text-transform: uppercase; font-size: 12px; font-weight: 500; color: #4A6B6B; }
  .rule { height: 1px; background: rgba(9,58,62,0.06); width: 100%; }
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 900ms cubic-bezier(.2,.7,.2,1), transform 900ms cubic-bezier(.2,.7,.2,1); }
  .reveal.is-in { opacity: 1; transform: none; }
  .stagger > * { transition-delay: var(--d, 0ms); }
  .hover-lift { transition: transform 200ms ease, border-color 200ms ease; }
  .hover-lift:hover { transform: translateY(-2px); border-color: rgba(9,58,62,0.18); }
  .ticker { font-variant-numeric: tabular-nums; }
  .dot::before { content: ''; display: inline-block; width: 6px; height: 6px; border-radius: 999px; background: #F5B800; margin-right: 10px; vertical-align: middle; transform: translateY(-2px); }
