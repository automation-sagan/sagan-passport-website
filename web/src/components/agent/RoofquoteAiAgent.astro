---
/* Faithful port of /agent/roofquote-ai. Modeled on the agent/ group reference
 * (FreightAgent.astro): Tailwind CDN + inline config + the page's custom <style>,
 * bespoke body verbatim, with hero copy + CTA URL driven by the `agentDemo`
 * Sanity doc. Isolated via its own route file so the generic class names don't
 * collide. NOTE: the source page has no logo image — the nav/footer use a
 * text-only "an AI agent · by Sagan" treatment, reproduced verbatim. */
import type { AgentDemoData } from '../../lib/agentDemos';

interface Props {
  data: AgentDemoData;
}
const { data } = Astro.props;
const cta = data.ctaUrl ?? 'https://www.shipyourweekendproject.com/';
---

<!-- Tailwind CDN + theme config (kept verbatim from the source page) -->
<script is:inline src="https://cdn.tailwindcss.com"></script>
<script is:inline>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          ink: '#0A0A0A',
          paper: '#FAFAF7',
          char: '#1C1C1C',
          ember: '#E8502C',
          ash:   '#8A8A85',
          line:  '#E5E2DA'
        },
        fontFamily: {
          sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
          mono: ['JetBrains Mono', 'ui-monospace', 'SFMono-Regular', 'monospace']
        }
      }
    }
  }
</script>

<!-- NAV -->
<nav class="sticky top-0 z-50 backdrop-blur bg-paper/85 border-b border-line">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="#" class="font-mono text-sm text-char/70">an AI agent · by Sagan</a>
    <div class="hidden md:flex items-center gap-8 text-sm text-char/80">
      <a href="#pain" class="hover:text-ink">the problem</a>
      <a href="#how" class="hover:text-ink">how it works</a>
      <a href="#pricing" class="hover:text-ink">pricing</a>
      <a href="#for" class="hover:text-ink">is this for you</a>
    </div>
    <a href={cta} class="group inline-flex items-center gap-2 bg-ink text-paper px-4 py-2 text-sm font-medium">
      Join the waitlist
      <span aria-hidden class="transition-transform group-hover:translate-x-0.5">→</span>
    </a>
  </div>
</nav>

<!-- HERO -->
<header class="border-b border-line relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 pt-20 pb-24 md:pt-28 md:pb-32 relative">
    <div class="reveal">
      <div class="eyebrow text-ember mb-8"><span class="dot"></span>{data.heroEyebrow}</div>
      <h1 class="display text-6xl md:text-8xl font-semibold text-ink" set:html={data.heroHeadlineHtml}></h1>
    </div>

    <div class="reveal mt-10 max-w-2xl text-lg md:text-xl text-char/80 leading-relaxed" style="--d:150ms" set:html={data.heroLeadHtml}></div>

    <div class="reveal mt-10 flex flex-col sm:flex-row gap-4" style="--d:300ms">
      <a href={cta} class="inline-flex items-center justify-center gap-2 bg-ink text-paper px-6 py-4 text-base font-medium hover:bg-ember transition-colors">
        Join the waitlist
        <span aria-hidden>→</span>
      </a>
      <a href="#pain" class="inline-flex items-center justify-center gap-2 border border-ink text-ink px-6 py-4 text-base font-medium hover:bg-ink hover:text-paper transition-colors">
        See the math
      </a>
    </div>

    <!-- timer diagram -->
    <div class="reveal mt-20 border border-line bg-white p-6 md:p-10" style="--d:450ms">
      <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-16">
        <div class="flex-1">
          <div class="eyebrow text-ash mb-3">before</div>
          <div class="font-mono text-5xl md:text-6xl ticker">04:30:00</div>
          <div class="mt-2 text-char/70">estimator time, per quote</div>
        </div>
        <div class="hidden md:block text-ember text-4xl font-mono">→</div>
        <div class="flex-1">
          <div class="eyebrow text-ember mb-3">after</div>
          <div class="font-mono text-5xl md:text-6xl ticker text-ember">00:30:00</div>
          <div class="mt-2 text-char/70">estimator reviews &amp; sends</div>
        </div>
        <div class="flex-1 md:border-l md:border-line md:pl-10">
          <div class="eyebrow text-ash mb-3">recovered</div>
          <div class="font-mono text-5xl md:text-6xl ticker">4:00<span class="text-ash text-2xl">/quote</span></div>
          <div class="mt-2 text-char/70">hours back in the business</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ambient marquee -->
  <div class="border-t border-line py-4 overflow-hidden font-mono text-xs text-ash">
    <div class="marquee whitespace-nowrap">
      <span>CompanyCam photos → tagged · iRoof measurements → pulled · pricing → line-itemed · Google Sheet → formatted · PDF → sent · CompanyCam photos → tagged · iRoof measurements → pulled · pricing → line-itemed · Google Sheet → formatted · PDF → sent ·&nbsp;</span>
      <span>CompanyCam photos → tagged · iRoof measurements → pulled · pricing → line-itemed · Google Sheet → formatted · PDF → sent · CompanyCam photos → tagged · iRoof measurements → pulled · pricing → line-itemed · Google Sheet → formatted · PDF → sent ·&nbsp;</span>
    </div>
  </div>
</header>

<!-- THE MONDAY -->
<section id="pain" class="border-b border-line">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5 reveal">
        <div class="eyebrow text-ash mb-4">the problem</div>
        <h2 class="display text-4xl md:text-5xl font-semibold">
          You've had<br />this Monday<br />before.
        </h2>
      </div>
      <div class="md:col-span-7 reveal" style="--d:150ms">
        <p class="text-xl md:text-2xl text-char/85 leading-relaxed">
          A storm rolled through Saturday. By Monday eleven inspections are stacked on your board. It's 9pm and you're the one matching shingles to photos, squinting at iRoof diagrams, keying pricing into a spreadsheet somebody built in 2018.
        </p>
        <p class="mt-8 text-lg text-char/75 leading-relaxed">
          Three of those quotes will go out Friday instead of Tuesday. One homeowner will have already signed with someone faster. One will ghost. And the crew that could have been on a roof this week will start next week instead.
        </p>
      </div>
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-px bg-line border border-line reveal stagger">
      <div class="bg-paper p-8 hover-lift" style="--d:0ms">
        <div class="font-mono text-ember text-sm mb-2">01</div>
        <div class="font-semibold text-lg mb-2">Quotes out days late</div>
        <p class="text-char/75 text-sm leading-relaxed">The first quote in the door wins. You know this already — you've lost deals to it.</p>
      </div>
      <div class="bg-paper p-8 hover-lift" style="--d:100ms">
        <div class="font-mono text-ember text-sm mb-2">02</div>
        <div class="font-semibold text-lg mb-2">You are the bottleneck</div>
        <p class="text-char/75 text-sm leading-relaxed">You can't scale without taking the quoting off your own plate. Another estimator costs $80k and takes six months to train — you've been resisting it for a reason.</p>
      </div>
      <div class="bg-paper p-8 hover-lift" style="--d:200ms">
        <div class="font-mono text-ember text-sm mb-2">03</div>
        <div class="font-semibold text-lg mb-2">Margin leaks in the line items</div>
        <p class="text-char/75 text-sm leading-relaxed">Tired estimators forget flashing. Forget drip edge. Forget the fourteenth course of shingles on the dormer. You eat the change order.</p>
      </div>
    </div>
  </div>
</section>

<!-- THE MATH -->
<section class="border-b border-line bg-ink text-paper">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow text-ember mb-4">the math, if you want to look</div>
      <h2 class="display text-4xl md:text-6xl font-semibold max-w-4xl">
        At eight quotes a week,<br />
        that's <span class="text-ember">thirty-six hours</span>.<br />
        <span class="text-paper/60">A whole human.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-4 gap-px bg-paper/10 border border-paper/10 reveal stagger">
      <div class="bg-ink p-8" style="--d:0ms">
        <div class="font-mono text-xs text-paper/50 mb-2">QUOTES / WEEK</div>
        <div class="font-mono text-5xl ticker">8</div>
      </div>
      <div class="bg-ink p-8" style="--d:100ms">
        <div class="font-mono text-xs text-paper/50 mb-2">HRS SAVED / QUOTE</div>
        <div class="font-mono text-5xl ticker text-ember">4.0</div>
      </div>
      <div class="bg-ink p-8" style="--d:200ms">
        <div class="font-mono text-xs text-paper/50 mb-2">HRS BACK / WEEK</div>
        <div class="font-mono text-5xl ticker">32</div>
      </div>
      <div class="bg-ink p-8" style="--d:300ms">
        <div class="font-mono text-xs text-paper/50 mb-2">$ / WEEK LEAKING</div>
        <div class="font-mono text-5xl ticker text-ember">$3,200<span class="text-paper/50 text-2xl">/wk</span></div>
      </div>
    </div>

    <p class="reveal mt-10 text-paper/70 max-w-3xl" style="--d:450ms">
      32 hours × $100/hr owner-loaded cost = $3,200 a week of your time buried in spreadsheets. Over a year, that's more than double the $80k estimator hire you've been resisting — and it's coming out of the one person the business can't replace.
    </p>
  </div>
</section>

<!-- HOW -->
<section id="how" class="border-b border-line">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow text-ash mb-4">how it works</div>
      <h2 class="display text-4xl md:text-6xl font-semibold max-w-4xl">
        Your tools, already in place.<br />
        <span class="text-char/60">One new step between them.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-4 gap-0 reveal stagger">
      <div class="border border-line p-8 md:border-r-0" style="--d:0ms">
        <div class="font-mono text-sm text-ember mb-4">step 01</div>
        <div class="font-semibold text-xl mb-3">Inspection happens</div>
        <p class="text-char/75 text-sm leading-relaxed">Your crew shoots CompanyCam photos and drops iRoof measurements the way they already do.</p>
      </div>
      <div class="border border-line p-8 md:border-r-0" style="--d:100ms">
        <div class="font-mono text-sm text-ember mb-4">step 02</div>
        <div class="font-semibold text-xl mb-3">The agent reads it</div>
        <p class="text-char/75 text-sm leading-relaxed">Photos get tagged. Measurements get pulled. Line items get priced against your template. A draft Google Sheet is built.</p>
      </div>
      <div class="border border-line p-8 md:border-r-0" style="--d:200ms">
        <div class="font-mono text-sm text-ember mb-4">step 03</div>
        <div class="font-semibold text-xl mb-3">Estimator reviews</div>
        <p class="text-char/75 text-sm leading-relaxed">The draft lands in the estimator's inbox with every photo referenced. Thirty minutes to sanity-check, adjust, and send.</p>
      </div>
      <div class="border border-line p-8" style="--d:300ms">
        <div class="font-mono text-sm text-ember mb-4">step 04</div>
        <div class="font-semibold text-xl mb-3">Homeowner signs</div>
        <p class="text-char/75 text-sm leading-relaxed">Proposal lands the same day as the inspection. The homeowner hasn't called three other roofers yet. You close it.</p>
      </div>
    </div>

    <!-- terminal visual -->
    <div class="mt-16 reveal" style="--d:400ms">
      <div class="border border-line bg-ink text-paper font-mono text-sm">
        <div class="border-b border-paper/10 px-5 py-3 flex items-center gap-2 text-paper/60 text-xs">
          <span class="w-2.5 h-2.5 rounded-full bg-paper/20"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-paper/20"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-paper/20"></span>
          <span class="ml-4">ai agent · estimator console</span>
        </div>
        <div class="p-6 space-y-2 leading-7">
          <div><span class="text-ember">→</span> inspection #4821 received · 47 photos, iRoof report attached</div>
          <div><span class="text-ash">··</span> tagging photos [shingle damage, flashing gap, gutter, valley]</div>
          <div><span class="text-ash">··</span> measurements parsed · 24.3 squares, 6/12 pitch, 2 valleys</div>
          <div><span class="text-ash">··</span> pricing against template · repair tier · 2026 pricing</div>
          <div><span class="text-ash">··</span> drafting line items [14]</div>
          <div><span class="text-ember">✓</span> quote draft ready · <span class="text-paper">sent to estimator@</span></div>
          <div class="text-paper/50">—</div>
          <div><span class="text-ember">total elapsed</span>: 00:04:12<span class="blink text-ember">_</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FOR / NOT FOR -->
<section id="for" class="border-b border-line">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow text-ash mb-4">honest qualification</div>
      <h2 class="display text-4xl md:text-6xl font-semibold">Is this for you?</h2>
    </div>

    <div class="mt-16 grid md:grid-cols-2 gap-0 border border-line">
      <div class="p-8 md:p-10 border-b md:border-b-0 md:border-r border-line reveal">
        <div class="eyebrow text-ember mb-5">built for you if</div>
        <ul class="space-y-4 text-lg">
          <li class="flex gap-3"><span class="text-ember font-mono mt-1">✓</span><span>You run a residential roofing operation doing $3M+ a year</span></li>
          <li class="flex gap-3"><span class="text-ember font-mono mt-1">✓</span><span>Your team already uses CompanyCam + iRoof for inspections</span></li>
          <li class="flex gap-3"><span class="text-ember font-mono mt-1">✓</span><span>Your estimator is the bottleneck on how fast you can grow</span></li>
          <li class="flex gap-3"><span class="text-ember font-mono mt-1">✓</span><span>You've lost deals because a competitor quoted faster</span></li>
          <li class="flex gap-3"><span class="text-ember font-mono mt-1">✓</span><span>You want detail in your quotes — not a one-page estimate</span></li>
        </ul>
      </div>
      <div class="p-8 md:p-10 bg-paper reveal" style="--d:100ms">
        <div class="eyebrow text-ash mb-5">not for you if</div>
        <ul class="space-y-4 text-lg text-char/75">
          <li class="flex gap-3"><span class="text-ash font-mono mt-1">—</span><span>You don't use CompanyCam or iRoof in the field</span></li>
          <li class="flex gap-3"><span class="text-ash font-mono mt-1">—</span><span>Your quotes are handshake-and-a-number on a napkin</span></li>
          <li class="flex gap-3"><span class="text-ash font-mono mt-1">—</span><span>You do mostly new construction bids, not repair/replacement</span></li>
          <li class="flex gap-3"><span class="text-ash font-mono mt-1">—</span><span>Your estimator enjoys the weekend spreadsheet work</span></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" class="border-b border-line">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow text-ash mb-4">pricing</div>
      <h2 class="display text-4xl md:text-6xl font-semibold max-w-4xl">
        Straightforward.<br />
        <span class="text-char/60">No retainer. No surprises.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-2 gap-0 border border-line reveal">
      <div class="p-8 md:p-12 border-b md:border-b-0 md:border-r border-line">
        <div class="eyebrow text-ember mb-4">to build</div>
        <div class="font-mono text-6xl ticker">$500</div>
        <div class="mt-3 text-char/75">One-time. Scoped, built, and deployed in about two weeks.</div>
      </div>
      <div class="p-8 md:p-12">
        <div class="eyebrow text-ash mb-4">then</div>
        <div class="font-mono text-6xl ticker">usage-based</div>
        <div class="mt-3 text-char/75">You pay when the agent runs. No seats, no subscription floor.</div>
      </div>
    </div>

    <p class="reveal mt-8 text-sm text-char/70" style="--d:150ms">
      Full rate card and terms live on the program site →
      <a class="underline hover:text-ink" href={cta}>shipyourweekendproject.com</a>
    </p>
  </div>
</section>

<!-- CTA -->
<section class="bg-ember text-ink">
  <div class="max-w-7xl mx-auto px-6 py-24 md:py-32">
    <div class="grid md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-8 reveal">
        <div class="eyebrow mb-4">waitlist · private beta</div>
        <h2 class="display text-5xl md:text-7xl font-semibold">
          Stop writing quotes<br />at&nbsp;11pm.
        </h2>
      </div>
      <div class="md:col-span-4 reveal" style="--d:150ms">
        <p class="text-lg mb-6 text-ink/80">
          32 hours a week. $3,200 of your time. More than an $80k hire costs — and you're the one bleeding it. A small cohort of roofers is being onboarded this quarter.
        </p>
        <a href={cta} class="inline-flex items-center gap-2 bg-ink text-paper px-6 py-4 text-base font-medium hover:bg-char transition-colors">
          Join the waitlist
          <span aria-hidden>→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="bg-ink text-paper/70 text-sm">
  <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div>
      <div class="font-mono text-paper">an AI agent · roofing estimates</div>
      <div class="mt-1 text-paper/50">a build program from <a class="underline hover:text-paper" href={cta}>Sagan</a></div>
    </div>
    <div class="flex gap-8 text-paper/60">
      <a href={cta} class="hover:text-paper">waitlist</a>
      <a href="https://getsagan.com" class="hover:text-paper">getsagan.com</a>
    </div>
  </div>
</footer>

<script is:inline>
  const io = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
    }
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  document.querySelectorAll('.stagger').forEach(g => {
    Array.from(g.children).forEach((c, i) => { if (!c.style.getPropertyValue('--d')) c.style.setProperty('--d', (i * 90) + 'ms'); });
  });
</script>
<script is:inline src="/hubspot-capture.js" data-portal-id="50517161" data-form-guid="daac2804-e5c3-48e7-8ab7-a5b41c9e7c38"></script>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', system-ui, sans-serif; background: #FAFAF7; color: #0A0A0A; -webkit-font-smoothing: antialiased; }
  .display { letter-spacing: -0.035em; line-height: 0.94; }
  .eyebrow { letter-spacing: 0.16em; text-transform: uppercase; font-size: 11px; font-weight: 500; }
  .rule { height: 1px; background: #E5E2DA; width: 100%; }
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 900ms cubic-bezier(.2,.7,.2,1), transform 900ms cubic-bezier(.2,.7,.2,1); }
  .reveal.is-in { opacity: 1; transform: none; }
  .stagger > * { transition-delay: var(--d, 0ms); }
  .hover-lift { transition: transform 200ms ease, border-color 200ms ease; }
  .hover-lift:hover { transform: translateY(-2px); border-color: #0A0A0A; }
  .ticker { font-variant-numeric: tabular-nums; }
  .grid-lines { background-image: linear-gradient(to right, #E5E2DA 1px, transparent 1px); background-size: 1px 100%; }
  .dot::before { content: ''; display: inline-block; width: 6px; height: 6px; border-radius: 999px; background: #E8502C; margin-right: 10px; vertical-align: middle; transform: translateY(-2px); }
  .marquee { display: flex; animation: marquee 40s linear infinite; gap: 3rem; }
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .blink { animation: blink 1.1s steps(2) infinite; }
  @keyframes blink { 50% { opacity: 0; } }
</style>
