---
/* Faithful port of /agent/freight. Reference component for the agent/ group:
 * Tailwind CDN + inline config + the page's custom <style>, bespoke body
 * verbatim, with hero copy + CTA URL driven by the `agentDemo` Sanity doc.
 * Isolated via its own route file so the generic class names don't collide. */
import type { AgentDemoData } from '../../lib/agentDemos';

interface Props {
  data: AgentDemoData;
}
const { data } = Astro.props;
const cta = data.ctaUrl ?? 'https://www.shipyourweekendproject.com/';
const logo = '/agent/freight/sagan-logo.png';
---

<!-- Tailwind CDN + theme config (kept verbatim from the source page) -->
<script is:inline src="https://cdn.tailwindcss.com"></script>
<script is:inline>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          glacier: '#093A3E',
          'glacier-dark': '#06282B',
          muted: '#4A6B6B',
          cream: '#F5F2ED',
          'cream-deep': '#EDE9E5',
          dandelion: '#F5B800',
          'sagan-blue': '#2197FF',
          hairline: 'rgba(9,58,62,0.06)',
          'hairline-strong': 'rgba(9,58,62,0.10)',
        },
        fontFamily: {
          display: ['Plus Jakarta Sans', 'system-ui', 'sans-serif'],
          sans: ['Space Grotesk', 'system-ui', 'sans-serif'],
          mono: ['Fragment Mono', 'ui-monospace', 'SFMono-Regular', 'monospace'],
        },
      },
    },
  };
</script>

<!-- NAV -->
<nav class="sticky top-0 z-50 backdrop-blur bg-cream/85 border-b border-hairline">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="#" class="flex items-center gap-3">
      <img src={logo} alt="Sagan" class="h-8 w-auto" />
      <span class="font-mono text-sm text-muted">an AI agent · by Sagan<span aria-hidden="true" style="display:inline-block;width:8px;height:8px;background:#2197FF;border-radius:999px;margin-left:4px;vertical-align:baseline;transform:translateY(-1px);box-shadow:0 0 10px rgba(33,151,255,0.35);"></span></span>
    </a>
    <div class="hidden md:flex items-center gap-8 text-sm text-glacier/80">
      <a href="#pain" class="hover:text-glacier">the problem</a>
      <a href="#how" class="hover:text-glacier">how it works</a>
      <a href="#pricing" class="hover:text-glacier">pricing</a>
      <a href="#for" class="hover:text-glacier">is this for you</a>
    </div>
    <a href={cta} class="group inline-flex items-center gap-2 bg-glacier text-cream px-5 py-2.5 text-sm font-medium rounded-full hover:bg-glacier-dark transition-colors">
      Get on the beta waitlist
      <span aria-hidden class="transition-transform group-hover:translate-x-0.5">→</span>
    </a>
  </div>
</nav>

<!-- HERO -->
<header class="border-b border-hairline relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 pt-20 pb-24 md:pt-28 md:pb-32 relative">
    <div class="reveal">
      <div class="eyebrow mb-8"><span class="dot"></span>{data.heroEyebrow}</div>
      <h1 class="display text-5xl md:text-7xl text-glacier" set:html={data.heroHeadlineHtml}></h1>
    </div>

    <div class="reveal mt-10 max-w-2xl text-lg md:text-xl text-glacier/80 leading-relaxed" style="--d:150ms" set:html={data.heroLeadHtml}></div>

    <div class="reveal mt-10 flex flex-col sm:flex-row gap-4" style="--d:300ms">
      <a href={cta} class="inline-flex items-center justify-center gap-2 bg-glacier text-cream px-7 py-4 text-base font-medium rounded-full hover:bg-glacier-dark transition-colors">
        Get on the beta waitlist
        <span aria-hidden>→</span>
      </a>
      <a href="#pain" class="inline-flex items-center justify-center gap-2 border border-glacier text-glacier px-7 py-4 text-base font-medium rounded-full hover:bg-glacier hover:text-cream transition-colors">
        See the $98K math
      </a>
    </div>

    <!-- before/after diagram -->
    <div class="reveal mt-20 s-card p-8 md:p-12" style="--d:450ms">
      <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-16">
        <div class="flex-1">
          <div class="eyebrow mb-3">before</div>
          <div class="ticker text-5xl md:text-6xl text-glacier">11.3<span class="text-muted text-2xl"> hrs/wk</span></div>
          <div class="mt-2 text-muted">coordinator drafting, chasing, aggregating</div>
        </div>
        <div class="hidden md:block text-dandelion text-4xl font-mono">→</div>
        <div class="flex-1">
          <div class="eyebrow mb-3" style="color:#F5B800">after</div>
          <div class="ticker text-5xl md:text-6xl text-glacier">≤ 45<span class="text-muted text-2xl"> min/wk</span></div>
          <div class="mt-2 text-muted">review and approve ranked comparison</div>
        </div>
        <div class="flex-1 md:border-l md:border-hairline md:pl-10">
          <div class="eyebrow mb-3">recovered</div>
          <div class="ticker text-5xl md:text-6xl text-glacier">$98K<span class="text-muted text-2xl">/yr</span></div>
          <div class="mt-2 text-muted">overhead + opportunity cost recovered</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ambient marquee -->
  <div class="border-t border-hairline py-4 overflow-hidden font-mono text-xs text-muted">
    <div class="marquee whitespace-nowrap">
      <span>RFQ drafted · carrier sent · quote received · normalized · compared · dispatched · workspace updated · RFQ drafted · carrier sent · quote received · normalized · compared · dispatched · workspace updated ·&nbsp;</span>
      <span>RFQ drafted · carrier sent · quote received · normalized · compared · dispatched · workspace updated · RFQ drafted · carrier sent · quote received · normalized · compared · dispatched · workspace updated ·&nbsp;</span>
    </div>
  </div>
</header>

<!-- THE PROBLEM -->
<section id="pain" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5 reveal">
        <div class="eyebrow mb-4">the problem</div>
        <h2 class="display text-4xl md:text-5xl text-glacier">
          The best rate<br />is rarely<br />the winning rate.
        </h2>
      </div>
      <div class="md:col-span-7 reveal" style="--d:150ms">
        <p class="text-xl md:text-2xl text-glacier/85 leading-relaxed">
          Sixty to two hundred loads hit your ops workspace every week. Each one needs three carriers pinged, replies chased, and a comparison built on the fly. By the time you decide, half the market has moved.
        </p>
        <p class="mt-8 text-lg text-glacier/75 leading-relaxed">
          The rate that gets accepted isn't the lowest one received &mdash; it's the first one reviewed. Every load where a better quote came in twenty minutes later is a $50 bill you handed back to a carrier.
        </p>
      </div>
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-6 reveal stagger">
      <div class="s-card p-8 hover-lift" style="--d:0ms">
        <div class="font-mono text-dandelion text-sm mb-2">01</div>
        <div class="display text-lg mb-2 text-glacier">Sixty to two hundred RFQs a week</div>
        <p class="text-muted text-sm leading-relaxed">Near-identical emails. Different carriers, different lanes, same template. Your coordinator drafts each one by hand because the variations matter.</p>
      </div>
      <div class="s-card p-8 hover-lift" style="--d:100ms">
        <div class="font-mono text-dandelion text-sm mb-2">02</div>
        <div class="display text-lg mb-2 text-glacier">Forty-eight-hour quote cycles</div>
        <p class="text-muted text-sm leading-relaxed">Responses trickle in across two days. The coordinator chases, re-sends, and retypes into a sheet. Thursday's decision runs on Monday's data.</p>
      </div>
      <div class="s-card p-8 hover-lift" style="--d:200ms">
        <div class="font-mono text-dandelion text-sm mb-2">03</div>
        <div class="display text-lg mb-2 text-glacier">Best rate ≠ winning rate</div>
        <p class="text-muted text-sm leading-relaxed">The quote that gets accepted is the first one reviewed &mdash; not the best one received. $50 per load, thirty loads a week, adds up before anyone notices.</p>
      </div>
    </div>
  </div>
</section>

<!-- THE MATH -->
<section class="border-b border-hairline" style="background:#06282B; color:#F5F2ED">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4" style="color:#F5B800">the math, if you want to look</div>
      <h2 class="display text-4xl md:text-6xl max-w-4xl" style="color:#F5F2ED">
        At thirty loads a week,<br />
        a two-hour-faster decision wins <span style="color:#F5B800">$50 more per load</span>.<br />
        <span style="color:rgba(245,242,237,0.6)">That's $78K a year &mdash; on top of the clerical $20K.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-4 gap-6 reveal stagger">
      <div class="p-8 rounded-3xl" style="background:rgba(245,242,237,0.04); border:1px solid rgba(245,242,237,0.08); --d:0ms">
        <div class="font-mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">RFQs / WEEK</div>
        <div class="ticker text-5xl">80</div>
      </div>
      <div class="p-8 rounded-3xl" style="background:rgba(245,242,237,0.04); border:1px solid rgba(245,242,237,0.08); --d:100ms">
        <div class="font-mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">HRS / WEEK</div>
        <div class="ticker text-5xl" style="color:#F5B800">11+</div>
      </div>
      <div class="p-8 rounded-3xl" style="background:rgba(245,242,237,0.04); border:1px solid rgba(245,242,237,0.08); --d:200ms">
        <div class="font-mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">$ / YR OVERHEAD</div>
        <div class="ticker text-5xl">$20K</div>
      </div>
      <div class="p-8 rounded-3xl" style="background:rgba(245,242,237,0.04); border:1px solid rgba(245,242,237,0.08); --d:300ms">
        <div class="font-mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">$ / YR LEFT ON TABLE</div>
        <div class="ticker text-5xl" style="color:#F5B800">$78K</div>
      </div>
    </div>

    <p class="reveal mt-10 max-w-3xl" style="color:rgba(245,242,237,0.7); --d:450ms">
      80 RFQs × ~4 minutes of drafting and aggregation, at a $35/hr loaded coordinator rate, runs about $20K a year in overhead. The bigger number is quieter: $50 per load × 30 loads a week × 52 weeks = $78K a year leaking out through decisions made on stale quotes. Together, that's $98K a year of logistics tax you never see billed.
    </p>
  </div>
</section>

<!-- HOW -->
<section id="how" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4">how it works</div>
      <h2 class="display text-4xl md:text-6xl text-glacier max-w-4xl">
        Your workspace, your carriers, your inbox.<br />
        <span class="text-muted">One new step between them.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-4 gap-6 reveal stagger">
      <div class="s-card p-8" style="--d:0ms">
        <div class="font-mono text-sm text-dandelion mb-4">step 01</div>
        <div class="display text-xl mb-3 text-glacier">Load enters the workspace</div>
        <p class="text-muted text-sm leading-relaxed">A new shipment lands in your ops workspace the way it already does. Lane, weight, pickup window, commodity &mdash; all present.</p>
      </div>
      <div class="s-card p-8" style="--d:100ms">
        <div class="font-mono text-sm text-dandelion mb-4">step 02</div>
        <div class="display text-xl mb-3 text-glacier">RFQs draft themselves</div>
        <p class="text-muted text-sm leading-relaxed">The agent drafts a tailored RFQ per carrier through your inbox, informed by your rate history on the lane and the carriers most likely to cover it.</p>
      </div>
      <div class="s-card p-8" style="--d:200ms">
        <div class="font-mono text-sm text-dandelion mb-4">step 03</div>
        <div class="display text-xl mb-3 text-glacier">Responses land ranked</div>
        <p class="text-muted text-sm leading-relaxed">Quotes come back, get normalized against accessorials, and rank by total cost plus on-time history. Your load boards give you a market-relative read.</p>
      </div>
      <div class="s-card p-8" style="--d:300ms">
        <div class="font-mono text-sm text-dandelion mb-4">step 04</div>
        <div class="display text-xl mb-3 text-glacier">You approve; workspace updates</div>
        <p class="text-muted text-sm leading-relaxed">You pick the winner. The decision writes back to the load board, the carrier gets a confirmation email, and the next load is already queued.</p>
      </div>
    </div>

    <!-- terminal visual -->
    <div class="mt-16 reveal" style="--d:400ms">
      <div class="rounded-3xl overflow-hidden" style="background:#06282B; color:#F5F2ED; font-family:'Fragment Mono', monospace; font-size:14px; border:1px solid rgba(9,58,62,0.06)">
        <div class="px-5 py-3 flex items-center gap-2 text-xs" style="border-bottom:1px solid rgba(245,242,237,0.1); color:rgba(245,242,237,0.6)">
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="ml-4">agent · dispatch console</span>
        </div>
        <div class="p-6 space-y-2 leading-7">
          <div><span style="color:#F5B800">agent:</span> load <span style="color:#F5B800">#28142</span> pulled from your workspace · ATL → MIA · 38k reefer · pickup tue <span style="color:#F5B800">[06:00]</span></div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> rate history scanned · <span style="color:#F5B800">[14]</span> prior runs · median <span style="color:#F5B800">$2,480</span> · top carriers <span style="color:#F5B800">[7]</span></div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> drafting RFQs via your inbox · tailored per carrier <span style="color:#F5B800">[7]</span></div>
          <div><span style="color:#F5B800">agent:</span> sent to dispatch@ across <span style="color:#F5B800">[7]</span> carriers · replies tracked</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> <span style="color:#F5B800">[00:42:00]</span> · 5 quotes returned · normalizing accessorials</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> cross-checked against your load boards · market band <span style="color:#F5B800">$2,380–$2,620</span></div>
          <div><span style="color:#F5B800">agent:</span> ranked comparison ready · sent to distributor@</div>
          <div style="color:rgba(245,242,237,0.5)">&mdash;</div>
          <div><span style="color:#F5B800">total elapsed</span>: <span style="color:#F5B800">00:48:11</span><span class="blink" style="color:#F5B800">_</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FOR / NOT FOR -->
<section id="for" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4">honest qualification</div>
      <h2 class="display text-4xl md:text-6xl text-glacier">Is this for you?</h2>
    </div>

    <div class="mt-16 grid md:grid-cols-2 gap-6">
      <div class="s-card p-8 md:p-10 reveal">
        <div class="eyebrow mb-5" style="color:#F5B800">built for you if</div>
        <ul class="space-y-4 text-lg">
          <li class="flex gap-3"><span class="text-dandelion font-mono mt-1">✓</span><span class="text-glacier">You run a $30–80M specialty distributor or similar shipper</span></li>
          <li class="flex gap-3"><span class="text-dandelion font-mono mt-1">✓</span><span class="text-glacier">You dispatch 20–40 loads a week across a known carrier network</span></li>
          <li class="flex gap-3"><span class="text-dandelion font-mono mt-1">✓</span><span class="text-glacier">Your carriers quote by email, not through a portal</span></li>
          <li class="flex gap-3"><span class="text-dandelion font-mono mt-1">✓</span><span class="text-glacier">You run a load board in your ops workspace, or something close</span></li>
          <li class="flex gap-3"><span class="text-dandelion font-mono mt-1">✓</span><span class="text-glacier">Faster dispatch decisions directly change what you pay per load</span></li>
        </ul>
      </div>
      <div class="s-card p-8 md:p-10 reveal" style="background:#EDE9E5; --d:100ms">
        <div class="eyebrow mb-5">not for you if</div>
        <ul class="space-y-4 text-lg text-muted">
          <li class="flex gap-3"><span class="text-muted font-mono mt-1">—</span><span>You run contract-only lanes with preset carrier assignments</span></li>
          <li class="flex gap-3"><span class="text-muted font-mono mt-1">—</span><span>You're a single-carrier shop with no RFQ process</span></li>
          <li class="flex gap-3"><span class="text-muted font-mono mt-1">—</span><span>Your TMS already automates carrier selection end-to-end</span></li>
          <li class="flex gap-3"><span class="text-muted font-mono mt-1">—</span><span>You're a spot-market broker playing a different game entirely</span></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4">pricing</div>
      <h2 class="display text-4xl md:text-6xl text-glacier max-w-4xl">
        Straightforward.<br />
        <span class="text-muted">No retainer. No seat fees.</span>
      </h2>
    </div>

    <div class="mt-16 s-card reveal overflow-hidden">
      <div class="grid md:grid-cols-2">
        <div class="p-8 md:p-12 border-b md:border-b-0 md:border-r border-hairline">
          <div class="eyebrow mb-4" style="color:#F5B800">to build</div>
          <div class="ticker text-6xl md:text-7xl text-glacier">$500</div>
          <div class="mt-3 text-muted">One-time. Scoped, built, and deployed in about two weeks.</div>
        </div>
        <div class="p-8 md:p-12">
          <div class="eyebrow mb-4">then</div>
          <div class="ticker text-6xl md:text-7xl text-glacier">usage-based</div>
          <div class="mt-3 text-muted">Pay when the agent runs. No seats, no subscription floor.</div>
        </div>
      </div>
    </div>

    <p class="reveal mt-8 text-sm text-muted" style="--d:150ms">
      See the full rate card and terms on the program site →
      <a class="underline hover:text-glacier" href={cta}>shipyourweekendproject.com</a>
    </p>
  </div>
</section>

<!-- CTA -->
<section style="background:#093A3E; color:#F5F2ED">
  <div class="max-w-7xl mx-auto px-6 py-24 md:py-32">
    <div class="grid md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-8 reveal">
        <div class="eyebrow mb-4" style="color:#F5B800">waitlist · private beta</div>
        <h2 class="display text-5xl md:text-7xl" style="color:#F5F2ED">
          Stop drafting eighty<br />RFQs a week.
        </h2>
      </div>
      <div class="md:col-span-4 reveal" style="--d:150ms">
        <p class="text-lg mb-6" style="color:rgba(245,242,237,0.8)">
          Recover $98K a year in clerical logistics. Get eleven hours back. A small cohort of distributors onboards this quarter.
        </p>
        <a href={cta} class="inline-flex items-center gap-2 px-7 py-4 text-base font-medium rounded-full transition-colors" style="background:#F5B800; color:#093A3E">
          Claim a beta spot
          <span aria-hidden>→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="bg-cream text-muted text-sm border-t border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div class="flex items-center gap-3">
      <img src={logo} alt="Sagan" class="h-8 w-auto" />
      <div>
        <div class="font-mono text-glacier">an AI agent · freight dispatch</div>
        <div class="mt-1 text-muted">a build program from <a class="underline hover:text-glacier" href={cta}>Sagan</a></div>
      </div>
    </div>
    <div class="flex gap-8">
      <a href={cta} class="hover:text-glacier">waitlist</a>
      <a href="https://getsagan.com" class="hover:text-glacier">getsagan.com</a>
    </div>
  </div>
</footer>

<script is:inline>
  const io = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
    }
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  document.querySelectorAll('.stagger').forEach((g) => {
    Array.from(g.children).forEach((c, i) => { if (!c.style.getPropertyValue('--d')) c.style.setProperty('--d', (i * 90) + 'ms'); });
  });
</script>
<script is:inline src="/hubspot-capture.js" data-portal-id="50517161" data-form-guid="daac2804-e5c3-48e7-8ab7-a5b41c9e7c38"></script>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=Fragment+Mono&display=swap');
  html { scroll-behavior: smooth; }
  body { font-family: 'Space Grotesk', system-ui, sans-serif; background: #F5F2ED; color: #093A3E; -webkit-font-smoothing: antialiased; }
  .display { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; letter-spacing: -0.035em; line-height: 1.02; font-weight: 700; }
  .eyebrow { font-family: 'Space Grotesk', system-ui, sans-serif; letter-spacing: 0.2em; text-transform: uppercase; font-size: 12px; font-weight: 500; color: #4A6B6B; }
  .rule { height: 1px; background: rgba(9,58,62,0.06); width: 100%; }
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 900ms cubic-bezier(.2,.7,.2,1), transform 900ms cubic-bezier(.2,.7,.2,1); }
  .reveal.is-in { opacity: 1; transform: none; }
  .stagger > * { transition-delay: var(--d, 0ms); }
  .hover-lift { transition: transform 200ms ease, border-color 200ms ease; }
