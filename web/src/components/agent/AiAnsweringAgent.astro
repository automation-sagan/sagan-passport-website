---
/* Faithful port of /agent/ai-answering — the SPECIAL one with a LIVE Vapi voice
 * demo. Tailwind CDN + inline config + the page's custom <style> verbatim, the
 * bespoke body reproduced 1:1, with hero copy + CTA URL driven by the
 * `agentDemo` Sanity doc. The live demo console / transcript / tool-trace / QA
 * markup is kept as static markup; /agent/ai-answering/app.js?v=2 populates it
 * at runtime. Isolated via its own route file so generic class names don't
 * collide. */
import type { AgentDemoData } from '../../lib/agentDemos';

interface Props {
  data: AgentDemoData;
}
const { data } = Astro.props;
const cta = data.ctaUrl ?? 'https://www.shipyourweekendproject.com/';
const logo = '/agent/ai-answering/sagan-logo.png';
---

<!-- Tailwind CDN + theme config (kept verbatim from the source page) -->
<script is:inline src="https://cdn.tailwindcss.com"></script>
<script is:inline>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          glacier: '#093A3E',
          'glacier-dark': '#06282B',
          muted: '#4A6B6B',
          cream: '#F5F2ED',
          'cream-deep': '#EDE9E5',
          dandelion: '#F5B800',
          'sagan-blue': '#2197FF',
          success: '#2E8B57',
          danger: '#C7443A',
          hairline: 'rgba(9,58,62,0.06)',
          'hairline-strong': 'rgba(9,58,62,0.10)'
        },
        fontFamily: {
          display: ['Plus Jakarta Sans', 'system-ui', 'sans-serif'],
          sans: ['Space Grotesk', 'system-ui', 'sans-serif'],
          mono: ['Fragment Mono', 'ui-monospace', 'SFMono-Regular', 'monospace']
        }
      }
    }
  }
</script>

<!-- NAV -->
<nav class="sticky top-0 z-50 backdrop-blur bg-cream/85 border-b border-hairline">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="#" class="flex items-center gap-3">
      <img src={logo} alt="Sagan" class="h-8 w-auto" />
      <span class="mono text-sm text-muted">an AI agent · by Sagan<span aria-hidden="true" style="display:inline-block;width:8px;height:8px;background:#2197FF;border-radius:999px;margin-left:4px;vertical-align:baseline;transform:translateY(-1px);box-shadow:0 0 10px rgba(33,151,255,0.35);"></span></span>
    </a>
    <div class="hidden md:flex items-center gap-8 text-sm text-glacier/80">
      <a href="#demo" class="hover:text-glacier">live demo</a>
      <a href="#how" class="hover:text-glacier">how it works</a>
      <a href="#pain" class="hover:text-glacier">the problem</a>
      <a href="#pricing" class="hover:text-glacier">pricing</a>
    </div>
    <a href="#demo" class="group inline-flex items-center gap-2 bg-glacier text-cream px-5 py-2.5 text-sm font-medium rounded-full hover:bg-glacier-dark transition-colors">
      Try the demo
      <span aria-hidden class="transition-transform group-hover:translate-x-0.5">→</span>
    </a>
  </div>
</nav>

<!-- HERO -->
<header class="border-b border-hairline relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 pt-20 pb-20 md:pt-28 md:pb-28 relative">
    <div class="reveal">
      <div class="eyebrow mb-8"><span class="dot"></span>{data.heroEyebrow}</div>
      <h1 class="display text-5xl md:text-7xl text-glacier" set:html={data.heroHeadlineHtml}></h1>
    </div>

    <div class="reveal mt-10 max-w-2xl text-lg md:text-xl text-glacier/80 leading-relaxed" style="--d:150ms" set:html={data.heroLeadHtml}></div>

    <div class="reveal mt-10 flex flex-col sm:flex-row gap-4" style="--d:300ms">
      <a href="#demo" class="inline-flex items-center justify-center gap-2 bg-glacier text-cream px-7 py-4 text-base font-medium rounded-full hover:bg-glacier-dark transition-colors">
        Talk to the agent
        <span aria-hidden>→</span>
      </a>
      <a href="#how" class="inline-flex items-center justify-center gap-2 border border-glacier text-glacier px-7 py-4 text-base font-medium rounded-full hover:bg-glacier hover:text-cream transition-colors">
        See how it works
      </a>
    </div>

    <!-- quick stats -->
    <div class="reveal mt-20 s-card p-8 md:p-12" style="--d:450ms">
      <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-16">
        <div class="flex-1">
          <div class="eyebrow mb-3">before</div>
          <div class="ticker text-5xl md:text-6xl text-glacier">15<span class="text-muted text-2xl"> calls/wk missed</span></div>
          <div class="mt-2 text-muted">voicemail, overflow, after hours</div>
        </div>
        <div class="hidden md:block text-dandelion text-4xl font-mono">→</div>
        <div class="flex-1">
          <div class="eyebrow mb-3" style="color:#F5B800">after</div>
          <div class="ticker text-5xl md:text-6xl text-glacier">0<span class="text-muted text-2xl"> unanswered</span></div>
          <div class="mt-2 text-muted">agent picks up, qualifies, books</div>
        </div>
        <div class="flex-1 md:border-l md:border-hairline md:pl-10">
          <div class="eyebrow mb-3">recovered</div>
          <div class="ticker text-5xl md:text-6xl text-glacier">$78K<span class="text-muted text-2xl">/yr</span></div>
          <div class="mt-2 text-muted">in jobs previously lost to unanswered calls</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ambient marquee -->
  <div class="border-t border-hairline py-4 overflow-hidden font-mono text-xs text-muted">
    <div class="marquee whitespace-nowrap">
      <span>call received · zip verified · calendar checked · slot offered · appointment booked · sms confirmed · owner notified · call received · zip verified · calendar checked · slot offered · appointment booked · sms confirmed · owner notified ·&nbsp;</span>
      <span>call received · zip verified · calendar checked · slot offered · appointment booked · sms confirmed · owner notified · call received · zip verified · calendar checked · slot offered · appointment booked · sms confirmed · owner notified ·&nbsp;</span>
    </div>
  </div>
</header>

<!-- LIVE DEMO -->
<section id="demo" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
    <div class="reveal">
      <div class="eyebrow mb-4"><span class="dot" style="background:#2197FF"></span>live demo · speak with the agent</div>
      <h2 class="display text-4xl md:text-6xl text-glacier max-w-4xl">
        Pick up the phone.<br />
        <span class="text-muted">Watch the agent work in real time.</span>
      </h2>
      <div class="reveal mt-8 max-w-3xl mx-auto s-card p-6 md:p-10" style="--d:150ms">
        <div class="eyebrow mb-4" style="color:#F5B800">your role · homeowner</div>
        <p class="text-lg text-glacier/90 leading-relaxed mb-5">
          You're a homeowner calling <span class="text-glacier font-medium">Splendid Tile Roofing</span>. Leila, the AI receptionist, picks up. Play it straight — real names, real-sounding phone numbers and addresses. Watch the right panel fire tool calls as the agent works.
        </p>
        <ol class="space-y-2 text-glacier/85 text-base leading-relaxed">
          <li class="flex gap-3"><span class="mono text-dandelion shrink-0">01</span><span>Click <span class="font-medium">Start demo call</span> and grant your browser mic access.</span></li>
          <li class="flex gap-3"><span class="mono text-dandelion shrink-0">02</span><span>Say you'd like to book a <span class="font-medium">roof inspection</span>.</span></li>
          <li class="flex gap-3"><span class="mono text-dandelion shrink-0">03</span><span>When asked for your ZIP, try <span class="mono text-glacier">90210</span> (in service area — she'll keep going) or <span class="mono text-glacier">30301</span> (out of area — she'll take a callback instead).</span></li>
          <li class="flex gap-3"><span class="mono text-dandelion shrink-0">04</span><span>Give a name, phone number, and street address when she asks. A 6 PM slot is always open if nothing else lands for you.</span></li>
          <li class="flex gap-3"><span class="mono text-dandelion shrink-0">05</span><span>Hang up when you're done — the post-call QA and CRM fires render below.</span></li>
        </ol>

        <!-- CTA + status sit inside the card so the reader's eye lands on the instructions right before they click -->
        <div class="mt-8 pt-6 border-t border-hairline flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <button id="demoToggle" class="demo-cta" type="button" aria-live="polite">
            <span class="mic-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
            </span>
            <span id="demoLabel">Start demo call</span>
          </button>
          <div class="flex items-center gap-6 text-sm text-muted mono">
            <span id="statusBadge" class="inline-flex items-center gap-2"><span id="statusDot" class="w-2 h-2 rounded-full bg-muted/50"></span><span id="statusText">idle</span></span>
            <span id="callTimer" class="ticker text-glacier">00:00</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Split-screen console -->
    <div class="reveal mt-8 grid lg:grid-cols-5 gap-6" style="--d:300ms">

      <!-- TRANSCRIPT -->
      <div class="lg:col-span-3 demo-console">
        <div class="titlebar px-5 flex items-center gap-2 text-xs mono h-[44px]">
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="ml-4">transcript · live</span>
          <span class="ml-auto flex items-center gap-1" id="levelBars" aria-hidden="true" style="height:22px;">
            <span class="level-bar" style="height:8px;"></span>
            <span class="level-bar" style="height:14px;"></span>
            <span class="level-bar" style="height:10px;"></span>
            <span class="level-bar" style="height:18px;"></span>
            <span class="level-bar" style="height:12px;"></span>
          </span>
        </div>
        <div id="transcript" class="p-6 space-y-3 font-mono text-sm leading-6 h-[480px] overflow-y-scroll" style="scrollbar-gutter: stable; scroll-behavior: auto; overflow-anchor: none;">
          <div class="text-[rgba(245,242,237,0.5)] italic">Transcript will appear here once the call starts. Grant mic access when prompted.</div>
        </div>
      </div>

      <!-- AGENT ACTIONS -->
      <div class="lg:col-span-2 demo-console">
        <div class="titlebar px-5 flex items-center gap-2 text-xs mono h-[44px]">
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="ml-4">agent actions · tool calls</span>
        </div>
        <div id="toolPanel" class="p-6 space-y-4 font-mono text-sm leading-6 h-[480px] overflow-y-scroll" style="scrollbar-gutter: stable;">
          <div class="text-[rgba(245,242,237,0.5)] italic">No tools called yet. The agent will check the caller's zip, pull availability, and book an appointment.</div>
        </div>
      </div>
    </div>

    <!-- Post-call panel (hidden until call completes) -->
    <div id="postCall" class="mt-10 hidden">
      <div class="eyebrow mb-4"><span class="dot" style="background:#2E8B57"></span>after the call · QA + CRM fires</div>
      <h3 class="display text-3xl md:text-4xl text-glacier max-w-3xl">The work that happens between the hang-up and the follow-up.</h3>
      <p class="mt-4 max-w-3xl text-glacier/80">Every call is auto-reviewed for script adherence, unanswered questions, and address validation &mdash; then the downstream CRM fires: a text to the customer, an alert to the owner, and a calendar event.</p>

      <div class="mt-8 grid lg:grid-cols-2 gap-6">
        <!-- QA CHECKS -->
        <div class="s-card p-8">
          <div class="eyebrow mb-4"><span style="color:#2E8B57">quality assurance</span></div>
          <h4 class="display text-xl mb-2 text-glacier">Automated call review</h4>
          <p class="text-sm text-muted mb-4">LLM reviews the transcript against the playbook the moment the call ends.</p>
          <div id="qaChecks">
            <!-- skeletons rendered by app.js on call-end -->
          </div>
        </div>

        <!-- CRM ARTIFACTS -->
        <div class="space-y-6">
          <!-- SMS to customer -->
          <div class="s-card p-6">
            <div class="eyebrow mb-3"><span style="color:#2197FF">sms to customer</span></div>
            <div id="smsCustomer" class="phone-frame space-y-3">
              <!-- skeletons rendered by app.js on call-end -->
            </div>
          </div>

          <!-- Owner notification (Slack / SMS) -->
          <div class="s-card p-6">
            <div class="eyebrow mb-3"><span style="color:#F5B800">owner alert</span></div>
            <div id="ownerAlert" class="slack">
              <!-- skeletons rendered by app.js on call-end -->
            </div>
          </div>

          <!-- Calendar booking -->
          <div class="s-card p-6">
            <div class="eyebrow mb-3"><span style="color:#093A3E">calendar</span></div>
            <div id="calendarCard" class="cal-card">
              <!-- skeletons rendered by app.js on call-end -->
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- HOW -->
<section id="how" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4">how it works</div>
      <h2 class="display text-4xl md:text-6xl text-glacier max-w-4xl">
        Your number, your calendar, your CRM.<br />
        <span class="text-muted">An agent that wires them together.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-4 gap-6 reveal stagger">
      <div class="s-card p-8" style="--d:0ms">
        <div class="mono text-sm text-dandelion mb-4">step 01</div>
        <div class="display text-xl mb-3 text-glacier">Answers the call</div>
        <p class="text-muted text-sm leading-relaxed">Forwards ring to the agent. Greets with your business name. Handles overflow, after-hours, and every call your team can't catch.</p>
      </div>
      <div class="s-card p-8" style="--d:100ms">
        <div class="mono text-sm text-dandelion mb-4">step 02</div>
        <div class="display text-xl mb-3 text-glacier">Qualifies the lead</div>
        <p class="text-muted text-sm leading-relaxed">Checks service area by zip. Classifies job type. Pulls your calendar for live availability. Never quotes over the phone.</p>
      </div>
      <div class="s-card p-8" style="--d:200ms">
        <div class="mono text-sm text-dandelion mb-4">step 03</div>
        <div class="display text-xl mb-3 text-glacier">Books the appointment</div>
        <p class="text-muted text-sm leading-relaxed">Offers real slots. Confirms decision-maker availability. Writes the event straight to your calendar with full context.</p>
      </div>
      <div class="s-card p-8" style="--d:300ms">
        <div class="mono text-sm text-dandelion mb-4">step 04</div>
        <div class="display text-xl mb-3 text-glacier">Hands off cleanly</div>
        <p class="text-muted text-sm leading-relaxed">Texts the customer a confirmation. Alerts you with a new-lead summary. Logs a callback request if it hits its limits.</p>
      </div>
    </div>

    <!-- terminal visual -->
    <div class="mt-16 reveal" style="--d:400ms">
      <div class="rounded-3xl overflow-hidden" style="background:#06282B; color:#F5F2ED; font-family:'Fragment Mono', monospace; font-size:14px; border:1px solid rgba(9,58,62,0.06)">
        <div class="px-5 py-3 flex items-center gap-2 text-xs" style="border-bottom:1px solid rgba(245,242,237,0.1); color:rgba(245,242,237,0.6)">
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(245,242,237,0.2)"></span>
          <span class="ml-4">agent · call console</span>
        </div>
        <div class="p-6 space-y-2 leading-7">
          <div><span style="color:#F5B800">call:</span> inbound <span style="color:#F5B800">+1-213-555-0173</span> · ring <span style="color:#F5B800">[1.2s]</span> · picked up</div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> greeting played · caller identified request: <span style="color:#F5B800">roof inspection</span></div>
          <div><span style="color:#F5B800">tool:</span> check_service_area <span style="color:#F5B800">&#123;zip:"90210"&#125;</span> → <span style="color:#F5B800">in_area</span></div>
          <div><span style="color:#F5B800">tool:</span> get_available_slots <span style="color:#F5B800">&#123;any&#125;</span> → <span style="color:#F5B800">3 slots</span></div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> offered tue 2pm · caller confirmed</div>
          <div><span style="color:#F5B800">tool:</span> book_appointment <span style="color:#F5B800">&#123;slot, name, phone, addr&#125;</span> → <span style="color:#F5B800">APT-8471</span></div>
          <div><span style="color:rgba(245,242,237,0.5)">··</span> customer sms sent · owner alerted · calendar written</div>
          <div style="color:rgba(245,242,237,0.5)">&mdash;</div>
          <div><span style="color:#F5B800">total elapsed</span>: <span style="color:#F5B800">00:02:17</span><span class="blink" style="color:#F5B800">_</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- THE MATH -->
<section id="pain" class="border-b border-hairline" style="background:#06282B; color:#F5F2ED">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4" style="color:#F5B800">the math, if you want to look</div>
      <h2 class="display text-4xl md:text-6xl max-w-4xl" style="color:#F5F2ED">
        Fifteen missed calls a week.<br />
        <span style="color:#F5B800">$78K a year</span> in lost jobs.<br />
        <span style="color:rgba(245,242,237,0.6)">Every one of them was ready to book.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-4 gap-6 reveal stagger">
      <div class="p-8 rounded-3xl" style="background:rgba(245,242,237,0.04); border:1px solid rgba(245,242,237,0.08); --d:0ms">
        <div class="mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">CALLS / WEEK</div>
        <div class="ticker text-5xl">50</div>
      </div>
      <div class="p-8 rounded-3xl" style="background:rgba(245,242,237,0.04); border:1px solid rgba(245,242,237,0.08); --d:100ms">
        <div class="mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">% UNANSWERED</div>
        <div class="ticker text-5xl" style="color:#F5B800">30%</div>
      </div>
      <div class="p-8 rounded-3xl" style="background:rgba(245,242,237,0.04); border:1px solid rgba(245,242,237,0.08); --d:200ms">
        <div class="mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">AVG CLOSE RATE</div>
        <div class="ticker text-5xl">25%</div>
      </div>
      <div class="p-8 rounded-3xl" style="background:rgba(245,242,237,0.04); border:1px solid rgba(245,242,237,0.08); --d:300ms">
        <div class="mono text-xs mb-2" style="color:rgba(245,242,237,0.5)">$ / YR LEFT ON TABLE</div>
        <div class="ticker text-5xl" style="color:#F5B800">$78K</div>
      </div>
    </div>

    <p class="reveal mt-10 max-w-3xl" style="color:rgba(245,242,237,0.7); --d:450ms">
      Fifty calls × thirty percent unanswered = fifteen missed a week. Half are qualified leads; one in four closes at a $400 average margin. That's $78K a year walking to the next contractor on Google &mdash; the one who picked up.
    </p>
  </div>
</section>

<!-- FOR / NOT FOR -->
<section class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="reveal">
      <div class="eyebrow mb-4">honest qualification</div>
      <h2 class="display text-4xl md:text-6xl text-glacier">Is this for you?</h2>
    </div>

    <div class="mt-16 grid md:grid-cols-2 gap-6">
      <div class="s-card p-8 md:p-10 reveal">
        <div class="eyebrow mb-5" style="color:#F5B800">built for you if</div>
        <ul class="space-y-4 text-lg">
          <li class="flex gap-3"><span class="text-dandelion mono mt-1">✓</span><span class="text-glacier">You run a home services business &mdash; roofing, HVAC, plumbing, electrical, pool, landscaping</span></li>
          <li class="flex gap-3"><span class="text-dandelion mono mt-1">✓</span><span class="text-glacier">Calls are your number-one lead source and every missed call hurts</span></li>
          <li class="flex gap-3"><span class="text-dandelion mono mt-1">✓</span><span class="text-glacier">You run a known service area and book by appointment</span></li>
          <li class="flex gap-3"><span class="text-dandelion mono mt-1">✓</span><span class="text-glacier">You have a calendar (Google, Jobber, ServiceTitan, HouseCall Pro) we can read and write to</span></li>
          <li class="flex gap-3"><span class="text-dandelion mono mt-1">✓</span><span class="text-glacier">You want every lead captured, not a cheaper receptionist</span></li>
        </ul>
      </div>
      <div class="s-card p-8 md:p-10 reveal" style="background:#EDE9E5; --d:100ms">
        <div class="eyebrow mb-5">not for you if</div>
        <ul class="space-y-4 text-lg text-muted">
          <li class="flex gap-3"><span class="text-muted mono mt-1">—</span><span>You don't have a consistent service area or pricing structure</span></li>
          <li class="flex gap-3"><span class="text-muted mono mt-1">—</span><span>Most of your leads come through online forms, not phone</span></li>
          <li class="flex gap-3"><span class="text-muted mono mt-1">—</span><span>You need a human-only concierge brand at the phone line</span></li>
          <li class="flex gap-3"><span class="text-muted mono mt-1">—</span><span>You're allergic to the idea of AI on your front door at all</span></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" class="border-b border-hairline">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
