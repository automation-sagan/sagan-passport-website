<!-- Scroll reveal + calculator (numbers injected from Sanity) -->
<script
  is:inline
  define:vars={{
    membershipMonthly: calc.membershipMonthly ?? 499,
    finderFeePct: calc.finderFeePct ?? 18,
  }}
>
  // ── Scroll reveal ──
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // ── Calculator ──
  const salaryInput = document.getElementById('salary');
  const hiresSelect = document.getElementById('hires');

  // NOTE: 0.35 = the competitor (Somewhere) hiring-fee rate — no Sanity field maps to it, kept inline.
  const SOMEWHERE_RATE = 0.35;
  const SAGAN_RATE = finderFeePct / 100; // from data.calc.finderFeePct (18 → 0.18)
  const MEMBERSHIP = membershipMonthly;  // from data.calc.membershipMonthly (499)

  function fmt(n) { return '$' + n.toLocaleString('en-US'); }

  function calculate() {
    const monthly = parseInt(salaryInput.value) || 2000;
    const annual = monthly * 12;
    const hires = parseInt(hiresSelect.value) || 3;

    const swCost = Math.round(annual * SOMEWHERE_RATE * hires);
    const saganPlacement = Math.round(annual * SAGAN_RATE * hires);
    const saganMembership = MEMBERSHIP * 12;
    const saganTotal = saganPlacement + saganMembership;

    document.getElementById('somewhere-cost').textContent = fmt(swCost);
    document.getElementById('somewhere-detail').textContent = '35% of ' + fmt(annual) + ' salary × ' + hires + (hires === 1 ? ' hire' : ' hires');
    document.getElementById('sagan-cost').textContent = fmt(saganTotal);
    document.getElementById('sagan-detail').textContent = fmt(saganPlacement) + ' hiring fee + ' + fmt(saganMembership) + ' membership';

    const savings = swCost - saganTotal;
    const el = document.getElementById('savings-amount');
    const note = document.getElementById('savings-note');

    if (savings > 0) {
      el.textContent = 'Save ' + fmt(savings);
      el.style.color = '#2197FF';
      note.textContent = 'Plus post-hire support, playbooks & community — included free';
    } else if (savings >= -1000) {
      el.textContent = 'Comparable cost';
      el.style.color = '#F5B800';
      note.textContent = 'But Sagan includes post-hire support, playbooks & community that Somewhere doesn’t offer';
    } else {
      el.textContent = fmt(saganTotal - swCost) + ' more upfront';
      el.style.color = '#F5B800';
      note.textContent = 'But includes $' + saganMembership.toLocaleString() + '/yr of post-hire support, community & playbooks that Somewhere doesn’t offer at any price';
    }
  }

  salaryInput.addEventListener('input', calculate);
  hiresSelect.addEventListener('change', calculate);
  calculate();
</script>

