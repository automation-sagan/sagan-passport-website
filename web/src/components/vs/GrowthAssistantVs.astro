<!-- Scroll reveal + calculator (numbers injected from Sanity) + sticky CTA -->
<script
  is:inline
  define:vars={{
    talentMonthly: calc.talentMonthly ?? 800,
    middlemanMonthly: calc.middlemanMonthly ?? 2200,
    membershipMonthly: calc.membershipMonthly ?? 499,
    finderFeePct: calc.finderFeePct ?? 18,
    competitor: C,
  }}
>
  // Scroll reveal with spring-like timing
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Calculator
  const hiresSelect = document.getElementById('hires');
  const yearsSelect = document.getElementById('years');
  const TALENT = talentMonthly;
  const MIDDLEMAN = middlemanMonthly;
  const MEMBERSHIP = membershipMonthly;
  const FINDER = finderFeePct / 100;

  function fmt(n) { return '$' + n.toLocaleString('en-US'); }

  function calculate() {
    const hires = parseInt(hiresSelect.value) || 1;
    const years = parseInt(yearsSelect.value) || 2;
    const months = years * 12;
    const annualSalary = TALENT * 12;

    const gaMiddleman = MIDDLEMAN * hires * months;
    const saganPlacement = Math.round(annualSalary * FINDER * hires);
    const saganMembership = MEMBERSHIP * months;
    const saganTotal = saganPlacement + saganMembership;

    document.getElementById('ga-cost').textContent = fmt(gaMiddleman);
    document.getElementById('ga-detail').textContent =
      fmt(MIDDLEMAN) + '/mo × ' + hires + (hires > 1 ? ' people' : ' person') + ' × ' + months + ' months';

    document.getElementById('sagan-cost').textContent = fmt(saganTotal);
    document.getElementById('sagan-detail').textContent =
      fmt(saganPlacement) + ' finder’s fee + ' + fmt(saganMembership) + ' membership';

    document.getElementById('sagan-membership-note').textContent =
      hires > 1
        ? 'Same ' + fmt(MEMBERSHIP) + '/mo membership whether you hire ' + hires + ' people or 1.'
        : 'Same ' + fmt(MEMBERSHIP) + '/mo membership whether you hire 1 person or 10.';

    const savings = gaMiddleman - saganTotal;
    document.getElementById('savings-amount').textContent = fmt(savings);
    document.getElementById('savings-note').textContent =
      'Your hire gets paid the same either way. The only difference is how much goes to the middleman.';

    var talentNote = document.querySelector('.calc-talent-note');
    talentNote.innerHTML =
      '<strong>Sagan finds you great people. ' + competitor + ' rents them to you.</strong> ' + competitor + ' takes ' + fmt(gaMiddleman) + ' over ' + years + (years === 1 ? ' year' : ' years') + '. Sagan takes ' + fmt(saganTotal) + '. You save ' + fmt(savings) + '. Cancel anytime — keep your whole team.';
  }

  hiresSelect.addEventListener('change', calculate);
  yearsSelect.addEventListener('change', calculate);
  calculate();

  // Sticky mobile CTA - show after scrolling past hero
  const stickyCta = document.getElementById('sticky-cta');
  const heroSection = document.querySelector('.hero');
  if (stickyCta && heroSection) {
    const stickyObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) {
          stickyCta.classList.add('visible');
        } else {
          stickyCta.classList.remove('visible');
        }
      });
    }, { threshold: 0 });
    stickyObserver.observe(heroSection);
  }
</script>

