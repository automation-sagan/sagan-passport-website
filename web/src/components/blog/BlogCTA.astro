---
/* BlogCTA — the blog sidebar CTA card. Content is editable per post (the `cta`
 * field on the blog document); blank fields fall back to the site defaults
 * below. A simple navy card: title + description + "Schedule a Call" button. */
import type { BlogCTAData } from '../../lib/blog';

const CALENDLY_URL =
  'https://calendly.com/d/5j7-3xv-p5k/global-talent-hiring-consultation?utm_source=saganpassportdotcom&utm_term=talent';

interface Props {
  cta?: BlogCTAData | null;
}
const cta = Astro.props.cta ?? {};

const title = cta.title || 'Ready to build a stronger global team?';
const description =
  cta.description ||
  'Stop guessing and start building. Schedule a call to get a custom plan for your business and see how Sagan Passport can help you hire with confidence.';
const buttonText = cta.buttonText || 'Schedule a Call';
const link = cta.buttonLink || CALENDLY_URL;
const external = /^https?:\/\//.test(link);
---

<div class="bcta">
  <h3 class="bcta__title">{title}</h3>
  <div class="bcta__desc" set:html={description}></div>
  <a
    class="bcta__btn"
    href={link}
    target={external ? '_blank' : undefined}
    rel={external ? 'noreferrer' : undefined}>
    {buttonText} <span aria-hidden="true">→</span>
  </a>
</div>

<style>
  .bcta {
    background: rgb(0, 31, 69);
    border-radius: 16px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }
  .bcta__title {
    margin: 0;
    font-family: var(--pp);
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: -0.4px;
    color: #fff;
  }
  .bcta__desc {
    font-family: var(--pp);
    font-size: 15px;
    line-height: 1.5;
    color: rgb(176, 196, 222);
  }
  .bcta__desc :global(p) {
    margin: 0;
  }
  .bcta__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
    padding: 14px 24px;
    background: var(--dandelion);
    color: var(--glacier);
    border-radius: 10px;
    font-family: var(--pp);
    font-size: 16px;
    text-decoration: none;
    transition: background-color 0.25s ease;
  }
  .bcta__btn:hover {
    background: rgb(230, 173, 0);
  }
</style>
