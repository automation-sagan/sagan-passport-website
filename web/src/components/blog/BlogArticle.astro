---
/* BlogArticle — the full blog-post article body (cover, breadcrumb, title,
 * lead, cost cards, sections, sticky sidebar). Extracted from /blog/[slug] so
 * the draft-preview route (/preview/blog/[slug]) renders the exact same
 * markup. Pages own Layout/Navbar/Footer; this owns everything inside. */
import BlogCTA from './BlogCTA.astro';
import { formatDate, type BlogFull, type BlogSummary } from '../../lib/blog';
import { richBodyHtml } from '../../lib/richTextHtml';
import { imgUrl } from '../../lib/sanityImage';

interface Props {
  post: BlogFull;
  more: BlogSummary[];
}
const { post, more } = Astro.props;

/* The live template wraps the cover image in the same "Schedule a Call" link
 * used site-wide (Navbar / BlogCTA). */
const CALENDLY_URL =
  'https://calendly.com/d/5j7-3xv-p5k/global-talent-hiring-consultation?utm_source=saganpassportdotcom&utm_term=talent';

const coverImage = imgUrl(post.image);
const showSidebar = post.showSidebar !== false;
const metaBits = [post.date ? formatDate(post.date) : null, post.author, post.readTime].filter(Boolean);
const introHtml = richBodyHtml(post.intro);

/* Section titles render as H2 by default; the Framer "Use H2 Headings" flag
 * turns them into H3 (visually identical — .bp__sectitle carries the style). */
const HeadingTag = post.useH2Headings === false ? 'h3' : 'h2';
---

<article class="bp">
  <div class="bp__container">
    {coverImage && (
      <a class="bp__cover" href={CALENDLY_URL} target="_blank" rel="noreferrer">
        <img src={coverImage} alt={post.imageAlt || post.title} loading="eager" />
      </a>
    )}

    <div class={showSidebar ? 'bp__wrap' : 'bp__wrap bp__wrap--full'}>
      <!-- main content -->
      <div class="bp__main">
        <p class="bp__crumb"><a href="/blog">BLOG POST</a> <span>› {post.title}</span></p>
        <h1 class="bp__title">{post.title}</h1>
        <p class="bp__meta">{metaBits.join('  •  ')}</p>

        {introHtml && <div class="bp__lead article-content" set:html={introHtml}></div>}

        {post.costCards && post.costCards.length > 0 && (
          <div class="blog-costcards" style="margin-top:32px">
            {post.costCards.map((c) => (
              <div class="blog-costcard">
                <span class="blog-costcard__title">{c.title}</span>
                <span class="blog-costcard__price">{c.price}</span>
                <span class="blog-costcard__unit">{c.unit}</span>
              </div>
            ))}
          </div>
        )}
        {post.costNote && <p class="blog-costnote" style="margin-top:16px">{post.costNote}</p>}

        <div class="bp__sections">
          {(post.sections ?? []).map((s) => (
            <section class="bp__sec">
              {s.label && <p class="bp__seclabel">{s.label}</p>}
              {s.title && <HeadingTag class="bp__sectitle">{s.title}</HeadingTag>}
              {s.intro && <p class="bp__sec-intro">{s.intro}</p>}
              <div class="bp__sec-body article-content" set:html={richBodyHtml(s.content)}></div>
              {s.quote && (
                <div class="article-content">
                  <blockquote><p>{s.quote}</p></blockquote>
                </div>
              )}
              {s.content2 && s.content2.length > 0 && (
                <div class="bp__sec-body article-content" set:html={richBodyHtml(s.content2)}></div>
              )}
            </section>
          ))}
        </div>
      </div>

      {/* sticky sidebar */}
      {showSidebar && (
        <aside class="bp__aside">
          {more.length > 0 && (
            <div class="bp__more">
              <h3 class="bp__more-title">More from the blog</h3>
              <div class="bp__more-line"></div>
              {more.map((p) => (
                <a class="bp__pc" href={`/blog/${p.slug}`}>
                  <span class="bp__pc-thumb" style={imgUrl(p.image) ? `background-image:url(${imgUrl(p.image)})` : undefined}></span>
                  <span class="bp__pc-body">
                    <span class="bp__pc-cat">{p.category}</span>
                    <span class="bp__pc-title">{p.title}</span>
                    {p.readTime && <span class="bp__pc-read">{p.readTime}</span>}
                  </span>
                </a>
              ))}
            </div>
          )}
          <BlogCTA cta={post.cta} />
        </aside>
      )}
    </div>
  </div>
</article>
