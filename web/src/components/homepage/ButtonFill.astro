---
/* ButtonFill — primary button (Astro port): dark glacier text pill + a touching
 * glacier arrow circle, white label/arrow. Hover darkens to deep-glacier while
 * the arrow slides out right and its white twin slides in from the left (the
 * same swap as the pricing Get Started button / live saganpassport.com). */
interface Props {
  label: string;
  href: string;
  external?: boolean;
}
const { label, href, external = false } = Astro.props;
---

<a
  class="btn-fill"
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noreferrer' : undefined}>
  <span class="btn-fill__label">{label}</span>
  <span class="btn-fill__circle">
    <svg class="btn-fill__arrow btn-fill__arrow--a" viewBox="0 0 24 24" width="22" height="22" fill="none" aria-hidden="true">
      <path d="M5 12h13M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
    <svg class="btn-fill__arrow btn-fill__arrow--b" viewBox="0 0 24 24" width="22" height="22" fill="none" aria-hidden="true">
      <path d="M5 12h13M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </span>
</a>

<style>
  .btn-fill {
    display: inline-flex;
    align-items: center;
    gap: 0; /* arrow circle touches the pill — no gap */
    padding: 0;
    background: transparent;
    border: none;
    text-decoration: none;
    cursor: pointer;
    font-family: var(--pp);
  }
  .btn-fill__label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 60px;
    padding: 0 28px;
    font-size: 17px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--white);
    background: var(--glacier);
    border-radius: 100px;
    white-space: nowrap;
    transition: background-color 0.3s cubic-bezier(0.44, 0, 0.56, 1);
  }
  .btn-fill__circle {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: none;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    color: var(--white);
    background: var(--glacier);
    transition: background-color 0.3s cubic-bezier(0.44, 0, 0.56, 1);
  }
  /* Two stacked arrows; both centered, offset via translateX. Same 0.7s
     ease-out swap as the pricing Get Started button. */
  .btn-fill__arrow {
    position: absolute;
    top: 50%;
    left: 50%;
    transition:
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* Resting arrow: centered. Hover: slides out to the right. */
  .btn-fill__arrow--a {
    transform: translate(-50%, -50%) translateX(0);
    opacity: 1;
  }
  /* Incoming arrow (same color): waits off to the left. Hover: slides in. */
  .btn-fill__arrow--b {
    transform: translate(-50%, -50%) translateX(-200%);
    opacity: 0;
  }
  .btn-fill:hover .btn-fill__arrow--a {
    transform: translate(-50%, -50%) translateX(200%);
    opacity: 0;
  }
  .btn-fill:hover .btn-fill__arrow--b {
    transform: translate(-50%, -50%) translateX(0);
    opacity: 1;
  }
  .btn-fill:hover .btn-fill__label,
  .btn-fill:hover .btn-fill__circle {
    background: var(--deep-glacier);
  }
  .btn-fill:active {
    transform: translateY(1px);
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-fill__arrow {
      transition: none;
    }
  }
</style>
