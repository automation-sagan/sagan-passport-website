---
/* Process — "From Wishlist to A-Player": heading + 3 sticky-stacking ProcessCards.
 * The .hiw-sticky wrappers (position: sticky at staggered tops) are styled in
 * howitworks.css; the per-step `top` is set inline below. */
import ProcessCard from './ProcessCard.astro';
import { imgUrl } from '../../lib/sanityImage';
import type { HiwProcessStep } from '../../lib/howItWorks';

interface Props {
  heading?: string;
  subcopy?: string;
  steps?: HiwProcessStep[];
}
const { heading, subcopy, steps = [] } = Astro.props;

/* The per-step sticky `top` offset is layout, not content — kept in code. */
const TOPS = [100, 124, 148];
---

<section class="section hiw-process-wrap">
  <div class="hiw-process">
    <div class="hiw-process__head">
      <h2 class="t-h2" style="max-width:365px;margin:0">{heading}</h2>
      <p class="t-body" style="max-width:440px;margin:0">{subcopy}</p>
    </div>
    <div class="hiw-process__cards">
      {
        steps.map((s, i) => (
          <div class="hiw-sticky" style={`top:${TOPS[i] ?? 100}px`}>
            <ProcessCard
              step={s.step}
              title={s.title}
              body={s.body}
              badgeColor={s.badgeColor}
              icon={imgUrl(s.icon)}
              image={imgUrl(s.image)}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
