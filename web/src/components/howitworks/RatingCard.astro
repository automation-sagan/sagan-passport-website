---
/* ----------------------------------------------------------------------------
 * RatingCard — the G2 / Clutch proof cards (hand-built in the original page).
 * Logo + 5 dandelion stars + rating label + an outline "Read Reviews" button.
 * Layout classes (.hiw-rating*) live in howitworks.css; reuses the homepage
 * ButtonOutline (framer button-1, outline variant, external link).
 * ------------------------------------------------------------------------- */
import ButtonOutline from '../homepage/ButtonOutline.astro';

interface Props {
  logo?: string;
  logoAlt?: string;
  rating?: string;
  buttonLabel?: string;
  buttonHref?: string;
}
const { logo, logoAlt, rating, buttonLabel, buttonHref } = Astro.props;

const DANDELION = 'rgb(245, 184, 0)';
const STAR = 'M12 2l2.9 6.06 6.6.78-4.9 4.52 1.3 6.54L12 17.3 6.1 20.4l1.3-6.54L2.5 9.34l6.6-.78L12 2z';
---

<div class="hiw-rating">
  <img class="hiw-rating__logo" src={logo} alt={logoAlt} />
  <div class="hiw-rating__stars">
    <div class="hiw-stars">
      {
        Array.from({ length: 5 }).map(() => (
          <svg width="24" height="24" viewBox="0 0 24 24" fill={DANDELION} xmlns="http://www.w3.org/2000/svg">
            <path d={STAR} />
          </svg>
        ))
      }
    </div>
    <span class="hiw-rating__label">{rating}</span>
  </div>
  <ButtonOutline label={buttonLabel ?? ''} href={buttonHref ?? ''} external />
</div>
