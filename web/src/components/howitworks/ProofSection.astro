---
/* Proof — big testimonial card + G2 / Clutch rating cards (5-col grid).
 * Content comes from the How It Works singleton in Sanity. */
import RatingCard from './RatingCard.astro';
import { imgUrl } from '../../lib/sanityImage';
import type { HowItWorksData } from '../../lib/howItWorks';

type Proof = NonNullable<HowItWorksData['proof']>;
interface Props {
  eyebrow?: string;
  heading?: string;
  avatar?: Proof['avatar'];
  quote?: string;
  name?: string;
  org?: string;
  ratingCards?: NonNullable<Proof['ratingCards']>;
}
const { eyebrow, heading, avatar, quote, name, org, ratingCards = [] } = Astro.props;
const avatarUrl = imgUrl(avatar);
---

<section class="section hiw-proof">
  <div class="hiw-centered appear-el appear-el--rise" data-appear>
    <p class="t-eyebrow">{eyebrow}</p>
    <h2 class="t-h2" style="text-align:center">{heading}</h2>
  </div>
  <div class="hiw-proof__grid appear-el appear-el--rise" data-appear style="transition-delay:0.1s">
    {/* Big testimonial */}
    <div class="hiw-testimonial">
      <div
        class="hiw-testimonial__avatar"
        style={`background-image:url(${avatarUrl})`}
      >
      </div>
      <div class="hiw-testimonial__body">
        <h3 class="t-h3">{quote}</h3>
        <div class="hiw-nametag">
          <span class="hiw-name">{name}</span>
          <span class="hiw-org">{org}</span>
        </div>
      </div>
    </div>

    {
      ratingCards.map((c) => (
        <RatingCard
          logo={imgUrl(c.logo)}
          logoAlt={c.logoAlt}
          rating={c.rating}
          buttonLabel={c.buttonLabel}
          buttonHref={c.buttonHref}
        />
      ))
    }
  </div>
</section>
