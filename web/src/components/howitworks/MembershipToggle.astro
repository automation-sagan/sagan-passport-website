const I_MAP = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"><path stroke="#093A3E" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M25 10.417 15 7.083 5 10.417v21.666l10-3.333m10-18.333 10-3.334V28.75l-10 3.333-10-3.333m10-18.333V31.25m-10-2.5V7.917"/></svg>';
const I_BOARD = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"><path stroke="#093A3E" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m26.667 35.833-1.429-5m-11.905 5 1.429-5m-1.429-9.166v1.666m6.667-10v10m6.667-5v5M35 6.667V30H5V6.667h30Z"/></svg>';
const I_CHAT = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"><path stroke="#093A3E" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M28.333 23.333h6.67V6.667H11.67v6.666m16.667 0H5.004V30h5v4.166l7.5-4.166h10.833V13.333Z"/></svg>';
const I_LOCK = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"><path stroke="#093A3E" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M26.667 16.667v-5a6.667 6.667 0 0 0-13.334 0v5M20 23.333v5M8.333 16.667h23.334V35H8.333V16.667Z"/></svg>';
const I_STAR = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"><path stroke="#093A3E" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M31.667 21.667C23.497 22.374 19.04 26.83 18.333 35 17.596 26.704 13.163 22.591 5 21.667c8.291-.957 12.377-5.042 13.333-13.334.925 8.163 5.038 12.597 13.334 13.334Z"/><path fill="#093A3E" d="M31.477 3.909a.648.648 0 0 0-1.288-.002c-.175 1.524-.628 2.57-1.337 3.279-.709.709-1.754 1.161-3.278 1.337a.648.648 0 0 0 .001 1.288c1.498.17 2.567.622 3.294 1.336.724.71 1.185 1.754 1.319 3.262a.648.648 0 0 0 1.291-.001c.128-1.483.59-2.55 1.317-3.278.728-.728 1.795-1.19 3.278-1.317a.648.648 0 0 0 .002-1.292c-1.509-.134-2.553-.595-3.263-1.318-.714-.727-1.166-1.796-1.336-3.294Z"/></svg>';
const I_DOC = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"><path stroke="#093A3E" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21.667 5H8.333v30h23.334V15m-10-10 10 10m-10-10v10h10M15 21.667h5m-5 6.666h10.833"/></svg>';
const I_TOOLS = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"><path fill="#093A3E" d="M10 16.667h1a1 1 0 0 0-1-1v1ZM10 27.5v1a1 1 0 0 0 1-1h-1Zm20.833-10.833v-1a1 1 0 0 0-1 1h1Zm0 10.833h-1a1 1 0 0 0 1 1v-1ZM20 35h-1a1 1 0 0 0 1 1v-1Zm1-3.333a1 1 0 1 0-2 0h2ZM33.917 27.5a1 1 0 1 0-2 0h2ZM7.5 16.667v1H10v-2H7.5v1Zm2.5 0H9V27.5h2V16.667h-1ZM10 27.5v-1H7.5v2H10v-1ZM5 25h1v-5.833H4V25h1Zm2.5 2.5v-1A1.5 1.5 0 0 1 6 25H4a3.5 3.5 0 0 0 3.5 3.5v-1Zm0-10.833v-1a3.5 3.5 0 0 0-3.5 3.5h2a1.5 1.5 0 0 1 1.5-1.5v-1Zm23.333 0v1h2.5v-2h-2.5v1Zm5 2.5h-1V25h2v-5.833h-1Zm-2.5 8.333v-1h-2.5v2h2.5v-1Zm-2.5 0h1V16.667h-2V27.5h1Zm5-2.5h-1a1.5 1.5 0 0 1-1.5 1.5v2a3.5 3.5 0 0 0 3.5-3.5h-1Zm-2.5-8.333v1a1.5 1.5 0 0 1 1.5 1.5h2a3.5 3.5 0 0 0-3.5-3.5v1Zm-25-.417h1C9.333 10.655 14.227 6 20.417 6V4C13.259 4 7.333 9.418 7.333 16.25h1ZM20.417 5v1C26.607 6 31.5 10.655 31.5 16.25h2C33.5 9.418 27.574 4 20.417 4v1ZM8.333 16.25h-1v.417h2v-.417h-1Zm24.167 0h-1v.417h2v-.417h-1ZM25.417 35v-1H20v2h5.417v-1ZM20 35h1v-3.333h-2V35h1Zm12.917-7.5h-1a6.5 6.5 0 0 1-6.5 6.5v2a8.5 8.5 0 0 0 8.5-8.5h-1Z"/></svg>';
const I_LAYERS = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"><path stroke="#093A3E" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M38.333 15 20 23.333 1.667 15 20 6.667 38.333 15Zm0 0v11.667m-30-8.334V27.5L20 33.333 31.667 27.5v-9.167"/></svg>';
const I_UMBRELLA = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"><path stroke="#093A3E" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.663 33.333H33.33m-13.33-5v5m0-21.666v-5m-3.333 0h6.666m-16.67 20c0-9.167 5.97-15 13.333-15 7.364 0 13.334 5.833 13.334 15v1.666H6.663v-1.666Z"/></svg>';
const I_GLOBE = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"><path stroke="#093A3E" stroke-linecap="square" stroke-width="2" d="M35 20c0 8.284-6.716 15-15 15m15-15c0-8.284-6.716-15-15-15m15 15H5m15 15c-8.284 0-15-6.716-15-15m15 15c-3.682 0-6.667-6.716-6.667-15 0-8.284 2.985-15 6.667-15m0 30c3.682 0 6.667-6.716 6.667-15 0-8.284-2.985-15-6.667-15M5 20c0-8.284 6.716-15 15-15"/></svg>';

/* Icon lookup — the editable content (label/title/description/photo) lives in the
 * `membership` Sanity singleton; each benefit stores an `iconKey` that maps to one
 * of these inlined SVGs (the icons themselves stay in code). */
const ICONS: Record<string, string> = {
  tag: I_TAG,
  hand: I_HAND,
  map: I_MAP,
  doc: I_DOC,
  chat: I_CHAT,
  star: I_STAR,
  board: I_BOARD,
  umbrella: I_UMBRELLA,
  tools: I_TOOLS,
  lock: I_LOCK,
  layers: I_LAYERS,
  globe: I_GLOBE,
};

import { imgUrl } from '../../lib/sanityImage';
import type { MembershipTab } from '../../lib/membership';

interface Props {
  tabs?: MembershipTab[];
}
const { tabs = [] } = Astro.props;

const TABS = tabs.map((t) => ({
  label: t.label,
  image: imgUrl(t.image),
  items: (t.items ?? []).map((it) => ({
    icon: ICONS[it.iconKey ?? ''] ?? '',
    title: it.title,
    description: it.description,
  })),
}));
---

<div class="mtog">
  <div class="mtog__tabs" role="tablist">
    {
      TABS.map((t, i) => (
        <button
          type="button"
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          class={`mtog__tab${i === 0 ? ' is-active' : ''}`}
          data-tab={i}
        >
          {t.label}
        </button>
      ))
    }
  </div>

  <div class="mtog__panel">
    <div class="mtog__media">
      {
        TABS.map((t, i) => (
          <img
            class={`mtog__photo${i === 0 ? ' is-active' : ''}`}
            data-photo={i}
            src={t.image}
            alt=""
            loading="lazy"
          />
        ))
      }
    </div>
    <div class="mtog__points">
      {
        TABS.map((t, i) => (
          <div class={`mtog__group${i === 0 ? ' is-active' : ''}`} data-group={i}>
            {t.items.map((it) => (
              <div class="mtog__item">
                <span class="mtog__icon" aria-hidden="true" set:html={it.icon} />
                <h5 class="mtog__title">{it.title}</h5>
                <p class="mtog__desc">{it.description}</p>
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  /* MembershipToggle — interactive benefits tab switcher (framer toggle-component). */
  .mtog {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  /* ---- Tab bar ---- */
  .mtog__tabs {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
  }
  .mtog__tab {
    padding: 12px 24px;
    font-family: var(--pp);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--glacier);
    background: transparent;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    transition:
      background-color 0.3s cubic-bezier(0.44, 0, 0.56, 1),
      color 0.3s cubic-bezier(0.44, 0, 0.56, 1);
  }
  /* Active = Clay maroon pill (framer toggle-button active color). */
  .mtog__tab.is-active {
    background: rgb(97, 31, 44);
    color: var(--white);
  }

  /* ---- Content panel ---- */
  .mtog__panel {
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 56px;
    padding: 56px;
    background: var(--white);
    border: 1px solid rgb(227, 222, 216);
    border-radius: 32px;
    box-shadow:
      0.0602px 0.6022px 0.6052px -1.0833px rgba(0, 0, 0, 0.11),
      0.2289px 2.2885px 2.2999px -2.1667px rgba(0, 0, 0, 0.1),
      1px 10px 10.0499px -3.25px rgba(0, 0, 0, 0.06);
  }
  /* Image side (per-tab photo) */
  .mtog__media {
    position: relative;
    flex: 1 1 0;
    min-height: 520px;
    border-radius: 24px;
    overflow: hidden;
    background: var(--space-200);
  }
  .mtog__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.3s cubic-bezier(0.44, 0, 0.56, 1);
  }
  .mtog__photo.is-active {
    opacity: 1;
  }
  /* Benefit items, stacked on the other side */
  .mtog__points {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .mtog__group {
    display: none;
    flex-direction: column;
    gap: 40px;
  }
  .mtog__group.is-active {
    display: flex;
  }
  .mtog__item {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .mtog__icon {
    display: block;
    width: 40px;
    height: 40px;
  }
  .mtog__icon :global(svg) {
    display: block;
    width: 40px;
    height: 40px;
  }
  .mtog__title {
    margin: 0;
    font-family: var(--pp-semibold);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--glacier);
  }
  .mtog__desc {
    margin: 0;
    font-family: var(--pp);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: var(--glacier);
  }

  /* ===== Tablet / phone ===== */
  @media (max-width: 810px) {
    .mtog {
      gap: 32px;
    }
    .mtog__panel {
      flex-direction: column;
      padding: 32px;
      gap: 32px;
    }
    .mtog__media {
      min-height: 280px;
    }
    .mtog__group {
      gap: 32px;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.mtog').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLElement>('[data-tab]'));
    const photos = Array.from(root.querySelectorAll<HTMLElement>('[data-photo]'));
    const groups = Array.from(root.querySelectorAll<HTMLElement>('[data-group]'));

    const activate = (idx: number) => {
      tabs.forEach((t, i) => {
        const on = i === idx;
        t.classList.toggle('is-active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      photos.forEach((p, i) => p.classList.toggle('is-active', i === idx));
      groups.forEach((g, i) => g.classList.toggle('is-active', i === idx));
    };

    tabs.forEach((t, i) => t.addEventListener('click', () => activate(i)));
  });
</script>
