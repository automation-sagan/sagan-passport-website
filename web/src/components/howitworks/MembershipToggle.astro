---
/* ----------------------------------------------------------------------------
 * MembershipToggle — Astro port of the Framer `toggle-component`. An interactive
 * 4-tab switcher (Hiring · Education · Tools · Compensation); the active tab
 * reveals its benefit items (icon + title + description). Tab switching is driven
 * by the vanilla <script> at the bottom.
 *
 * Icons are INLINED (the exact Framer line-art SVGs, stroke #093A3E) so they
 * always render with no CDN/image-loading dependency. Content extracted verbatim
 * from toggle-component.jsx.
 * ------------------------------------------------------------------------- */

/* Inlined 40×40 line icons (verbatim from framerusercontent SVGs). */
const I_TAG = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"><path stroke="#093A3E" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m7.5 29.167-4.167 4.166m7.5-.833-2.5 2.5M5 20.833s6.283 2.117 9.167 5c2.883 2.884 5 9.167 5 9.167L25 30v-5c6.667-3.333 10.833-8.333 10-20-11.667-.833-16.667 3.333-20 10h-5l-5 5.833Zm23.333-6.666a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Z"/></svg>';
