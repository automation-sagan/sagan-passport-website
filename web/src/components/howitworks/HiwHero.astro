---
/* How It Works hero — "Stop Sifting." + Spline animation + subcopy. */
import SplineEmbed from '../homepage/SplineEmbed.astro';
---

<section class="section hiw-hero">
  <div class="hiw-hero__content">
    <div class="hiw-hero__title">
      <h2 class="t-h2" style="text-align:center">Stop Sifting.</h2>
      <div class="hiw-hero__anim">
        <SplineEmbed
          scene="https://prod.spline.design/hnKgxipHE7hU2hJC-JWR/scene.hanacode"
          version="1.2.38"
        />
      </div>
    </div>
    <p class="t-body" style="text-align:center">
      Hiring shouldn&rsquo;t be a second job. We do the heavy lifting and deliver a vetted
      shortlist of high-caliber talent, saving you dozens of hours.
    </p>
  </div>
</section>
