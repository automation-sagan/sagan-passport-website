---
/* How It Works hero — "Stop Sifting." + Spline animation + subcopy. Heading/body
 * come from Sanity; the Spline scene URL stays in code. */
import SplineEmbed from '../homepage/SplineEmbed.astro';

interface Props {
  heading?: string;
  body?: string;
}
const { heading, body } = Astro.props;
---

<section class="section hiw-hero">
  <div class="hiw-hero__content">
    <div class="hiw-hero__title">
      <h2 class="t-h2 appear-el appear-el--rise" style="text-align:center" data-appear>{heading}</h2>
      <div class="hiw-hero__anim">
        <SplineEmbed
          scene="https://prod.spline.design/hnKgxipHE7hU2hJC-JWR/scene.hanacode"
          version="1.2.38"
        />
      </div>
    </div>
    <p class="t-body appear-el appear-el--rise" style="text-align:center;transition-delay:0.12s" data-appear>{body}</p>
  </div>
</section>
