---
/* FAQ — heading (left) + accordion (right). Content comes from the How It Works
 * singleton in Sanity. */
import FaqAccordion from './FaqAccordion.astro';
import type { QA } from './FaqAccordion.astro';
import type { HiwFaqItem } from '../../lib/howItWorks';

interface Props {
  heading?: string;
  items?: HiwFaqItem[];
}
const { heading, items = [] } = Astro.props;

const faqs: QA[] = items.map((it) => ({
  question: it.question ?? '',
  answer: it.answer ?? '',
}));
---

<section class="section hiw-faq">
  <div class="hiw-faq__inner">
    <div class="hiw-faq__head appear-el appear-el--rise" data-appear>
      <h3 class="t-h3" style="max-width:291px;margin:0">{heading}</h3>
    </div>
    <div class="hiw-faq__list appear-el appear-el--rise" data-appear style="transition-delay:0.1s">
      <FaqAccordion items={faqs} />
    </div>
  </div>
</section>
