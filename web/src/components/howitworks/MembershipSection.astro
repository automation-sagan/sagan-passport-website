---
/* Membership benefits — eyebrow + heading + subcopy + the interactive toggle. */
import MembershipToggle from './MembershipToggle.astro';
---

<section class="section hiw-membership">
  <div class="hiw-centered">
    <p class="t-eyebrow">Membership Benefits</p>
    <h2 class="t-h2" style="text-align:center">
      More Than a Recruiter:&nbsp; A True Talent Partnership
    </h2>
    <p class="t-body" style="text-align:center">
      Your membership is an investment in a rich support ecosystem that ensures retention and
      success. This is what sets Sagan apart. All benefits extend to your entire team.
    </p>
  </div>
  <div class="hiw-toggle">
    <MembershipToggle />
  </div>
</section>
