        <span class="review-meta">(45 reviews)</span>
      </div>
      <div class="review-pill">
        <span class="review-trophy" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 4C5 8 5 13 7 18" />
            <path d="M17 4C19 8 19 13 17 18" />
            <path d="M9 19c1 1 2 1 3 1s2 0 3-1" />
            <path d="M8 9c1 0 2-.5 2-1.5" />
            <path d="M8 13c1 0 2-.5 2-1.5" />
            <path d="M16 9c-1 0-2-.5-2-1.5" />
            <path d="M16 13c-1 0-2-.5-2-1.5" />
