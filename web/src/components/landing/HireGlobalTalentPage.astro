<!-- Twitter / X widgets embed (loads the testimonial wall). Kept verbatim. -->
<script is:inline async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>

<script is:inline define:vars={{ CALENDLY_URL: cta }}>
  const reveals = document.querySelectorAll(".reveal");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  reveals.forEach((node) => observer.observe(node));

  const hydrateTweetCard = (card) => {
    const quote = card.querySelector(".tweet-fallback");

    if (!quote || quote.dataset.tweetHydrated === "true") return;

    quote.dataset.tweetHydrated = "true";
    quote.classList.add("twitter-tweet");

    if (window.twttr && window.twttr.widgets) {
      window.twttr.widgets.load(card);
    }
  };

  const startTweetHydration = () => {
    if (!window.twttr || !window.twttr.widgets) {
      window.setTimeout(startTweetHydration, 250);
      return;
    }

    const tweetCards = Array.from(document.querySelectorAll(".tweet-embed-card"));
    tweetCards.slice(0, 3).forEach(hydrateTweetCard);

    const tweetObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          hydrateTweetCard(entry.target);
          tweetObserver.unobserve(entry.target);
        });
      },
      { rootMargin: "900px 0px", threshold: 0.01 }
    );

    tweetCards.slice(3).forEach((card) => tweetObserver.observe(card));
  };

  window.addEventListener("load", startTweetHydration);

  /* ---- HubSpot email capture ----
     Same portal + form used site-wide (see hubspot-capture.js).
     Both IDs are public and safe to keep in this file. */
  const HUBSPOT = {
    portalId: "50517161",
    formGuid: "daac2804-e5c3-48e7-8ab7-a5b41c9e7c38",
  };

  /* Make.com webhook — fires a parallel POST on every submission, mirroring
     hubspot-capture.js. Body shape: { submission: { submittedAt, pageUrl,
     pageTitle, ...fields } } — all keys flat. */
  const MAKE_WEBHOOK_URL = "https://hook.us2.make.com/2ccpsjqsst3arigocljg0trvlx7reu1n";

  /* Fire-and-forget POST to the Make scenario. `raw` is the flat set of
     submitted fields (email + any UTMs); page context is merged on top. */
  const sendToMake = (raw) => {
    if (!MAKE_WEBHOOK_URL) return;
    const submission = Object.assign(
      {
        submittedAt: new Date().toISOString(),
        pageUrl: window.location.href,
        pageTitle: document.title,
      },
      raw
    );
    const payload = { submission: submission };
    try {
      fetch(MAKE_WEBHOOK_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
        keepalive: true,
      }).catch((err) => console.warn("[Make Webhook] Network error:", err));
    } catch (e) {
      console.warn("[Make Webhook] Failed to send:", e);
    }
  };

  /* Capture UTM params (utm_source/medium/campaign/content/term) and
     persist them in sessionStorage so they survive a multi-page journey —
     mirrors the behaviour of the shared hubspot-capture.js. Returns a flat
     { utm_source: "...", ... } object for whatever is present. */
  const captureUTMs = () => {
    const params = new URLSearchParams(window.location.search);
    const keys = ["utm_source", "utm_medium", "utm_campaign", "utm_content", "utm_term"];
    const found = {};
    keys.forEach((k) => {
      const v = params.get(k);
      if (v) found[k] = v;
    });
    if (Object.keys(found).length > 0) {
      try { sessionStorage.setItem("_sg_utms", JSON.stringify(found)); } catch (e) {}
    }
    let stored = {};
    try { stored = JSON.parse(sessionStorage.getItem("_sg_utms") || "{}"); } catch (e) {}
    const result = Object.assign({}, stored, found); // URL params win over stored
    // Fallback for this landing page: if the visitor arrived with no
    // utm_source (URL or a prior page), tag the lead source as "HSA".
    // A real utm_source from an ad/campaign is always kept. Applied only
    // to the returned value — never written to sessionStorage — so it
    // can't override the source on other Sagan pages.
    if (!result.utm_source) result.utm_source = "HSA";
    return result;
  };

  (function initLeadForm() {
    const form = document.getElementById("leadForm");
    if (!form) return;

    const emailInput = document.getElementById("leadEmail");
    const msg = document.getElementById("leadFormMsg");
    const successMsg = document.getElementById("leadFormSuccess");
    const submitBtn = form.querySelector('button[type="submit"]');

    const showSuccess = () => {
      form.hidden = true;
      successMsg.hidden = false;
      // Best-effort: open Calendly. If the browser blocks it, the button below still works.
      try {
        window.open(CALENDLY_URL, "_blank", "noopener");
      } catch (e) {}
    };

    const isConfigured =
      HUBSPOT.portalId &&
      HUBSPOT.formGuid &&
      HUBSPOT.portalId !== "YOUR_PORTAL_ID" &&
      HUBSPOT.formGuid !== "YOUR_FORM_GUID";

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const email = emailInput.value.trim();
      msg.textContent = "";
      msg.classList.remove("is-error");

      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        msg.textContent = "Please enter a valid email address.";
        msg.classList.add("is-error");
        emailInput.focus();
        return;
      }

      const originalLabel = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";

      if (!isConfigured) {
        console.warn("[HubSpot] Set HUBSPOT.portalId and HUBSPOT.formGuid to enable capture.");
        showSuccess();
        return;
      }

      try {
        // Build the field list: email + any UTM params we captured.
        const fields = [{ name: "email", value: email }];
        const utms = captureUTMs();
        const raw = { email: email };
        ["utm_source", "utm_medium", "utm_campaign", "utm_content", "utm_term"].forEach((k) => {
          if (utms[k]) {
            fields.push({ name: k, value: utms[k] });
            raw[k] = utms[k];
          }
        });

        // Fire the Make.com webhook in parallel — same email + UTMs + page context.
        sendToMake(raw);

        const res = await fetch(
          "https://api.hsforms.com/submissions/v3/integration/submit/" +
            HUBSPOT.portalId +
            "/" +
            HUBSPOT.formGuid,
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              fields: fields,
              context: {
                pageUri: window.location.href,
                pageName: document.title,
              },
            }),
          }
        );
        if (!res.ok) throw new Error("HubSpot responded " + res.status);
        showSuccess();
      } catch (err) {
        console.error(err);
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
        msg.textContent = "Something went wrong — please try again.";
        msg.classList.add("is-error");
      }
    });

    // CTAs across the page point at #call (smooth-scroll). Focus the email
    // field once they land, so capturing the email is clearly the first step.
    document.querySelectorAll('a[href="#call"]').forEach((link) => {
      link.addEventListener("click", () => {
        if (form.hidden) return; // already submitted — leave the success state alone
        window.setTimeout(function () {
          emailInput.focus({ preventScroll: true });
        }, 500);
      });
    });
  })();

  /* ---- Layout-shift-proof in-page navigation ----
     The testimonial wall lazy-loads ~30 Twitter embeds as you scroll, which
     grows the page by thousands of px mid-scroll. A native #anchor jump (or
     CSS smooth scroll) locks onto a stale target position and strands you in
     the tweet wall instead of the section you clicked. This re-reads the
     target's live position every frame so the scroll tracks the growing
     content, then settles exactly on the section under the sticky header.
     HEADER_OFFSET is derived from the 76px .topbar (+ small gap) — adjust
     if the topbar height changes. */
  (function initSmoothAnchors() {
    const HEADER_OFFSET = 80;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function targetTop(el) {
      return Math.max(0, el.getBoundingClientRect().top + window.scrollY - HEADER_OFFSET);
    }

    function scrollToEl(el) {
      if (reduceMotion) {
        window.scrollTo(0, targetTop(el));
        return;
      }
      const startY = window.scrollY;
      const startTime = performance.now();
      const duration = 650;
      const settleDeadline = startTime + duration + 1500; // cap the settle phase
      const ease = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

      // Suppress CSS smooth-scroll so our per-frame jumps aren't double-animated.
      const root = document.documentElement;
      const prevBehavior = root.style.scrollBehavior;
      root.style.scrollBehavior = "auto";

      let stableFrames = 0;
      let lastTarget = targetTop(el);

      function frame(now) {
        const elapsed = now - startTime;
        if (elapsed < duration) {
          const y = startY + (targetTop(el) - startY) * ease(elapsed / duration);
          window.scrollTo(0, y);
          requestAnimationFrame(frame);
          return;
        }
        // Settle: glide onto the (possibly still-moving) target, then lock.
        const ty = targetTop(el);
        const next = window.scrollY + (ty - window.scrollY) * 0.3;
        window.scrollTo(0, next);
        stableFrames = Math.abs(ty - lastTarget) < 1 && Math.abs(ty - next) < 1
          ? stableFrames + 1
          : 0;
        lastTarget = ty;
        if (stableFrames < 5 && now < settleDeadline) {
          requestAnimationFrame(frame);
        } else {
          window.scrollTo(0, ty);
          root.style.scrollBehavior = prevBehavior;
        }
      }
      requestAnimationFrame(frame);
    }

    document.querySelectorAll('a[href^="#"]').forEach((link) => {
      const hash = link.getAttribute("href");
      if (!hash || hash === "#") return; // leave "#"/"#top" to native behaviour
      link.addEventListener("click", (event) => {
        const el = document.querySelector(hash);
        if (!el) return; // no matching target — don't hijack the click
        event.preventDefault();
        scrollToEl(el);
        history.replaceState(null, "", hash);
      });
    });
  })();
</script>
