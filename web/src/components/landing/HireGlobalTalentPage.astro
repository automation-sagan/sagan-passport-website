---
/* Faithful 1:1 port of /hire-global-talent/index.html. Bespoke layout, copy,
 * testimonial wall, lead-form/HubSpot/Make capture, and smooth-anchor JS are
 * preserved verbatim. Only the hero (eyebrow, headline, lead) and the primary
 * Calendly CTA are driven by the `landingPage` Sanity document. CSS is the
 * page's exact original, extracted to styles/landing/hire-global-talent.css
 * (with the source <head> Google Fonts <link> prepended as an @import). */
import type { LandingPageData } from '../../lib/landingPages';
import '../../styles/landing/hire-global-talent.css';

interface Props {
  data: LandingPageData;
}
const { data } = Astro.props;

const cta =
  data.ctaUrl ?? 'https://calendly.com/d/cmcb-jfm-gs8/global-talent-hiring-consultation-rene';
---

<header class="topbar">
  <div class="wrap topbar__row">
    <a class="brand" href="#top" aria-label="Sagan home">
      <img src="/hire-global-talent/assets/sagan-logo.png" alt="" />
      <span>Sagan</span>
    </a>
    <nav class="nav" aria-label="Page navigation">
      <a href="#model">Model</a>
      <a href="#roles">Roles</a>
      <a href="#process">Process</a>
      <a href="#call">Consultation</a>
    </nav>
    <a class="btn btn--blue" href="#call">
      Find my next hire
    </a>
  </div>
</header>

<main id="top">
  <section class="hero" aria-labelledby="hero-title">
    <div class="wrap hero__grid">
      <div class="hero__copy reveal">
        <span class="eyebrow">{data.heroEyebrow ?? 'global talent hiring consultation'}</span>
        <h1 id="hero-title" set:html={data.heroHeadlineHtml ?? 'Hire the person. Skip the staffing markup.'} />
        <p
          class="hero__lead"
          set:html={data.heroLeadHtml ??
            'Sagan helps HVAC, plumbing, roofing, cleaning, and home service operators hire career-caliber professionals across Latin America, South Africa, the Philippines, and beyond. Dispatch, phones, books, estimates, follow-up, and ops support without the staffing markup.'}
        />
        <div class="hero__actions">
          <a class="btn btn--primary" href="#call">
            Find my next hire
          </a>
          <a class="btn btn--ghost" href="#model">See the model</a>
        </div>
        <p class="hero__note">30 minutes. Role, salary band, market fit, and the next move.</p>
        <div class="signal-strip" aria-label="Common global talent roles">
          <span>dispatcher</span>
          <span>CSR</span>
          <span>bookkeeper</span>
          <span>estimate coordinator</span>
          <span>ServiceTitan admin</span>
          <span>lead follow-up</span>
        </div>
      </div>

      <aside class="talent-panel reveal" aria-label="Sagan talent pipeline preview">
        <div class="panel-head">
          <span><span class="status-dot" aria-hidden="true"></span> live talent map</span>
          <span>SAGAN / DIRECT HIRE</span>
        </div>
        <div class="pipeline">
          <div class="candidate">
            <div class="avatar">AM</div>
            <div>
              <strong>Dispatch Coordinator</strong>
              <span>Colombia / ServiceTitan / $1.5k-$2.5k/mo</span>
            </div>
            <div class="match">shortlist</div>
          </div>
          <div class="candidate">
            <div class="avatar">TS</div>
            <div>
              <strong>Bookkeeper</strong>
              <span>South Africa / AP, AR, month-end / $900-$2k/mo</span>
            </div>
            <div class="match">screened</div>
          </div>
          <div class="candidate">
            <div class="avatar">LR</div>
            <div>
              <strong>Customer Service Rep</strong>
              <span>Philippines / phones, intake, scheduling / $900-$1.5k/mo</span>
            </div>
            <div class="match">ready</div>
          </div>
          <div class="candidate">
            <div class="avatar">JV</div>
            <div>
              <strong>Lead Follow-Up Coordinator</strong>
              <span>Mexico / estimates, CRM, rehash / $1.2k-$2.5k/mo</span>
            </div>
            <div class="match">match</div>
          </div>
        </div>
        <div class="panel-foot">
          <div class="metric">
            <b>20+</b>
            <span>countries sourced</span>
          </div>
          <div class="metric">
            <b>direct</b>
            <span>client relationship</span>
          </div>
          <div class="metric">
            <b>human</b>
            <span>not seats</span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <div class="proof">
    <div class="wrap proof__bar reveal" aria-label="Sagan operating principles">
      <div class="proof__item">
        <b>Direct hire</b>
        <span>The talent works with your team, not behind an agency wall.</span>
      </div>
      <div class="proof__item">
        <b>Global reach</b>
        <span>Latin America, South Africa, Philippines, Eastern Europe, and more.</span>
      </div>
      <div class="proof__item">
        <b>Operator-led</b>
        <span>Role design starts from workflow, not a generic job-description template.</span>
      </div>
      <div class="proof__item">
        <b>Clean math</b>
        <span>No mystery markup sitting between you and the person doing the work.</span>
      </div>
    </div>

