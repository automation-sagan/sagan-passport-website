<!-- ════════════════════════════════════════════════ BELOW THE FOLD ════════════════════════════════════════════════ -->

<!-- How it works: 3 steps -->
<section class="section section-white">
  <div class="wrap">
    <p class="label">The process</p>
    <h2 class="heading">One call. Your next hire<br><em>in 2-4 weeks.</em></h2>
    <p class="subhead">You never touch a job board. We do the heavy lifting and deliver vetted finalists directly to you.</p>
    <div class="steps">
      <div class="step">
        <div class="sn">1</div>
        <div class="sb">
          <h3>We define your perfect hire in one strategy call</h3>
          <p>We build a detailed scorecard, run a tailored search across global markets, and screen hundreds of candidates so you don't have to.</p>
        </div>
      </div>
      <div class="step">
        <div class="sn">2</div>
        <div class="sb">
          <h3>You meet 2-3 vetted finalists with 360 profiles</h3>
          <p>Every finalist comes with resume, video intro, strengths assessment, and recruiter evaluation. Pick your favourite and go straight to final interviews.</p>
        </div>
      </div>
      <div class="step">
        <div class="sn">3</div>
        <div class="sb">
          <h3>Your hire starts fast. 30-90 day onboarding plan included</h3>
          <p>Offer templates, custom onboarding milestones, and a 90-day replacement guarantee. We stay involved until it works.</p>
        </div>
      </div>
    </div>
  </div>
</section>

