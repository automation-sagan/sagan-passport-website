      <article class="personx" aria-hidden="true"><img src="https://cdn.sanity.io/images/3ofs1zkm/production/700e9eadef388ba1d8e0c1df024ef8371c90eba0-1293x888.png?w=800&fit=max&auto=format" alt="" loading="lazy" /><div class="personx__overlay"></div><div class="personx__content"><div class="personx__info"><span class="personx__name">Agostina</span><span class="personx__role">Customer Service Rep.</span></div><span class="personx__rate">$1,200/month</span></div></article>
