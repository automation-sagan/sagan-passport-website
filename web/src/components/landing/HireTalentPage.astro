---
/* Faithful 1:1 port of the bespoke /hire-talent landing page. The full bespoke
 * layout + persuasive copy are preserved verbatim from the source HTML; only the
 * hero (eyebrow / headline / lead) is driven by the `landingPage` Sanity doc, and
 * the primary booking/Calendly CTA resolves from `data.ctaUrl`. The page's exact
 * original CSS (incl. base64 PP Mori fonts) is extracted to
 * styles/landing/hire-talent.css. */
import type { LandingPageData } from '../../lib/landingPages';
import '../../styles/landing/hire-talent.css';

interface Props {
  data: LandingPageData;
}
const { data } = Astro.props;

const cta =
  data.ctaUrl ??
  'https://calendly.com/d/5j7-3xv-p5k/global-talent-hiring-consultation?utm_source=meta_retargeting&utm_medium=paid&utm_campaign=retargeting-v1&hide_gdpr_banner=1&hide_event_type_details=1&background_color=ffffff&text_color=093a3e&primary_color=093a3e';
---

<!-- ─── NAV BAR: Sagan logo + Schedule a Call only ─── -->
<header class="bar">
  <a href="https://saganpassport.com" class="bar-logo" aria-label="Sagan — home">
    <img src="https://cdn.sanity.io/images/3ofs1zkm/production/4290436ea09e67a14e91e18ae3467dc741ab1e2e-80x80.png" alt="" width="26" height="26" />
    <span>Sagan</span>
  </a>
  <a href="#book" class="bar-cta">Schedule a Call</a>
</header>

<!-- ════════════════════════════════════════════════
     HERO — single column, centered (main-website feel)
════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero-inner">

    {data.heroEyebrow && (
      <div class="eyebrow"><span class="e-dot"></span>{data.heroEyebrow}</div>
    )}

    <h1 class="h1" set:html={data.heroHeadlineHtml}></h1>

    <p class="sub" set:html={data.heroLeadHtml}></p>

    <ul class="bullets">
      <li>
        <div class="b-icon">✓</div>
        <span><strong>You meet 3 finalists</strong>: every candidate passes skill tests, live English interviews, and US culture screening before you see them</span>
      </li>
      <li>
        <div class="b-icon">✓</div>
        <span><strong>0-2 hour time zone overlap</strong>: most talent is in Latin America; they work your hours, join your standups, and use your tools</span>
      </li>
      <li>
        <div class="b-icon">✓</div>
        <span><strong>90-day free replacement guarantee</strong>: if it isn't a perfect fit for any reason, we replace them at zero additional cost</span>
      </li>
    </ul>

    <div class="cta-wrap">
      <a href="#book" class="btn-fill">
        <span class="btn-fill__label">Get a Free Hiring Consultation</span>
        <span class="btn-fill__circle">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" aria-hidden="true"><path d="M5 12h13M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
    </div>

  </div>
</section>

