---
/* ResourceCard — a single card in the Resources grid. Styling comes from the
 * global .res-card classes in resources.css. data-category drives the
 * client-side category filter on the listing page. */
import { formatDate, type ResourceSummary } from '../../lib/resources';
import { imgUrl } from '../../lib/sanityImage';
interface Props {
  resource: ResourceSummary;
}
const { resource: r } = Astro.props;
const mainImage = imgUrl(r.mainImage);
const authorImage = imgUrl(r.authorImage);
---

<a href={`/resources/${r.slug}`} class="res-card" data-category={r.category ?? ''}>
  <div class="res-card__img" style={`background-image:url(${mainImage})`}>
    <span class="res-card__cat">{r.category}</span>
  </div>
  <div class="res-card__body">
    <h3 class="res-card__title">{r.title}</h3>
    <div class="res-card__meta">
      <span class="res-card__avatar" style={`background-image:url(${authorImage})`}></span>
      <span class="res-card__author">{r.authorName}</span>
      {r.date && <span class="res-card__date">· {formatDate(r.date)}</span>}
    </div>
  </div>
</a>
