---
/* /agent/lead-intake — own route so only this page's CSS/scripts bundle. */
import LandingLayout from '../../layouts/LandingLayout.astro';
import LeadIntakeAgent from '../../components/agent/LeadIntakeAgent.astro';
import { getAgentDemoBySlug } from '../../lib/agentDemos';

export const prerender = true;
const data = (await getAgentDemoBySlug('lead-intake'))!;
---

<LandingLayout
  title={data.seoTitle ?? 'Lead Intake — a Sagan AI agent'}
  description={data.seoDescription}
  canonical={data.canonical}
>
  <LeadIntakeAgent data={data} />
</LandingLayout>
