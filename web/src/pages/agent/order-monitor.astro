---
/* /agent/order-monitor — own route so only this page's CSS/scripts bundle. */
import LandingLayout from '../../layouts/LandingLayout.astro';
import OrderMonitorAgent from '../../components/agent/OrderMonitorAgent.astro';
import { getAgentDemoBySlug } from '../../lib/agentDemos';

export const prerender = true;
const data = await getAgentDemoBySlug('order-monitor');
if (!data) return new Response(null, { status: 404 });
---

<LandingLayout
  title={data.seoTitle ?? 'Order Monitor — a Sagan AI agent'}
  description={data.seoDescription}
  canonical={data.canonical}
>
  <OrderMonitorAgent data={data} />
</LandingLayout>
