---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Appear from '../components/homepage/Appear.astro';
import ButtonOutline from '../components/homepage/ButtonOutline.astro';
import ButtonFill from '../components/homepage/ButtonFill.astro';
import FeatureCard from '../components/homepage/FeatureCard.astro';
import CourseCard from '../components/saganuniversity/CourseCard.astro';
import ProgramCard from '../components/saganuniversity/ProgramCard.astro';
import CheckmarkCard from '../components/saganuniversity/CheckmarkCard.astro';
import PlayButton from '../components/saganuniversity/PlayButton.astro';
import TestimonialSlideshow from '../components/saganuniversity/TestimonialSlideshow.astro';
import VideoLightbox from '../components/saganuniversity/VideoLightbox.astro';
import '../styles/saganuniversity.css';
import { getSaganUniversity } from '../lib/saganUniversity';
import { imgUrl } from '../lib/sanityImage';

/* Astro build of saganpassport.com/sagan-university. Content + images come from
 * the saganUniversity singleton in Sanity; the YouTube embed mechanism and the
 * leaf-card layouts live in code. */
const data = await getSaganUniversity();

const hero = data.hero ?? {};
const why = data.why ?? {};
const approach = data.approach ?? {};
const caseStudy = data.caseStudy ?? {};
const courses = data.courses ?? [];
const programs = data.programs ?? [];
const checks = approach.checks ?? [];
const checkIconUrl = imgUrl(approach.checkIcon);
const testimonials = (data.testimonials ?? []).map((t) => ({
  image: imgUrl(t.image),
  quote: t.quote ?? '',
  name: t.name ?? '',
  title: t.title ?? '',
}));

/* Ticker doubles the course list for a seamless marquee loop. */
const TICKER = [...courses, ...courses];
---

<Layout title={data.seoTitle ?? 'Sagan University — Sagan Passport'}>
  <Navbar />
  <div class="home">
    <!-- Hero -->
    <section class="section su-hero">
      <Appear rise class="su-centered">
        <h2 class="t-h2" style="text-align:center">{hero.heading}</h2>
        <h4 class="t-h4" style="text-align:center">{hero.subheading}</h4>
        <p class="t-body" style="text-align:center">{hero.body}</p>
        <div class="su-hero__buttons">
          {
            (hero.buttons ?? []).map((b) =>
              b.variant === 'fill' ? (
                <ButtonFill label={b.label ?? ''} href={b.href ?? ''} external={b.external} />
              ) : (
                <ButtonOutline
                  label={b.label ?? ''}
                  href={b.href ?? ''}
                  external={b.external}
                  variant={b.variant === 'white' ? 'white' : 'outline'}
                />
              ),
            )
          }
        </div>
      </Appear>
    </section>

    <!-- Featured courses ticker (auto-scrolling marquee) -->
    <section class="su-ticker">
      <span class="su-ticker__label">{data.coursesLabel}</span>
      <div class="su-ticker__viewport">
        <div class="su-ticker__track">
          {TICKER.map((c) => <CourseCard title={c.title ?? ''} image={imgUrl(c.image)} />)}
        </div>
      </div>
    </section>

    <!-- Why Sagan University -->
    <section class="section su-why" id="why">
      <Appear rise class="su-centered">
        <h2 class="t-h2" style="text-align:center">{why.heading}</h2>
        <p class="t-body-sm" style="text-align:center">{why.body}</p>
      </Appear>
      <Appear rise class="su-feature-grid" delay={0.1}>
        {
          (why.features ?? []).map((f) => (
            <FeatureCard title={f.title ?? ''} description={f.description ?? ''} icon={imgUrl(f.icon)} />
          ))
        }
      </Appear>
    </section>

    <!-- Programs -->
    <section class="section su-programs">
      <Appear rise class="su-program-grid">
        {
          programs.map((p) => (
            <ProgramCard title={p.title ?? ''} tag={p.tag ?? ''} body={p.body ?? ''} icon={imgUrl(p.icon)} />
          ))
        }
      </Appear>
    </section>

    <!-- Approach -->
    <section class="section su-approach">
      <Appear rise class="su-centered">
        <p class="t-eyebrow">{approach.eyebrow}</p>
        <h2 class="t-h2" style="text-align:center">{approach.heading}</h2>
      </Appear>
      <Appear rise class="su-check-grid" delay={0.1}>
        {checks.map((c) => <CheckmarkCard text={c} icon={checkIconUrl} />)}
      </Appear>
      <Appear
        rise
        class="su-largecard"
        blur={false}
        style={`background-image:url(${imgUrl(approach.cardImage)})`}>
        <div class="su-largecard__overlay"></div>
        <div class="su-largecard__content">
          <h2 class="t-h2" style="color:rgb(255,255,255)">{approach.cardHeading}</h2>
          <p class="t-body" style="color:rgb(255,255,255)">{approach.cardBody}</p>
        </div>
      </Appear>
    </section>

    <!-- Testimonials -->
    <section class="su-testimonial-wrap">
      <div class="su-testimonial">
        <TestimonialSlideshow slides={testimonials.length ? testimonials : undefined} />
      </div>
    </section>

    <!-- Case study / video -->
    <section class="section su-case">
      <Appear rise class="su-case__content">
        <h2 class="t-h2" style="max-width:580px">{caseStudy.heading}</h2>
        <p class="t-body" style="max-width:900px">{caseStudy.body}</p>
      </Appear>
      <VideoLightbox
        class="su-video"
        youtubeId={caseStudy.youtubeId ?? ''}
        style={`background-image:url(${imgUrl(caseStudy.poster)})`}>
        <div class="su-video__overlay"></div>
        <div class="su-video__play">
          <PlayButton />
        </div>
      </VideoLightbox>
    </section>
  </div>
  <Footer />
</Layout>
