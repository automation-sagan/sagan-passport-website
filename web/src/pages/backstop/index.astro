---
// Faithful 1:1 port of Backstop/index.html — an interactive landing page +
// claim form. Content stays IN CODE (no Sanity). Wrapped in LandingLayout for
// the SEO <head>; the page ships its own fonts (@import), <style is:global>,
// inline scripts, and the /hubspot-capture.js loader. The claim form POSTs to
// /backstop/api/send-email (ported APIRoute that proxies Resend).
import LandingLayout from '../../layouts/LandingLayout.astro';

export const prerender = true;
---

<LandingLayout
  title="Sagan Backstop — If oil hits $175, your Sagan membership is on us"
  description="If WTI crude settles at or above $175 a barrel on any trading day on or before June 30, 2026, we refund your Sagan Membership — and you keep all the benefits."
  canonical="https://saganpassport.com/backstop"
>
  <Fragment slot="head">
    <meta property="og:title" content="If oil hits $175, your Sagan membership is on us" />
    <meta property="og:description" content="Sagan Backstop. Our bet. Your refund. If WTI crude settles at or above $175 on any trading day on or before June 30, 2026, we refund your Sagan Membership." />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="If oil hits $175, your Sagan membership is on us" />
    <meta name="twitter:description" content="Sagan Backstop. Our bet. Your refund. If WTI crude settles at or above $175 on any trading day on or before June 30, 2026, we refund your Sagan Membership." />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-light.png" />
    <link rel="icon" href="/favicon-light.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon-dark.png" media="(prefers-color-scheme: dark)" />
  </Fragment>

  <style is:global>
@import url('https://fonts.googleapis.com/css2?family=Fragment+Mono&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,500&family=Space+Grotesk:wght@400;500;600;700&display=swap');
/* ────────────────────────────────────────────────────────────────
   SAGAN TOKENS — verified against saganpassport.com brand system
──────────────────────────────────────────────────────────────── */
:root {
  --glacier:        #093A3E;
  --dark-glacier:   #06282B;
  --glacier-muted:  #4A6B6B;
  --cream:          #F5F2ED;
  --cream-deep:     #EDE9E5;
  --white:          #FFFFFF;
  --dandelion:      #F5B800;
  --hairline:       rgba(9, 58, 62, 0.10);
  --hairline-soft:  rgba(9, 58, 62, 0.06);
  --hairline-strong: rgba(9, 58, 62, 0.18);

  --display: 'Plus Jakarta Sans', 'PP Mori', 'Inter', system-ui, sans-serif;
  --body:    'Space Grotesk', system-ui, sans-serif;
  --mono:    'Fragment Mono', ui-monospace, 'SF Mono', Menlo, monospace;

  --r-chip:  10px;
  --r-card:  24px;
  --r-panel: 40px;
  --r-hero:  48px;
  --r-pill:  999px;

  --ease: cubic-bezier(0.5, 0, 0, 1);
  --gutter: 24px;
  --max: 1200px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; scroll-behavior: smooth; }

body {
  font-family: var(--body);
  color: var(--glacier);
  background: var(--cream);
  font-size: 17px;
  line-height: 1.55;
  overflow-x: hidden;
}

a { color: inherit; text-decoration: none; }
ul { list-style: none; }

.wrap { max-width: var(--max); margin: 0 auto; padding: 0 var(--gutter); }

/* ────────────────────────────────────────────────────────────────
   TYPOGRAPHY
──────────────────────────────────────────────────────────────── */
h1, h2, h3 {
  font-family: var(--display);
  color: var(--glacier);
  font-weight: 600;
}

.mono { font-family: var(--mono); font-feature-settings: "tnum"; letter-spacing: 0; }

.eyebrow {
  font-family: var(--body);
  font-weight: 500;
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--glacier-muted);
}

.dash { color: var(--dandelion); }

/* ────────────────────────────────────────────────────────────────
   NAV
──────────────────────────────────────────────────────────────── */
.nav {
  position: sticky;
  top: 0;
  z-index: 50;
  padding: 18px 0;
  backdrop-filter: saturate(1.4) blur(10px);
  -webkit-backdrop-filter: saturate(1.4) blur(10px);
  background: rgba(245, 242, 237, 0.78);
  border-bottom: 1px solid transparent;
  transition: border-color .3s var(--ease);
}
.nav.is-scrolled { border-bottom-color: var(--hairline-soft); }
.nav__row {
  display: flex;
  align-items: center;
  gap: 28px;
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 var(--gutter);
}
.nav__logo {
  font-family: var(--display);
  font-weight: 600;
  letter-spacing: -0.015em;
  color: var(--glacier);
  font-size: 20px;
}
.nav__spacer { flex: 1; }
.nav__cta {
  display: inline-block;
  padding: 11px 22px;
  border-radius: var(--r-pill);
  background: var(--glacier);
  color: var(--cream);
  font-family: var(--display);
  font-weight: 600;
  font-size: 15px;
  letter-spacing: -0.005em;
  transition: transform .3s var(--ease), background .3s var(--ease);
  cursor: pointer;
}
.nav__cta:hover { transform: translateY(-1px); background: var(--dark-glacier); }

/* ────────────────────────────────────────────────────────────────
   BUTTONS
──────────────────────────────────────────────────────────────── */
.btn {
  display: inline-block;
  padding: 18px 30px;
  border-radius: var(--r-pill);
  font-family: var(--display);
  font-weight: 600;
  font-size: 16px;
  letter-spacing: -0.005em;
  transition: transform .3s var(--ease), background .3s var(--ease), color .3s var(--ease), border-color .3s var(--ease);
  cursor: pointer;
  border: 1px solid transparent;
  text-align: center;
}
.btn--primary { background: var(--glacier); color: var(--cream); }
.btn--primary:hover { background: var(--dark-glacier); transform: translateY(-2px); }
.btn--ghost { background: transparent; color: var(--glacier); border-color: var(--hairline); }
.btn--ghost:hover { background: var(--glacier); color: var(--cream); border-color: var(--glacier); }
.btn--large { padding: 22px 40px; font-size: 17px; }
.btn .arrow { display: inline-block; transition: transform .3s var(--ease); margin-left: 6px; }
.btn:hover .arrow { transform: translateX(3px); }

/* ────────────────────────────────────────────────────────────────
   HERO
──────────────────────────────────────────────────────────────── */
.hero { padding: 96px 0 48px; }
.hero__eyebrow { margin-bottom: 32px; }
.hero h1 {
  font-size: clamp(42px, 6.8vw, 80px);
  letter-spacing: -0.035em;
  line-height: 1.04;
  margin-bottom: 28px;
  max-width: 20ch;
}
.hero__lead {
  max-width: 56ch;
  font-size: clamp(17px, 1.4vw, 20px);
  color: var(--glacier-muted);
  line-height: 1.55;
  margin-bottom: 40px;
}
.hero__ctas {
  display: flex;
  gap: 14px;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 56px;
}

/* PROOF BAR — G2 / Clutch / Clutch 100 (Sagan standard) */
.proof {
  display: inline-flex;
  align-items: center;
  gap: 28px;
  padding: 14px 24px;
  background: var(--white);
  border: 1px solid var(--hairline);
  border-radius: var(--r-pill);
  animation: proof-rise .9s var(--ease) .15s both;
  max-width: 100%;
  flex-wrap: wrap;
}
@keyframes proof-rise {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
.proof__item {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  white-space: nowrap;
}
.proof__stars {
  color: var(--dandelion);
  font-size: 14px;
  letter-spacing: 1px;
  line-height: 1;
}
.proof__num {
  font-family: var(--mono);
  font-size: 20px;
  font-weight: 500;
  color: var(--glacier);
  letter-spacing: -0.02em;
  font-feature-settings: "tnum";
}
.proof__mark {
  display: inline-flex;
  align-items: center;
  color: var(--glacier);
  line-height: 1;
}
.proof__mark--g2 svg { width: 22px; height: 22px; display: block; fill: currentColor; }
.proof__mark--clutch {
  font-family: var(--display);
  font-weight: 800;
  font-size: 16px;
  letter-spacing: -0.04em;
  padding-top: 1px;
}
.proof__badge {
  color: var(--dandelion);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.proof__ranking {
  display: inline-flex;
  align-items: baseline;
  gap: 5px;
  font-family: var(--body);
  font-size: 13px;
  color: var(--glacier-muted);
  letter-spacing: -0.005em;
}
.proof__ranking .proof__mark--clutch { font-size: 15px; align-self: center; padding-top: 0; }
.proof__ranking-num {
  font-family: var(--display);
  font-weight: 800;
  font-size: 14px;
  color: var(--glacier);
  letter-spacing: -0.02em;
}
.proof__divider {
  width: 1px;
  height: 28px;
  background: var(--hairline-strong);
}

/* CAMPAIGN STRIP — countdown / trigger / refund (minimal, below proof bar) */
.campaign-strip {
  display: flex;
  align-items: center;
  gap: 18px;
  margin-top: 20px;
  font-family: var(--mono);
  font-size: 13px;
  color: var(--glacier-muted);
  letter-spacing: 0;
  flex-wrap: wrap;
}
.campaign-strip .dot {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--hairline-strong);
  display: inline-block;
}
.campaign-strip .label {
  text-transform: uppercase;
  letter-spacing: 0.15em;
  font-size: 10px;
  font-weight: 500;
  font-family: var(--body);
  color: var(--glacier-muted);
  margin-right: 6px;
}
.campaign-strip .val { color: var(--glacier); }
.campaign-strip__link {
  text-decoration: none;
  color: inherit;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border-bottom: 1px solid var(--hairline-strong);
  padding-bottom: 2px;
  transition: border-color 280ms cubic-bezier(0.5, 0, 0, 1), color 280ms cubic-bezier(0.5, 0, 0, 1);
  cursor: pointer;
}
.campaign-strip__link:hover { border-color: var(--dandelion); }
.campaign-strip__link:hover .val { color: var(--dandelion); }
.campaign-strip__arrow {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--glacier-muted);
  margin-left: 2px;
  transition: transform 280ms cubic-bezier(0.5, 0, 0, 1), color 280ms cubic-bezier(0.5, 0, 0, 1);
  display: inline-block;
}
.campaign-strip__link:hover .campaign-strip__arrow {
  color: var(--dandelion);
  transform: translate(2px, -2px);
}

/* ────────────────────────────────────────────────────────────────
   NARRATIVE BLOCKS
──────────────────────────────────────────────────────────────── */
.narrative { padding: 96px 0; }
.narrative:has(.big-quote) { padding-bottom: 32px; }
.narrative:has(.big-quote) + .narrative { padding-top: 32px; }
.narrative__inner { max-width: 720px; }
.narrative .eyebrow { margin-bottom: 28px; }
.narrative h2 {
  font-size: clamp(30px, 4.5vw, 48px);
  letter-spacing: -0.03em;
  line-height: 1.08;
  margin-bottom: 36px;
}
.narrative p {
  font-size: clamp(17px, 1.3vw, 19px);
  line-height: 1.6;
  margin-bottom: 20px;
  color: var(--glacier);
}
.narrative p strong { color: var(--glacier); font-weight: 600; }
.narrative p.muted { color: var(--glacier-muted); }

.big-quote {
  font-family: var(--display);
  font-weight: 600;
  font-size: clamp(28px, 3.5vw, 40px);
  letter-spacing: -0.028em;
  line-height: 1.1;
  color: var(--glacier);
  margin-top: 40px;
  padding-top: 40px;
  border-top: 1px solid var(--hairline-soft);
  max-width: 20ch;
}

/* ────────────────────────────────────────────────────────────────
   PROMISE SECTION
──────────────────────────────────────────────────────────────── */
.promise { padding: 96px 0; background: var(--cream-deep); }
.promise__inner { max-width: 900px; }
.promise .eyebrow { margin-bottom: 28px; }
.promise h2 {
  font-size: clamp(30px, 4.5vw, 48px);
  letter-spacing: -0.03em;
  line-height: 1.08;
  margin-bottom: 40px;
  max-width: 28ch;
}
.parenthetical {
  color: var(--glacier-muted);
  font-weight: 400;
  letter-spacing: -0.01em;
}

/* ────────────────────────────────────────────────────────────────
   MACK PHOTO
──────────────────────────────────────────────────────────────── */
.mack-photo {
  margin-top: 48px;
  border-radius: var(--r-card);
  overflow: hidden;
  box-shadow: 0 24px 60px rgba(9, 58, 62, 0.14);
  background: var(--glacier);
  position: relative;
}
.mack-photo img {
  width: 100%;
  height: auto;
  display: block;
}
.mack-photo__caption {
  margin-top: 16px;
  font-family: var(--body);
  font-size: 13px;
  color: var(--glacier-muted);
  letter-spacing: 0.01em;
  line-height: 1.5;
  max-width: 60ch;
}
.mack-photo__caption strong {
  color: var(--glacier);
  font-weight: 500;
  font-family: var(--mono);
  margin-right: 6px;
}

.terms-card {
  background: var(--white);
  border: 1px solid var(--hairline-soft);
  border-radius: var(--r-card);
  padding: 40px 44px;
  margin-bottom: 48px;
}
.terms { }
.terms li {
  padding: 22px 0;
  border-bottom: 1px solid var(--hairline-soft);
  display: flex;
  gap: 20px;
  align-items: baseline;
  font-size: clamp(16px, 1.2vw, 18px);
  line-height: 1.5;
  color: var(--glacier);
}
.terms li:first-child { padding-top: 0; }
.terms li:last-child { padding-bottom: 0; border-bottom: none; }
.terms__dot {
  color: var(--dandelion);
  font-weight: 700;
  flex-shrink: 0;
  font-family: var(--mono);
}
.terms li strong { color: var(--glacier); font-weight: 600; }
.terms li span:last-child { color: var(--glacier); }

.claim-cta {
  text-align: center;
  max-width: 640px;
  margin: 0 auto;
}
.claim-cta h3 {
  font-size: clamp(22px, 2.2vw, 28px);
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: 16px;
}
.claim-cta p {
  font-size: 17px;
  line-height: 1.55;
  color: var(--glacier-muted);
  margin-bottom: 28px;
}
.claim-cta p strong { color: var(--glacier); font-weight: 600; }

/* ────────────────────────────────────────────────────────────────
   MODAL + CLAIM FORM
──────────────────────────────────────────────────────────────── */
.modal {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.modal[aria-hidden="false"] { display: flex; }
.modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(9, 58, 62, 0.55);
  -webkit-backdrop-filter: blur(10px);
  backdrop-filter: blur(10px);
  animation: modalFade 280ms var(--ease);
}
.modal__card {
  position: relative;
  background: var(--white);
  border-radius: var(--r-card);
  max-width: 560px;
  width: 100%;
  max-height: 92vh;
  overflow-y: auto;
  padding: 44px 36px;
  box-shadow: 0 40px 80px rgba(9, 58, 62, 0.22);
  animation: modalSlide 360ms var(--ease);
}
.modal__close {
  position: absolute;
  top: 14px;
  right: 16px;
  background: transparent;
  border: none;
  width: 36px;
  height: 36px;
  font-size: 26px;
  line-height: 1;
  color: var(--glacier-muted);
  cursor: pointer;
  border-radius: 8px;
  transition: color 220ms var(--ease), background 220ms var(--ease);
}
.modal__close:hover { color: var(--glacier); background: var(--cream); }
.modal__header { margin-bottom: 28px; }
.modal__header .eyebrow { margin-bottom: 12px; }
.modal__header h3 {
  font-family: var(--display);
  font-size: clamp(22px, 2.4vw, 28px);
  font-weight: 600;
  color: var(--glacier);
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: 10px;
}
.modal__header p {
  font-size: 15px;
  color: var(--glacier-muted);
  line-height: 1.55;
}

.claim-form .field { margin-bottom: 18px; }
.claim-form label,
.claim-form .field__legend {
  display: block;
  font-family: var(--body);
  font-size: 11px;
  font-weight: 500;
  color: var(--glacier);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.claim-form .hint {
  font-weight: 400;
  color: var(--glacier-muted);
  text-transform: none;
  letter-spacing: 0;
  font-size: 11px;
  margin-left: 6px;
}
.claim-form input[type="text"],
.claim-form input[type="email"],
.claim-form textarea {
  width: 100%;
  font-family: var(--body);
  font-size: 15px;
  padding: 13px 16px;
  border: 1px solid var(--hairline-strong);
  border-radius: 12px;
  background: var(--cream);
  color: var(--glacier);
  transition: border-color 220ms var(--ease), background 220ms var(--ease);
}
.claim-form input:focus,
.claim-form textarea:focus {
  outline: none;
  border-color: var(--glacier);
  background: var(--white);
}
.claim-form textarea { resize: vertical; min-height: 72px; font-family: var(--body); }
.claim-form input[type="file"] {
  font-family: var(--body);
  font-size: 14px;
  width: 100%;
  padding: 12px;
  border: 1px dashed var(--hairline-strong);
  border-radius: 12px;
  background: var(--cream);
  color: var(--glacier-muted);
  cursor: pointer;
}
.claim-form input[type="file"]::file-selector-button {
  font-family: var(--display);
  font-size: 13px;
  font-weight: 600;
  padding: 8px 14px;
  border-radius: 999px;
  border: none;
  background: var(--glacier);
  color: var(--cream);
  margin-right: 12px;
  cursor: pointer;
}
.claim-form .radio-group {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.claim-form .radio {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  border: 1px solid var(--hairline-strong);
  border-radius: 999px;
  font-family: var(--body);
  font-size: 14px;
  color: var(--glacier);
  cursor: pointer;
  transition: border-color 220ms var(--ease), background 220ms var(--ease);
}
.claim-form .radio input { accent-color: var(--glacier); }
.claim-form .radio:has(input:checked) {
  border-color: var(--glacier);
  background: var(--cream);
}
.form__status {
  font-family: var(--body);
  font-size: 13px;
  line-height: 1.5;
  margin: 0 0 14px;
  min-height: 0;
  color: var(--glacier-muted);
}
.form__status.error { color: #B33A2A; }
.form__status.success { color: #0A6B47; }
#submit-btn { width: 100%; }
#submit-btn[disabled] { opacity: 0.6; cursor: wait; }
.modal__success {
  text-align: center;
  padding: 20px 0;
}
.modal__success h4 {
  font-family: var(--display);
  font-size: 24px;
  color: var(--glacier);
  margin-bottom: 12px;
  letter-spacing: -0.02em;
}
.modal__success p {
  font-size: 15px;
  color: var(--glacier-muted);
  line-height: 1.55;
}

@keyframes modalFade { from { opacity: 0; } to { opacity: 1; } }
@keyframes modalSlide {
  from { opacity: 0; transform: translateY(16px) scale(0.98); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

@media (max-width: 520px) {
  .modal__card { padding: 32px 22px; border-radius: 18px; }
}

.rules {
  display: flex;
  flex-direction: column;
  border-top: 1px solid var(--hairline);
  margin: 0 0 20px;
  padding: 0;
}
.rules__section {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--glacier);
  margin: 28px 0 10px;
  font-weight: 600;
}
.rules__section:first-of-type { margin-top: 4px; }
.rules__row {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 20px;
  padding: 16px 0;
  border-bottom: 1px solid var(--hairline);
  margin: 0;
}
.rules__label {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--glacier-muted);
  padding-top: 2px;
  margin: 0;
}
.rules__body {
  font-size: 14.5px;
  line-height: 1.6;
  color: var(--glacier);
  margin: 0;
}
.rules__body strong { font-weight: 600; }
.rules__body em { font-style: italic; color: var(--glacier-muted); }
.rules__cta { width: 100%; justify-content: center; }
#rules-modal .modal__header h3 { outline: none; }

@media (max-width: 520px) {
  .rules__row { grid-template-columns: 1fr; gap: 6px; }
  .rules__label { font-size: 10px; }
}

/* ────────────────────────────────────────────────────────────────
   FINAL CTA BAND
──────────────────────────────────────────────────────────────── */
.final {
  padding: 140px 0;
  text-align: center;
}
.final .eyebrow { display: block; margin-bottom: 32px; color: var(--glacier-muted); }
.final h2 {
  font-size: clamp(36px, 5.5vw, 60px);
  letter-spacing: -0.035em;
  line-height: 1.06;
  margin: 0 auto 32px;
