      { keys: ['sdr', 'sales development', 'business development rep', 'bdr', 'lead qualifier', 'lead qualification'], color: 'red', us: 5500, sag: 200, sol: 'Inbound Qualifier Agent', why: 'Screens every new lead in under 60 seconds. Routes the hot ones to closers. Kills junk before it touches your pipeline.' },
