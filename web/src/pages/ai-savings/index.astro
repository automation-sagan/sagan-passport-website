          <div class="role-savings-sub">${item.count > 1 ? `${fmtMoney(item.saveSum / item.count)} × ${item.count}` : 'per month'}</div>`;
      })();

      const mathLine = showMath
        ? `<div class="role-math">
             <span class="was">${fmtMoney(item.usSum)}</span>
             <span class="arrow">→</span>
             <strong>${fmtMoney(item.sagSum)}</strong>
