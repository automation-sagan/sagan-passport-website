    const HUBSPOT_PORTAL_ID = '50517161';
    const HUBSPOT_FORM_ID = 'daac2804-e5c3-48e7-8ab7-a5b41c9e7c38';
    const MAKE_WEBHOOK_URL = 'https://hook.us2.make.com/2ccpsjqsst3arigocljg0trvlx7reu1n';

    // UTM attribution: capture from URL on page load, persist first-touch for 30 days
    // (matches HubSpot's default attribution window), pass to HubSpot on submit.
    const UTM_KEYS = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
    const UTM_STORAGE_KEY = 'sagan_utms_v1';
    const UTM_TTL_MS = 30 * 24 * 60 * 60 * 1000;

    (function captureUtmsFromUrl() {
      try {
        const qs = new URLSearchParams(window.location.search);
        const found = {};
        let hasAny = false;
        UTM_KEYS.forEach(k => {
          const v = qs.get(k);
          if (v) { found[k] = v; hasAny = true; }
        });
        if (!hasAny) return;

        // First-touch wins: don't overwrite existing UTMs within the TTL window.
        const raw = localStorage.getItem(UTM_STORAGE_KEY);
        if (raw) {
          try {
            const prev = JSON.parse(raw);
            if (prev && prev.ts && (Date.now() - prev.ts) < UTM_TTL_MS) return;
          } catch (_) {}
        }
        localStorage.setItem(UTM_STORAGE_KEY, JSON.stringify({ ts: Date.now(), utms: found }));
      } catch (err) {
        console.warn('UTM capture failed:', err);
      }
    })();

    function readStoredUtms() {
      try {
        const raw = localStorage.getItem(UTM_STORAGE_KEY);
        if (!raw) return {};
        const parsed = JSON.parse(raw);
        if (!parsed || !parsed.ts || (Date.now() - parsed.ts) >= UTM_TTL_MS) return {};
        return parsed.utms || {};
      } catch { return {}; }
    }

    function readCookie(name) {
      const m = document.cookie.match(new RegExp('(?:^|; )' + name.replace(/([.$?*|{}()\[\]\\\/\+^])/g, '\\$1') + '=([^;]*)'));
      return m ? decodeURIComponent(m[1]) : '';
    }

    async function syncToHubspot({ firstName, email, company }) {
