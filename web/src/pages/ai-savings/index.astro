      { keys: ['bookkeeper'], color: 'yellow', us: 5500, sag: 1500, sol: 'Global Bookkeeper + reconciliation agent', why: 'Global hire ($1,400) plus a reconciliation agent ($100). The bookkeeper owns the close. The agent eats the categorization grind.' },
      { keys: ['accountant', 'staff accountant', 'senior accountant'], color: 'yellow', us: 7500, sag: 2000, sol: 'Global Accountant + agent', why: 'Global hire ($1,800) plus an agent ($200). Reconciliation and data entry to the agent. Advisory, tax strategy, and judgment to the human.' },
      { keys: ['customer service rep', 'customer support', 'csr', 'customer service representative', 'customer support specialist'], color: 'yellow', us: 4800, sag: 1450, sol: 'Global CSR + deflection agent', why: 'Global hire ($1,300) plus a deflection agent ($150). AI kills Tier 1 tickets. The human takes the escalations and the pissed-off calls.' },
      { keys: ['virtual assistant', 'executive assistant', 'personal assistant', 'admin assistant', 'administrative assistant'], color: 'yellow', us: 5800, sag: 1650, sol: 'Global EA + agent', why: 'Global hire ($1,500) plus an agent ($150). The agent owns scheduling, research, drafts. The EA owns relationships, judgment, and your calendar war.' },
      { keys: ['recruiter', 'talent acquisition', 'talent partner'], color: 'yellow', us: 6500, sag: 1900, sol: 'Global Recruiter + sourcing agent', why: 'Global hire ($1,700) plus a sourcing agent ($200). Sourcing and screening to the agent. Final interviews and the close stay human.' },
      { keys: ['marketing coordinator', 'marketing assistant', 'marketing specialist', 'marketing manager'], color: 'yellow', us: 5500, sag: 1550, sol: 'Global Marketing + agent', why: 'Global hire ($1,400) plus an agent ($150). Execution and ops to the agent. Strategy and creative direction stay human.' },
      { keys: ['copywriter', 'content writer', 'content creator', 'writer'], color: 'yellow', us: 5500, sag: 1650, sol: 'Global Writer + AI', why: 'Global hire ($1,500) plus an agent ($150). Drafts and research to the agent. Voice, taste, and editing stay human.' },
      { keys: ['social media manager'], color: 'yellow', us: 5500, sag: 1550, sol: 'Global Social Manager + AI', why: 'Global hire ($1,400) plus an agent ($150). Production and scheduling to the agent. Community and strategy stay human.' },
      { keys: ['project coordinator', 'operations coordinator', 'project manager'], color: 'yellow', us: 6000, sag: 1750, sol: 'Global PM + agent', why: 'Global hire ($1,600) plus an agent ($150). Status reports and doc prep to the agent. Stakeholder management stays human.' },
      { keys: ['inside sales', 'sales rep', 'sales representative', 'sales associate'], color: 'yellow', us: 5800, sag: 1700, sol: 'Global Inside Sales + AI', why: 'Global hire ($1,500) plus an agent ($200). Research and first-touch to the agent. Discovery and close stay human.' },
      { keys: ['hr coordinator', 'hr assistant', 'hr specialist', 'people ops'], color: 'yellow', us: 5200, sag: 1550, sol: 'Global HR + agent', why: 'Global hire ($1,400) plus an agent ($150). Policy lookup, forms, onboarding to the agent. People judgment stays human.' },
      { keys: ['graphic designer', 'designer'], color: 'yellow', us: 5200, sag: 1500, sol: 'Global Designer + AI', why: 'Global hire ($1,400) plus an agent ($100). Drafts and variants to the agent. Taste and direction stay human.' },
      { keys: ['paralegal', 'legal assistant'], color: 'yellow', us: 6500, sag: 1900, sol: 'Global Paralegal + agent', why: 'Global hire ($1,700) plus an agent ($200). Drafts, research, summarization to the agent. Filings and judgment stay human.' },

      // ─── GREEN: Global Talent (direct hire, no agent) ──────
      { keys: ['account executive', 'outside sales', 'closer', 'enterprise ae', 'ae'], color: 'green', us: 9000, sag: 2800, sol: 'Global Account Executive', why: 'Relationship-driven closing. The LAST thing to automate. Global AEs exist and they close. Pay them well.' },
      { keys: ['account manager', 'customer success manager', 'csm'], color: 'green', us: 7500, sag: 2200, sol: 'Global Account Manager', why: 'Relationship plus expansion judgment. Global hire handles it. AI supports. Never replaces.' },
      { keys: ['general manager', 'gm', 'operations manager', 'service manager', 'branch manager', 'site manager'], color: 'green', us: 10000, sag: 3500, sol: 'Global GM / Ops lead', why: 'Leadership and people work. J Blanton Plumbing hit $5M→$30M with dozens of global senior operators. Not a typo.' },
      { keys: ['foreman', 'supervisor', 'shift lead', 'team lead'], color: 'green', physical: true, us: 6500, sag: 6500, sol: 'Stay local', why: 'Frontline supervision of field teams. Keep them on-site and promoted.' },
      { keys: ['director', 'vp', 'vice president', 'coo', 'cfo', 'cto', 'cmo'], color: 'green', us: 15000, sag: 5500, sol: 'Global senior leadership', why: 'Strategic judgment. Global senior execs absolutely exist. We place them.' },
      { keys: ['ceo', 'president', 'owner', 'founder'], color: 'green', self: true, us: 0, sag: 0, sol: 'You', why: 'This is you. Keep doing you. Everything below you has leverage hiding in it.' },

      // ─── GREEN physical: keep local ─────────────────────────
      // NOTE: keep keys as SPECIFIC COMPOUNDS only. Bare words like "technician",
      // "apprentice", "supervisor" over-match non-physical roles (IT Technician,
      // Marketing Supervisor, etc.). Sonnet re-classifies with business context.
      { keys: ['field technician', 'service technician', 'installation technician', 'production technician', 'repair technician', 'maintenance technician', 'installer', 'installation specialist', 'field tech', 'service tech', 'repair tech', 'field crew', 'crew member', 'laborer'], color: 'green', physical: true, us: 6500, sag: 6500, sol: 'Stay local', why: 'Physical on-site work. Agents optimize dispatch around them. The tech stays human and local.' },
      { keys: ['plumber', 'electrician', 'hvac technician', 'hvac tech', 'hvac installer', 'mechanic', 'carpenter', 'welder', 'roofer', 'painter', 'equipment operator', 'forklift operator', 'crane operator'], color: 'green', physical: true, us: 7500, sag: 7500, sol: 'Stay local', why: 'Trade skill plus on-site judgment. Untouchable. Protect them. Promote them.' },
      { keys: ['registered nurse', 'rn', 'physician', 'doctor', 'dentist', 'therapist', 'dental hygienist'], color: 'green', physical: true, us: 9000, sag: 9000, sol: 'Stay local', why: 'Clinical judgment plus licensure. Local, forever.' },
      { keys: ['inspector', 'safety officer', 'compliance officer', 'site inspector'], color: 'green', physical: true, us: 7000, sag: 7000, sol: 'Stay local', why: 'Compliance plus on-site judgment. Keep local.' },
      { keys: ['senior engineer', 'staff engineer', 'principal engineer'], color: 'green', us: 14000, sag: 5000, sol: 'Global Senior Engineer', why: 'Architecture and system judgment. Elite global engineers exist. Pair with AI. Never replace.' },
      { keys: ['chef', 'cook', 'line cook', 'sous chef', 'prep cook', 'driver', 'delivery driver', 'route driver', 'courier', 'warehouse worker', 'warehouse associate', 'stocker'], color: 'green', physical: true, us: 4500, sag: 4500, sol: 'Stay local', why: 'Physical work. Humans. Local. Forever.' }
    ];

    // Unmatched roles that still scream "physical trade" → tag local so we don't
    // overpromise savings. Strict indicators only — bare "tech" / "field" are
    // intentionally out because they hit software/sales roles.
    const PHYSICAL_HINT = /\b(installer|installation|journey(?:man|person)|laborer|mechanic|roof|plumb|electric|hvac|weld|carpent|glazier|mason|concrete|landscap|delivery|courier|on-?site|shop floor|warehouse|fabricator|rigger)\b/i;

    // ============================================================
    // STATE
    // ============================================================
    const state = {
      description: '',
      headcount: 0,
      roster: [],       // [{role: 'Dispatcher', count: 2}, ...]
      results: [],      // classified output
      unlocked: false,
    };

    // ============================================================
    // PARSING & CLASSIFICATION
    // ============================================================
    function parseInput(text) {
      return (text || '')
        .split(/\r?\n/)
        .map(s => s.trim())
        .filter(s => s.length > 1 && s.length < 120)
        .slice(0, 200); // hard cap
    }

    function rosterToRoleList(roster) {
      // Expand [{role, count}] into a flat list for the classifier
      const out = [];
      for (const r of roster) {
        const n = Math.max(0, Math.min(50, r.count || 0));
        for (let i = 0; i < n; i++) out.push(r.role);
      }
      return out;
    }

    function classify(roleText) {
      const lower = roleText.toLowerCase();
      // Score each entry by longest keyword match — most specific wins
      let best = null;
      let bestLen = 0;
      for (const entry of CLASSIFIER) {
        for (const k of entry.keys) {
          if (lower.includes(k) && k.length > bestLen) {
            best = entry;
            bestLen = k.length;
          }
        }
      }
      if (!best) {
        // Catch physical trade roles that don't hit a specific keyword
        if (PHYSICAL_HINT.test(lower)) {
          return {
            color: 'green',
            physical: true,
            us: 6000,
            sag: 6000,
            sol: 'Stay local',
            why: 'Physical / on-site work. Local only. Protect and promote your best people here.',
            uncategorized: true,
          };
        }
        return {
          color: 'yellow',
          us: 5500,
          sag: 1700,
          sol: 'Global Talent + AI (custom)',
          why: "Doesn't match. We'd audit it against our live hiring data and propose a global hire plus agent blend.",
          uncategorized: true,
        };
      }
      const entry = { ...best };
      entry.save = Math.max(0, (entry.us || 0) - (entry.sag || 0));
      return entry;
    }

    function summarize(items) {
      const totals = items.reduce((acc, c) => {
        acc.us += (c.us || 0);
        acc.sag += (c.sag || 0);
        return acc;
      }, { us: 0, sag: 0 });
      return {
        total: items.length,
        red: items.filter(c => c.color === 'red').length,
        yellow: items.filter(c => c.color === 'yellow').length,
        green: items.filter(c => c.color === 'green').length,
        greenGlobal: items.filter(c => c.color === 'green' && !c.physical && !c.self).length,
        greenLocal: items.filter(c => c.color === 'green' && (c.physical || c.self)).length,
        usTotal: totals.us,
        sagTotal: totals.sag,
        save: Math.max(0, totals.us - totals.sag),
      };
    }

    function analyze(roles) {
      const classified = roles.map(r => ({
        label: r,
        ...classify(r),
      }));
      return { items: classified, summary: summarize(classified) };
    }

    // ============================================================
    // CSV PARSING
    // ============================================================
    function parseCSV(text) {
      const lines = text.split(/\r?\n/).filter(l => l.trim());
      if (!lines.length) return [];
      // Very basic CSV — handles quoted cells, commas inside quotes
      const parseLine = (line) => {
        const out = []; let cur = ''; let q = false;
        for (let i = 0; i < line.length; i++) {
          const c = line[i];
          if (c === '"') { q = !q; continue; }
          if (c === ',' && !q) { out.push(cur); cur = ''; continue; }
          cur += c;
        }
        out.push(cur);
        return out.map(s => s.trim());
      };
      const header = parseLine(lines[0]).map(h => h.toLowerCase());
      const titleKeys = ['title', 'job title', 'position', 'role', 'job_title', 'jobtitle'];
      let titleIdx = header.findIndex(h => titleKeys.includes(h));
      if (titleIdx === -1) titleIdx = 0; // fall back to first col
      return lines.slice(1).map(parseLine).map(row => row[titleIdx]).filter(Boolean);
    }

    // ============================================================
    // DOM
    // ============================================================
    const $ = (s) => document.querySelector(s);
    const $$ = (s) => [...document.querySelectorAll(s)];

    const stageDescribe = $('#stageDescribe');
    const stageEdit = $('#stageEdit');
    const generatingEl = $('#generating');
    const loadingEl = $('#loading');
    const loadingCount = $('#loadingCount');
    const resultsEl = $('#results');

    function setStage(name) {
      const panels = {
        describe: stageDescribe,
        edit: stageEdit,
        generating: generatingEl,
        scanning: loadingEl,
        results: null, // results always visible after scan
      };
      stageDescribe.classList.toggle('hidden', name !== 'describe');
      stageEdit.classList.toggle('hidden', name !== 'edit');
      generatingEl.classList.toggle('hidden', name !== 'generating');
      if (name === 'scanning') loadingEl.classList.add('active'); else loadingEl.classList.remove('active');
    }

    function scrollToEl(el, offset = 80) {
      const y = el.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top: y, behavior: 'smooth' });
    }

    // ============================================================
    // ADVANCED (paste) TOGGLE
    // ============================================================
    const advToggle = $('#advToggle');
    const advPanel = $('#advPanel');
    const rolesText = $('#rolesText');
    const advScanBtn = $('#advScanBtn');

    advToggle.addEventListener('click', () => {
      const isOpen = !advPanel.classList.contains('hidden');
      advPanel.classList.toggle('hidden', isOpen);
      advToggle.textContent = isOpen ? 'Already have a roster to paste? →' : 'Hide paste option ↑';
    });
    rolesText.addEventListener('input', () => {
      const parsed = parseInput(rolesText.value);
      advScanBtn.disabled = parsed.length === 0;
      advScanBtn.textContent = parsed.length === 0
        ? 'Scan pasted roster →'
        : `Scan ${parsed.length} role${parsed.length===1?'':'s'} →`;
    });
    advScanBtn.addEventListener('click', () => {
      const parsed = parseInput(rolesText.value);
      if (!parsed.length) return;
      // Collapse into roster format
      const counts = {};
      parsed.forEach(r => counts[r] = (counts[r] || 0) + 1);
      state.roster = Object.entries(counts).map(([role, count]) => ({ role, count }));
      state.headcount = parsed.length;
      state.description = 'pasted roster';
      renderRoster();
      $('#editTitle').textContent = `Here's your pasted roster.`;
      setStage('edit');
      scrollToEl(stageEdit, 90);
    });

    // ============================================================
    // STAGE A → B : DESCRIBE → GENERATE
    // ============================================================
    const describeForm = $('#describeForm');
    const bizDesc = $('#bizDesc');
    const bizHead = $('#bizHead');
    const describeError = $('#describeError');
    const generateBtn = $('#generateBtn');
    const generateBtnText = $('#generateBtnText');

    describeForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      describeError.classList.remove('active');
      const desc = bizDesc.value.trim();
      const head = parseInt(bizHead.value, 10);
      if (desc.length < 4 || !head || head < 1 || head > 500) {
        describeError.textContent = desc.length < 4
          ? 'Tell us a bit more about what your business does.'
          : 'Enter a headcount between 1 and 500.';
        describeError.classList.add('active');
        return;
      }
      state.description = desc;
      state.headcount = head;

      $('#genTitle').innerHTML = `Drafting a typical <em style="font-family:'Newsreader',serif;font-style:italic;font-weight:500;color:var(--sagan);">${escapeHtml(desc.length > 40 ? desc.slice(0, 40) + '…' : desc)}</em> team at ${head} people…`;
      setStage('generating');
      scrollToEl(generatingEl, 90);

      try {
        const roster = await generateRoster(desc, head);
        if (!roster.length) throw new Error('empty roster');
        state.roster = roster;
        renderRoster();
        $('#editTitle').innerHTML = `Here's a plausible ${head}-person team for <em style="font-family:'Newsreader',serif;font-style:italic;font-weight:500;color:var(--sagan);">${escapeHtml(desc.length > 48 ? desc.slice(0, 48) + '…' : desc)}</em>.`;
        setStage('edit');
        scrollToEl(stageEdit, 90);
      } catch (err) {
        console.error('Generation failed', err);
        // Fallback: generic roster scaled to headcount
        state.roster = fallbackRoster(head);
        renderRoster();
        $('#editTitle').innerHTML = `Draft roster (generic fallback).`;
        setStage('edit');
        scrollToEl(stageEdit, 90);
        showToast('Draft service hiccuped — using a generic fallback. Edit as needed.');
      }
    });

    // ============================================================
    // LLM: generate a plausible roster
    // ============================================================
    async function generateRoster(description, headcount) {
      const system = `You are Sagan's Role Intelligence model. Sagan has placed 2,500+ direct global hires for US small businesses and maintains a proprietary index mapping industries and team sizes to typical role breakdowns. When asked, you produce a plausible, specific roster that reflects how real operators in that industry actually staff their business.`;
      const user = `Business description: ${description}
Total headcount: ${headcount}

Return ONLY a valid JSON array of role objects, no prose, no markdown fencing. Structure:
[{"role":"Field Technician","count":6},{"role":"Dispatcher","count":2}, ...]

Rules:
- The sum of counts must equal ${headcount} exactly.
- 6-14 distinct roles. More distinct roles for larger teams.
- Use specific, common job titles ("Dispatcher", "Field Technician", "Account Manager", "Bookkeeper", "Customer Service Rep") — not vague ones like "Team Member" or "Staff".
- Include at least one leadership title (Owner, GM, or Operations Manager) for any team of 5+.
- Match the industry: if trades/home-services, include field roles; if agency, include account/creative roles; if e-comm, include ops/CX/marketing; if franchise, match the brand's typical footprint.
- Prefer roles that are commonly hired (so the red/yellow/green breakdown downstream is useful).`;

      const res = await fetch('/ai-savings/api/generate-team', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'anthropic/claude-haiku-4.5',
          messages: [
            { role: 'system', content: system },
            { role: 'user', content: user },
          ],
          temperature: 0.4,
          max_tokens: 900,
        }),
      });
      if (!res.ok) throw new Error(`LLM ${res.status}`);
      const data = await res.json();
      const raw = data?.choices?.[0]?.message?.content || '';
      // Try to parse — sometimes the model returns {"roles":[...]} instead of raw array
      let parsed;
      try { parsed = JSON.parse(raw); } catch { parsed = null; }
      if (!parsed) {
        const match = raw.match(/\[[\s\S]*\]/);
        if (match) try { parsed = JSON.parse(match[0]); } catch {}
      }
      if (!parsed) throw new Error('unparseable');
      const arr = Array.isArray(parsed) ? parsed : (parsed.roles || parsed.team || parsed.roster || []);
      return arr
        .filter(r => r && typeof r.role === 'string' && r.role.length < 80)
        .map(r => ({ role: r.role.trim(), count: Math.max(1, Math.min(50, parseInt(r.count, 10) || 1)) }))
        .slice(0, 20);
    }

    // ============================================================
    // LLM: Sonnet re-classifies and writes the rationale with business context.
    //
    // For each role it returns: color, physical, us, sag, sol, why.
    // These override the static classifier's best-guess values. Since Sonnet
    // sees the industry, "Production Technician" at Signarama gets tagged
    // physical but the same label at a podcast studio goes yellow.
    //
    // Fails soft — on any error we keep the static classifier's values.
    // ============================================================
    async function enrichDescriptions(classified, description, headcount) {
      if (!classified.length || !description) return;

      // Cost control: only ask Sonnet about roles where business context actually
      // matters. Physical / owner roles are already right from the static
      // classifier — paying to re-rule-on them is wasted tokens. Cap at 20 to
      // bound the prompt size even with abusive rosters.
      const agg = aggregateByLabel(classified)
        .filter(r => !r.physical && !r.self)
        .slice(0, 20);
      if (!agg.length) return;

      const system = `You are Sagan's Role Intelligence analyst. Sagan specializes in Global Talent + AI: direct global hires paired with AI agents, no BPO middleman. Your job: for each role in an SMB roster, decide if an AI agent can do it (red), a global hire plus an agent is the right blend (yellow), a global direct hire handles it (green), or the role must stay local/on-site (green physical). Then write a 15-30 word rationale in Jon Matzner's voice: short fragments, periods not commas, active verbs, no em-dashes, no AI marketing-speak, specific to the business.`;

      const rolesList = agg.map((r, i) => {
        return `${i+1}. "${r.label}" — ${r.count} on team`;
      }).join('\n');

      const user = `Business: ${description}
Team size: ${headcount}

For each role below, return EXACTLY these fields in a JSON array.

FIELD RULES (read carefully):
- "label": exact role name (unchanged)
- "color": one of "red", "yellow", "green"
- "physical": boolean. true ONLY if role must be physically on-site in THIS business (trade, field service, clinical, food, warehouse, driving). Default false. Bias toward false when unsure.
- "us": INTEGER monthly fully-loaded US salary IN DOLLARS. Typical ranges:
    junior admin / coordinator: 3500-5000
    specialist / associate: 4500-6500
    experienced individual contributor: 5500-8000
    senior / manager: 7500-11000
    director / VP: 12000-18000
    field tech / trade: 5500-8500
    skilled trade (licensed): 7000-9500
    owner / founder: 0
- "sag": INTEGER monthly Sagan alternative cost IN DOLLARS:
    red (AI agent does 80%+ of the work): 50 to 400
    yellow (global direct hire plus an AI agent): 1200 to 2200
    green non-physical (global direct hire, no agent): 1800 to 5500
    green physical (stay local, no savings): EQUAL to us value
    owner / founder: 0
- "sol": SHORT label, 2-5 words max. NOT a description. Examples: "Dispatch Agent", "Global Bookkeeper + agent", "Global Account Manager", "Stay local", "You"
- "why": 15-30 WORDS of Jon-voice rationale (short fragments, periods instead of commas, active verbs, no em-dashes, no AI marketing-speak). Reference the business where it sharpens the line.

CLASSIFICATION GUIDANCE:
- Use business context. A Production Technician at a sign printing franchise is physical (on-site fabrication). The same title at a podcast studio is yellow (remote-hirable).
- Owner / Founder / CEO / President: color "green", physical true, us 0, sag 0, sol "You", why "This is you. Keep doing you. Everything below you has leverage hiding in it."
- Sales / marketing / admin / bookkeeping / recruiting / CSR / design / content / ops coordinator / analyst / inside sales: almost always yellow or red. Bias against physical.
- Field tech, installer, plumber, electrician, HVAC, delivery driver, warehouse, clinical, chef, line cook: physical.

EXAMPLE of valid output format:
{"roles":[
  {"label":"Dispatcher","color":"red","physical":false,"us":4500,"sag":120,"sol":"Dispatch Agent","why":"Runs your dispatch board 24/7. Matches every job to the nearest tech. Never calls in sick."},
  {"label":"Bookkeeper","color":"yellow","physical":false,"us":5500,"sag":1500,"sol":"Global Bookkeeper + agent","why":"Global hire plus a reconciliation agent. Human owns the close. Agent eats the categorization grind."},
  {"label":"Field Technician","color":"green","physical":true,"us":6500,"sag":6500,"sol":"Stay local","why":"Physical on-site work. Can't be moved. Protect and promote your best field talent."}
]}

Roles to classify:
${rolesList}

Return ONLY valid JSON. No prose. No markdown fencing. Dollar fields must be real dollar amounts (thousands), not counts.`;

      try {
        const res = await fetch('/ai-savings/api/generate-team', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            model: 'anthropic/claude-sonnet-4.6',
            messages: [
              { role: 'system', content: system },
              { role: 'user', content: user },
            ],
            temperature: 0.4,
            max_tokens: 900,
          }),
        });
        if (!res.ok) throw new Error(`Sonnet ${res.status}`);
        const data = await res.json();
        const raw = data?.choices?.[0]?.message?.content || '';
        let parsed;
        try { parsed = JSON.parse(raw); } catch {
          const m = raw.match(/\{[\s\S]*\}/);
          if (m) try { parsed = JSON.parse(m[0]); } catch {}
        }
        const roles = parsed?.roles || [];
        if (!roles.length) return;

        // Build label → enriched-entry map
        const labelMap = {};
        for (const r of roles) {
          if (!r || typeof r.label !== 'string') continue;
          const key = r.label.toLowerCase().trim();
          labelMap[key] = r;
        }

        // Apply Sonnet's classification to every matching classified item.
        // Only accept values that look SANE — if Sonnet fumbles a field
        // (e.g. returns us=1 treating it as a count), keep the static default.
        classified.forEach(item => {
          const key = item.label.toLowerCase().trim();
          const r = labelMap[key];
          if (!r) return;

          const isSelfRole = typeof r.sol === 'string' && /^you$/i.test(r.sol.trim());

          if (r.color === 'red' || r.color === 'yellow' || r.color === 'green') item.color = r.color;
          if (typeof r.physical === 'boolean') item.physical = r.physical;

          // Dollar fields MUST be realistic. Reject obviously-wrong values
          // (e.g. us=1 because the model treated it as a count).
          // Owner/founder roles are allowed zeros.
          const usOk = Number.isFinite(r.us) && ((isSelfRole && r.us === 0) || (r.us >= 1500 && r.us <= 60000));
          if (usOk) item.us = Math.round(r.us);

          const sagFloor = isSelfRole ? 0 : 30;
          const sagOk = Number.isFinite(r.sag) && r.sag >= sagFloor && r.sag <= 60000;
          if (sagOk) item.sag = Math.round(r.sag);

          // sol must be SHORT (≤ 40 chars). Sonnet sometimes stuffs a full
          // sentence in here — reject that and keep the static label.
          if (typeof r.sol === 'string' && r.sol.length > 0 && r.sol.length <= 40) {
            item.sol = r.sol.trim();
          }

          if (typeof r.why === 'string' && r.why.length > 10 && r.why.length <= 300) {
            item.why = r.why.trim().replace(/—/g, '.').replace(/\s+\./g, '.');
          }

          // Owner/founder convention: zero out the math so the UI shows "You"
          if (isSelfRole) { item.self = true; item.us = 0; item.sag = 0; }

          item.save = Math.max(0, (item.us || 0) - (item.sag || 0));
        });
      } catch (err) {
        console.warn('Sonnet enrichment failed, using static classification:', err);
      }
    }

