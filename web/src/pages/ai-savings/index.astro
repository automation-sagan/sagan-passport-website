    function verdictCopy(summary) {
      const { total, red, yellow, green, save, usTotal, sagTotal } = summary;

      if (!total) return { head: "We couldn't find any roles.", sub: "Head back and describe your team." };

      const fmtK = (n) => n >= 1000 ? `$${Math.round(n/1000)}K` : `$${n}`;
      const saveK = fmtK(save);
      const pctSaved = usTotal > 0 ? Math.round((save / usTotal) * 100) : 0;

      if (save === 0) {
        return {
          head: `Your team is <em>already built for humans.</em>`,
          sub: `No automation wins in this mix. The leverage move isn't cutting. It's hiring more of these exact humans globally at Sagan rates.`,
        };
      }
      if (red >= 3 || save >= 20000) {
        return {
          head: `<em>~${saveK}/month</em> back in your pocket.`,
          sub: `Same team, same output. ${pctSaved}% lower payroll. ${red} roles an agent does today, ${yellow} that are Global Talent + AI, ${green} where humans are the product. Build it. Watch the number land.`,
        };
      }
      if (save >= 5000) {
        return {
          head: `<em>~${saveK}/month</em> of leverage in your payroll.`,
          sub: `That's ${pctSaved}% of current cost. ${red} agent play${red!==1?'s':''}, ${yellow} Global Talent + AI play${yellow!==1?'s':''}, ${green} human-essential. Tune-up, not tear-down. No one gets cut who shouldn't.`,
        };
      }
      return {
        head: `<em>Solid team. Leverage on the table.</em>`,
        sub: `~${saveK}/month in savings (about ${pctSaved}%). ${yellow+green} roles to hire globally or pair with an agent. No one gets cut.`,
      };
    }

    const prefersReducedMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function countUp(el, target, { duration = 1200, prefix = '', suffix = '', bounce = false } = {}) {
      if (!el) return;
      if (prefersReducedMotion()) {
        el.textContent = prefix + target.toLocaleString('en-US') + suffix;
        return;
      }
      const start = performance.now();
      const from = 0;
      const diff = target - from;
      const step = (now) => {
        const t = Math.min(1, (now - start) / duration);
        // easeOutCubic
        const eased = 1 - Math.pow(1 - t, 3);
        const val = Math.round(from + diff * eased);
        el.textContent = prefix + val.toLocaleString('en-US') + suffix;
        if (t < 1) {
          requestAnimationFrame(step);
        } else if (bounce) {
          const card = el.closest('.stat-card');
          if (card) {
            card.classList.add('punch');
            setTimeout(() => card.classList.remove('punch'), 750);
          }
        }
      };
      requestAnimationFrame(step);
    }

    function renderTeaser(analysis) {
