        fetch(MAKE_WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ submission }),
          keepalive: true,
        }).catch(err => console.warn('Make webhook failed (non-blocking):', err));
      }

      try {
        const fields = [
          { objectTypeId: '0-1', name: 'firstname', value: firstName },
          { objectTypeId: '0-1', name: 'email', value: email },
          { objectTypeId: '0-1', name: 'company', value: company },
        ];
        UTM_KEYS.forEach(k => {
          if (utms[k]) fields.push({ objectTypeId: '0-1', name: k, value: utms[k] });
        });

        const payload = {
          fields,
          context: {
            pageUri: window.location.href,
            pageName: document.title,
          },
        };
        const hutk = readCookie('hubspotutk');
        if (hutk) payload.context.hutk = hutk;

        const res = await fetch(`https://api.hsforms.com/submissions/v3/integration/submit/${HUBSPOT_PORTAL_ID}/${HUBSPOT_FORM_ID}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) {
          const body = await res.text();
          console.error('[HubSpot] ' + res.status, body);
        }
      } catch (err) {
        console.warn('HubSpot sync failed (non-blocking):', err);
      }
    }

    function buildEmailHTML({ firstName, company, summary, items }) {
      const red = aggregateByLabel(items.filter(i => i.color === 'red'));
      const yellow = aggregateByLabel(items.filter(i => i.color === 'yellow'));
      const greenGlobal = aggregateByLabel(items.filter(i => i.color === 'green' && !i.physical && !i.self));
      const greenLocal = aggregateByLabel(items.filter(i => i.color === 'green' && (i.physical || i.self)));

      const pctSaved = summary.usTotal > 0 ? Math.round((summary.save / summary.usTotal) * 100) : 0;

      const row = (i) => {
        const isPhysical = !!i.physical;
        const isSelf = !!i.self;
        const showMath = !isPhysical && !isSelf && i.saveSum > 0;
        const saveText = isSelf ? '— you —' : isPhysical ? 'Keep local' : '$' + i.saveSum.toLocaleString('en-US');
        const saveColor = (isPhysical || isSelf) ? '#64748b' : '#064e3b';
        const chipBg = isPhysical ? '#f5f3ee' : (isSelf ? '#fef3c7' : '#dbeafe');
        const chipInk = isPhysical ? '#334155' : (isSelf ? '#78350f' : '#152d4a');
        return `
          <tr>
            <td style="padding:16px 18px;border-bottom:1px solid #e5e2d9;vertical-align:top;">
              <div style="font-weight:700;color:#0f172a;font-size:15px;margin-bottom:4px;">
                ${escapeHtml(i.label)}${i.count > 1 ? ` <span style="color:#64748b;font-weight:600;font-size:13px;">× ${i.count}</span>` : ''}
              </div>
              <span style="display:inline-block;padding:3px 9px;background:${chipBg};color:${chipInk};border-radius:5px;font-weight:700;font-size:11px;margin-bottom:8px;">${escapeHtml(i.sol || 'Keep')}</span>
              <div style="font-size:13px;color:#475569;line-height:1.55;margin-bottom:${showMath ? '8' : '0'}px;">${escapeHtml(i.why)}</div>
              ${showMath ? `<div style="font-size:12px;color:#64748b;font-variant-numeric:tabular-nums;">
                <span style="text-decoration:line-through;color:#94a3b8;">$${i.usSum.toLocaleString('en-US')}</span>
                <span style="margin:0 6px;color:#94a3b8;">→</span>
                <strong style="color:#0f172a;">$${i.sagSum.toLocaleString('en-US')}</strong>
                <span>/mo${i.count > 1 ? ` across ${i.count}` : ''}</span>
              </div>` : ''}
            </td>
            <td style="padding:16px 18px;border-bottom:1px solid #e5e2d9;text-align:right;vertical-align:top;white-space:nowrap;">
              <div style="font-size:10px;font-weight:700;letter-spacing:0.12em;color:#64748b;text-transform:uppercase;margin-bottom:2px;">${isSelf ? 'You' : isPhysical ? 'Status' : 'Save / mo'}</div>
              <div style="font-size:17px;font-weight:900;color:${saveColor};font-variant-numeric:tabular-nums;letter-spacing:-0.01em;">${saveText}</div>
            </td>
          </tr>`;
      };

      const section = (title, subtitle, bg, ink, list) => !list.length ? '' : `
        <div style="margin-top:24px;">
          <div style="padding:12px 16px;background:${bg};border-radius:10px;margin-bottom:8px;">
            <div style="font-weight:800;color:${ink};font-size:15px;">${title}</div>
            <div style="font-size:13px;color:${ink};opacity:0.75;margin-top:2px;">${subtitle}</div>
          </div>
          <table style="width:100%;border-collapse:collapse;background:#ffffff;border:1px solid #e5e2d9;border-radius:10px;overflow:hidden;">
            ${list.map(row).join('')}
          </table>
        </div>`;

      const saveStr = summary.save >= 1000 ? `~$${Math.round(summary.save/1000)}K/month` : `$${summary.save}/month`;

      return `<!DOCTYPE html>
<html><body style="margin:0;padding:0;background:#fafaf7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Inter,sans-serif;color:#0f172a;">
  <div style="max-width:640px;margin:0 auto;padding:32px 24px;">
    <div style="padding:24px 0 28px;border-bottom:1px solid #e5e2d9;">
      <div style="font-size:12px;font-weight:700;letter-spacing:0.14em;color:#64748b;text-transform:uppercase;margin-bottom:8px;">Sagan · AI Savings Scan</div>
      <h1 style="font-size:24px;font-weight:800;letter-spacing:-0.02em;margin:0;line-height:1.3;">${escapeHtml(firstName)}, ${saveStr} back in your pocket.</h1>
      <div style="font-size:15px;color:#475569;line-height:1.55;margin-top:10px;">Same team at ${escapeHtml(company)}, ${pctSaved}% lower payroll. Global Talent + AI, one playbook. Below is the role-by-role breakdown.</div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr 1.4fr;gap:10px;margin:24px 0;">
      <div style="padding:14px 16px;background:#ffffff;border:1px solid #d9d5c9;border-radius:10px;">
        <div style="font-size:10px;font-weight:700;letter-spacing:0.12em;color:#64748b;text-transform:uppercase;">Currently</div>
        <div style="font-size:20px;font-weight:900;color:#0f172a;margin-top:4px;font-variant-numeric:tabular-nums;">$${summary.usTotal.toLocaleString('en-US')}</div>
        <div style="font-size:11px;color:#94a3b8;margin-top:2px;">US payroll, fully loaded</div>
      </div>
      <div style="padding:14px 16px;background:#dbeafe;border:1px solid #bfdcff;border-radius:10px;">
        <div style="font-size:10px;font-weight:700;letter-spacing:0.12em;color:#152d4a;text-transform:uppercase;">Sagan plan</div>
        <div style="font-size:20px;font-weight:900;color:#152d4a;margin-top:4px;font-variant-numeric:tabular-nums;">$${summary.sagTotal.toLocaleString('en-US')}</div>
        <div style="font-size:11px;color:#1e3a5f;margin-top:2px;">Global Talent + AI</div>
      </div>
      <div style="padding:14px 16px;background:#0f172a;color:#ffffff;border-radius:10px;">
        <div style="font-size:10px;font-weight:700;letter-spacing:0.12em;color:rgba(255,255,255,0.6);text-transform:uppercase;">Monthly savings</div>
        <div style="font-size:24px;font-weight:900;margin-top:4px;font-variant-numeric:tabular-nums;">$${summary.save.toLocaleString('en-US')}</div>
        <div style="font-size:11px;color:rgba(255,255,255,0.7);margin-top:2px;">Back into your P&amp;L, every month</div>
      </div>
    </div>

    ${section('Agent does this', 'AI handles it. Monthly cost is agent runtime only.', '#fef2f2', '#7f1d1d', red)}
    ${section('Global Talent + AI', 'Direct global hire paired with an agent. The Sagan combo.', '#fffbeb', '#78350f', yellow)}
    ${section('Global Talent · direct hire', 'Human-essential, no agent needed. Hire globally, skip the middleman markup.', '#ecfdf5', '#064e3b', greenGlobal)}
    ${section('Stay local', 'Physical or on-site work. Keep local. Protect and promote.', '#f5f3ee', '#334155', greenLocal)}

    <div style="margin-top:36px;padding:28px;background:#0f172a;color:#ffffff;border-radius:12px;">
      <div style="font-size:12px;font-weight:700;letter-spacing:0.14em;color:rgba(255,255,255,0.5);text-transform:uppercase;margin-bottom:12px;">What now?</div>
      <div style="font-size:17px;line-height:1.55;margin-bottom:18px;">We ran this same scan on ourselves six months ago. It's earning us <strong style="color:#94c5ff;">$267,781/month</strong> today. Your number above is what the same playbook gets you. Which agent to build first, which roles to hire globally, who to protect. One call.</div>
      <a href="https://getsagan.com/book" style="display:inline-block;padding:14px 26px;background:#ffffff;color:#0f172a;text-decoration:none;border-radius:8px;font-weight:700;font-size:15px;">Book a 20-min intro with Sagan</a>
    </div>

    <div style="margin-top:32px;padding-top:24px;border-top:1px solid #e5e2d9;font-size:13px;color:#64748b;line-height:1.6;">
      Reply to this email with questions — it goes straight to the team.<br>
      Yallah Habibi,<br>
      <strong style="color:#0f172a;">Jon Matzner</strong> · Sagan
    </div>
  </div>
</body></html>`;
    }

    // Gate form submission
    $('#gateForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const firstName = $('#firstName').value.trim();
      const email = $('#email').value.trim();
      const company = $('#company').value.trim();
      const honeypot = $('#websiteField') ? $('#websiteField').value : '';
      const errEl = $('#emailError');
      errEl.classList.remove('active');

      // Honeypot: invisible field that real users can't see. Bots auto-fill it.
      // Silent success — show the modal so they don't know they tripped it.
      if (honeypot) {
        state.unlocked = true;
        openSuccessModal(email || 'your inbox');
        return;
      }

      // Time-gate: real humans take > 3s to read the teaser and fill 3 fields.
      // Bots hit submit in <100ms. Silent success so bots don't retune.
      const elapsedMs = state.gateShownAt ? Date.now() - state.gateShownAt : 99999;
      if (elapsedMs < 3000) {
        state.unlocked = true;
        openSuccessModal(email || 'your inbox');
        return;
      }

      if (!firstName || !company) return;
      if (!isValidEmail(email)) {
        errEl.textContent = /@(gmail|yahoo|hotmail|outlook|aol|icloud|proton|me)\./i.test(email)
          ? 'Please use your work email. Personal inboxes go to spam.'
          : 'Please enter a valid email.';
        errEl.classList.add('active');
        return;
      }

      const btn = $('#gateSubmit');
      const btnText = $('#gateBtnText');
      btn.disabled = true;
      btnText.textContent = 'Sending…';

      // Silent HubSpot CRM sync, in parallel with Resend. Don't await — if HubSpot
      // is slow or down, the user still gets their scan email on time.
      syncToHubspot({ firstName, email, company });

      const { summary, items } = state.results;

      // Sonnet enrichment happens HERE (post-submit) so scanners who bounce
      // cost nothing. Capped at ~12s — falls back to static copy on timeout.
      try {
        const enrich = enrichDescriptions(items, state.description, state.headcount);
        const timeout = new Promise(r => setTimeout(r, 12000));
        await Promise.race([enrich, timeout]);
        state.results.summary = summarize(items);
      } catch (err) {
        console.warn('Enrichment skipped:', err);
      }

      const updatedSummary = state.results.summary;
      const html = buildEmailHTML({ firstName, company, summary: updatedSummary, items });
      const subject = updatedSummary.save >= 1000
        ? `${firstName}, $${updatedSummary.save.toLocaleString('en-US')}/mo`
        : `${firstName}, your scan from Sagan`;

      const plainLines = [
        `${firstName}, here's your scan for ${company}.`,
        ``,
        `Red (${updatedSummary.red}):   ${items.filter(i=>i.color==='red').map(i=>i.label).join(', ') || 'none'}`,
        `Yellow (${updatedSummary.yellow}): ${items.filter(i=>i.color==='yellow').map(i=>i.label).join(', ') || 'none'}`,
        `Green (${updatedSummary.green}):  ${items.filter(i=>i.color==='green').map(i=>i.label).join(', ') || 'none'}`,
        ``,
        `Est. monthly savings: $${updatedSummary.save.toLocaleString('en-US')}/mo`,
        ``,
        `Book a call: https://getsagan.com/book`,
      ];

      try {
        const res = await fetch('/ai-savings/api/email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            from: 'Jon Matzner <jon@globalandremote.com>',
            to: [email],
            reply_to: 'jon@getsagan.com',
            subject,
            html,
            text: plainLines.join('\n'),
          }),
        });
        if (!res.ok) {
          const body = await res.text();
          console.error('Resend error', res.status, body);
        }
      } catch (err) {
        console.error('Email dispatch failed', err);
      }

      state.unlocked = true;
      openSuccessModal(email);
    });

    // Hero CTA → scanner
    $$('a[href="#scanner"]').forEach(a => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        scrollToEl($('#scanner'));
      });
    });

    // Reveal animations
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => e.isIntersecting && e.target.classList.add('visible'));
    }, { threshold: 0.15 });
    $$('.reveal').forEach(el => io.observe(el));

    // Count-up trigger for $267K proof number when it enters the viewport
    const proofNumberEl = $('#proofNumber');
    if (proofNumberEl) {
      const proofIo = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const target = parseInt(e.target.dataset.target, 10) || 0;
            countUp(e.target, target, { duration: 1800, prefix: '$' });
            proofIo.unobserve(e.target);
          }
        });
      }, { threshold: 0.35 });
      proofIo.observe(proofNumberEl);
    }

    // Init — start on describe stage
    setStage('describe');
  </script>
</LandingLayout>
