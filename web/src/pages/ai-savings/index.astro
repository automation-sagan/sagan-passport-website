      $('#statLocal').textContent = s.greenLocal;
      countUp($('#statUs'), s.usTotal, { duration: 900 });
      countUp($('#statSag'), s.sagTotal, { duration: 1100 });
      countUp($('#statSave'), s.save, { duration: 1800, bounce: true });

      const v = verdictCopy(s);
      $('#verdictHead').innerHTML = v.head;
      $('#verdictSub').textContent = v.sub;
    }

    // Group individual role entries by label so "Dispatcher × 2" renders as one card.
    function aggregateByLabel(items) {
      const map = new Map();
      for (const it of items) {
        const key = it.label.toLowerCase().trim();
        if (!map.has(key)) {
          map.set(key, { ...it, count: 0, usSum: 0, sagSum: 0, saveSum: 0 });
        }
        const g = map.get(key);
        g.count += 1;
        g.usSum += (it.us || 0);
        g.sagSum += (it.sag || 0);
        g.saveSum += (it.save || 0);
      }
      return [...map.values()].sort((a, b) => b.saveSum - a.saveSum);
    }

    const fmtMoney = (n) => '$' + (n || 0).toLocaleString('en-US');

    function renderCard(item, i) {
      const isPhysical = !!item.physical;
