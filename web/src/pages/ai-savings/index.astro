---
// /ai-savings — faithful 1:1 port of the standalone "AI Savings Scan" app
// (Sagan passport Domain/AI savings scan/index.html). Content lives in code,
// not Sanity — this is a tool, not a CMS page. Own route so only this page's
// CSS/scripts bundle. Backends live at /ai-savings/api/{generate-team,email}.
//
// Astro notes:
//   - Every <script> with content/attrs is is:inline (the app is all hand-rolled
//     JS — letting Astro bundle/transform it would break it).
//   - Source <head> font <link> tags are converted to a top @import inside the
//     <style is:global> block; preconnect + favicon go in slot="head".
//   - The app fetches /ai-savings/api/generate-team and /ai-savings/api/email
//     (rewritten from the source's /api/* paths now that it lives under
//     /ai-savings/). All other logic is identical to the source.
import LandingLayout from '../../layouts/LandingLayout.astro';

export const prerender = true;
---

<LandingLayout
  title="AI Savings Scan · AI is earning us $267K/month. What could it save you?"
  description="Describe your team in one sentence. We show you where AI agents can save you money, role by role, with the monthly number. Built on Sagan's 2,500-hire dataset."
  canonical="https://saganpassport.com/ai-savings"
>
  <Fragment slot="head">
    <meta property="og:title" content="AI Savings Scan · How much could AI save your team each month?" />
    <meta property="og:description" content="AI is earning us an extra $267K/month inside Sagan. Describe your team in a sentence and see how much it could be saving yours." />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/ai-savings/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Start of HubSpot Embed Code -->
    <script type="text/javascript" id="hs-script-loader" async defer src="//js.hs-scripts.com/50517161.js" is:inline></script>
    <!-- End of HubSpot Embed Code -->
  </Fragment>

  <style is:global>
@import url('https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800;900&family=Newsreader:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy: #0b1220;
      --navy-2: #111a2e;
      --sagan: #1e3a5f;
      --sagan-deep: #152d4a;
      --sagan-light: #dbeafe;
      --ink: #0f172a;
      --ink-2: #1e293b;
      --ink-3: #334155;
      --ink-4: #475569;
      --ink-5: #64748b;
      --paper: #fafaf7;
      --paper-warm: #f5f3ee;
      --white: #ffffff;
      --line: #e5e2d9;
      --line-2: #d9d5c9;
      --red: #b91c1c;
      --red-ink: #7f1d1d;
      --red-bg: #fef2f2;
      --red-bg-2: #fee2e2;
      --amber: #b45309;
      --amber-ink: #78350f;
      --amber-bg: #fffbeb;
      --amber-bg-2: #fef3c7;
      --green: #047857;
      --green-ink: #064e3b;
      --green-bg: #ecfdf5;
      --green-bg-2: #d1fae5;
      --radius: 12px;
      --radius-lg: 16px;
      --radius-xl: 24px;
      --shadow-sm: 0 1px 2px rgba(11,18,32,0.04);
      --shadow: 0 1px 3px rgba(11,18,32,0.06), 0 1px 2px rgba(11,18,32,0.04);
      --shadow-md: 0 6px 16px rgba(11,18,32,0.06), 0 2px 6px rgba(11,18,32,0.04);
      --shadow-lg: 0 20px 40px rgba(11,18,32,0.08), 0 8px 16px rgba(11,18,32,0.04);
      --shadow-xl: 0 30px 60px rgba(11,18,32,0.12), 0 12px 24px rgba(11,18,32,0.06);
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'Geist', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--ink);
      background: var(--paper);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    .serif { font-family: 'Newsreader', Georgia, serif; }
    .mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }

    button { cursor: pointer; font-family: inherit; }
    button:disabled { cursor: not-allowed; }
    a { color: inherit; }

    .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }
    .container-narrow { max-width: 820px; margin: 0 auto; padding: 0 24px; }

    /* ── ANIMATIONS ── */
    .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-d1 { transition-delay: 0.1s; }
    .reveal-d2 { transition-delay: 0.2s; }
    .reveal-d3 { transition-delay: 0.3s; }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.55; transform: scale(1.15); }
    }
    @keyframes shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Respect users who prefer reduced motion */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
      .reveal { opacity: 1 !important; transform: none !important; }
    }

    /* Keyboard-visible focus rings on interactive elements */
    :focus { outline: none; }
    :focus-visible {
      outline: 2px solid var(--sagan);
      outline-offset: 2px;
      border-radius: 6px;
    }
    button:focus-visible,
    a:focus-visible,
    [role="button"]:focus-visible {
      box-shadow: 0 0 0 3px rgba(30, 58, 95, 0.22);
      outline-offset: 3px;
    }
    input:focus-visible, textarea:focus-visible {
      outline: none;
    }

    /* ── NAV ── */
    nav.top {
      position: sticky; top: 0; z-index: 100;
      background: rgba(250,250,247,0.88);
      backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--line);
    }
    .nav-inner {
      max-width: 1120px; margin: 0 auto; padding: 0 24px;
      display: flex; justify-content: space-between; align-items: center; height: 64px;
    }
    .nav-logo {
      color: var(--ink); font-weight: 800; font-size: 0.98rem;
      text-decoration: none; letter-spacing: -0.02em;
      display: flex; align-items: center; gap: 10px;
    }
    .nav-logo-mark {
      width: 22px; height: 22px; border-radius: 6px;
      background: linear-gradient(135deg, var(--sagan) 0%, var(--sagan-deep) 100%);
      display: grid; place-items: center;
      color: white; font-size: 0.68rem; font-weight: 900; letter-spacing: 0;
    }
    .nav-logo span { color: var(--sagan); }
    .nav-right { display: flex; align-items: center; gap: 18px; }
    .nav-pill {
      font-size: 0.78rem; color: var(--ink-4); font-weight: 600;
      display: flex; align-items: center; gap: 8px;
    }
    .nav-pill-dot {
      width: 7px; height: 7px; border-radius: 50%; background: var(--green);
      animation: pulse-dot 2.4s ease-in-out infinite;
    }
    @media (max-width: 640px) { .nav-pill { display: none; } }

    /* ── HERO ── */
    .hero {
      padding: 88px 24px 72px;
      text-align: center;
      position: relative;
      background:
        radial-gradient(ellipse 80% 60% at 50% 0%, rgba(30,58,95,0.06) 0%, transparent 70%),
        linear-gradient(180deg, var(--paper) 0%, var(--paper-warm) 100%);
      border-bottom: 1px solid var(--line);
      overflow: hidden;
    }
    .hero::before {
      content: ""; position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(11,18,32,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(11,18,32,0.025) 1px, transparent 1px);
      background-size: 48px 48px;
      mask-image: radial-gradient(ellipse 60% 80% at 50% 30%, black 20%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse 60% 80% at 50% 30%, black 20%, transparent 70%);
      pointer-events: none;
    }
    .hero-inner { max-width: 820px; margin: 0 auto; position: relative; }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      padding: 6px 14px;
      background: var(--white); border: 1px solid var(--line-2);
      border-radius: 999px;
      font-size: 0.72rem; font-weight: 700; color: var(--ink-3);
      letter-spacing: 0.08em; text-transform: uppercase;
      margin-bottom: 28px;
      box-shadow: var(--shadow-sm);
    }
    .hero-eyebrow-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--red);
      animation: pulse-dot 2s ease-in-out infinite;
    }
    .hero h1 {
      font-size: clamp(2.2rem, 5.2vw, 3.6rem);
      font-weight: 900; line-height: 1.06;
      letter-spacing: -0.038em; color: var(--ink);
      margin-bottom: 22px;
    }
    .hero h1 em {
      font-family: 'Newsreader', Georgia, serif;
      font-style: italic; font-weight: 500;
      color: var(--sagan);
    }
    .hero h1 .highlight {
      background: linear-gradient(180deg, transparent 62%, rgba(220,38,38,0.2) 62%);
      padding: 0 4px;
    }
    .hero p.lede {
      color: var(--ink-4);
      font-size: clamp(1.02rem, 1.5vw, 1.16rem);
      max-width: 640px; margin: 0 auto 36px;
      line-height: 1.65;
    }
    .hero-cta-row {
      display: flex; justify-content: center; align-items: center; gap: 16px; flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--ink); color: var(--white);
      padding: 15px 30px; border-radius: 10px;
      text-decoration: none; font-weight: 700; font-size: 0.98rem;
      border: none; cursor: pointer;
      transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1),
                  background 0.2s ease,
                  box-shadow 0.28s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.08),
        0 2px 6px rgba(11,18,32,0.2);
      will-change: transform;
    }
    .btn-primary:hover {
      background: var(--navy);
      transform: translateY(-2px);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.08),
        0 10px 24px rgba(11,18,32,0.28);
    }
    .btn-primary:active { transform: translateY(0); }
    .btn-primary:disabled { background: var(--ink-5); cursor: not-allowed; transform: none; box-shadow: none; opacity: 0.65; }
    .btn-ghost {
      display: inline-flex; align-items: center; gap: 8px;
      color: var(--ink-3); text-decoration: none; font-weight: 600;
      font-size: 0.9rem;
    }
    .btn-ghost:hover { color: var(--sagan); }

    .hero-proof {
      display: inline-flex; align-items: center; gap: 18px; flex-wrap: wrap;
      justify-content: center;
      margin-top: 42px;
      padding: 14px 22px;
      background: rgba(255,255,255,0.6);
      border: 1px solid var(--line);
      border-radius: 999px;
      font-size: 0.83rem; color: var(--ink-4);
      box-shadow: var(--shadow-sm);
    }
    .hero-proof strong { color: var(--ink); font-weight: 700; }
    .hero-proof-divider { width: 1px; height: 14px; background: var(--line-2); }
    @media (max-width: 640px) {
      .hero-proof-divider { display: none; }
      .hero-proof { flex-direction: column; gap: 6px; border-radius: 12px; }
    }

    /* ── TRUST STRIP ── */
    .trust-strip {
      padding: 40px 24px 28px;
      background: var(--paper);
      border-bottom: 1px solid var(--line);
    }
    .trust-inner {
      max-width: 1040px; margin: 0 auto;
      display: flex; flex-direction: column; align-items: center; gap: 18px;
    }
    .trust-label {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.16em;
      text-transform: uppercase; color: var(--ink-5);
    }
    .trust-metrics {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 28px; width: 100%;
    }
    @media (max-width: 720px) { .trust-metrics { grid-template-columns: repeat(2, 1fr); gap: 20px; } }
    .trust-metric {
      text-align: center;
      display: flex; flex-direction: column; align-items: center; gap: 6px;
    }
    .trust-metric-stars {
      display: inline-flex; gap: 2px; color: #f59e0b;
    }
    .trust-metric-stars svg { width: 14px; height: 14px; }
    .trust-metric-badge {
      width: 26px; height: 26px; border-radius: 7px;
      display: grid; place-items: center;
      background: linear-gradient(135deg, var(--sagan) 0%, var(--sagan-deep) 100%);
      color: white;
      box-shadow: 0 4px 10px rgba(30,58,95,0.22);
    }
    .trust-metric-badge svg { width: 14px; height: 14px; }
    .trust-metric-value {
      font-size: clamp(1.2rem, 2vw, 1.45rem); font-weight: 900;
      color: var(--ink); letter-spacing: -0.02em;
      line-height: 1.1;
      font-variant-numeric: tabular-nums;
    }
    .trust-metric-value em {
      font-family: 'Newsreader', serif; font-style: italic; font-weight: 500;
      color: var(--sagan);
    }
    .trust-metric-label {
      font-size: 0.78rem; color: var(--ink-4); font-weight: 500;
      line-height: 1.35;
    }

    /* ── SCANNER ── */
    .scanner { padding: 64px 24px 96px; background: var(--paper); }
    .scanner-card {
      max-width: 780px; margin: 0 auto;
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      box-shadow:
        0 1px 0 rgba(255,255,255,0.6) inset,
        0 24px 48px -16px rgba(11,18,32,0.08),
        0 8px 16px -8px rgba(11,18,32,0.05);
      overflow: hidden;
    }
    .scanner-card.hidden { display: none; }
    .describe-textarea { resize: vertical; min-height: 56px; line-height: 1.5; }
    .describe-fine {
      margin-top: 8px; font-size: 0.78rem; color: var(--ink-5);
      text-align: center;
    }
    .describe-fine a { color: var(--sagan); text-decoration: none; font-weight: 600; }
    .advanced-toggle {
      margin-top: 16px; text-align: center; font-size: 0.84rem;
      color: var(--ink-4); cursor: pointer; font-weight: 500;
      padding-top: 16px; border-top: 1px solid var(--line);
    }
    .advanced-toggle:hover { color: var(--sagan); }
    .advanced-panel {
      margin-top: 16px;
      padding: 16px;
      background: var(--paper);
      border-radius: 10px;
      border: 1px solid var(--line);
    }
    .advanced-panel.hidden { display: none; }

    /* ── ROSTER EDITOR ── */
    .roster-list { display: flex; flex-direction: column; gap: 8px; }
    .roster-row {
      display: grid;
      grid-template-columns: 1fr auto auto;
      gap: 12px; align-items: center;
      padding: 12px 14px;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 10px;
      transition: all 0.15s;
      animation: slideUp 0.25s ease backwards;
    }
    .roster-row:hover { border-color: var(--line-2); background: var(--white); }
    .roster-role {
      font-weight: 600; color: var(--ink); font-size: 0.95rem;
      border: none; background: transparent; padding: 4px 0;
      font-family: inherit; width: 100%;
    }
    .roster-role:focus { outline: none; border-bottom: 1px dashed var(--sagan); }
    .roster-counter {
      display: flex; align-items: center; gap: 6px;
      background: var(--white); border: 1px solid var(--line);
      border-radius: 8px; padding: 2px;
    }
    .counter-btn {
      width: 28px; height: 28px; border-radius: 6px;
      border: none; background: transparent;
      display: grid; place-items: center;
      color: var(--ink-4); cursor: pointer;
      font-weight: 700; font-size: 1rem;
      transition: all 0.1s;
    }
    .counter-btn:hover { background: var(--paper-warm); color: var(--ink); }
    .counter-btn:disabled { opacity: 0.35; cursor: not-allowed; }
    .counter-val {
      min-width: 28px; text-align: center;
      font-family: 'JetBrains Mono', monospace;
      font-weight: 700; font-size: 0.92rem; color: var(--ink);
    }
    .remove-btn {
      width: 32px; height: 32px; border-radius: 8px;
      border: none; background: transparent;
      display: grid; place-items: center;
      color: var(--ink-5); cursor: pointer;
      transition: all 0.1s;
    }
    .remove-btn:hover { background: var(--red-bg); color: var(--red); }
    .remove-btn svg { width: 16px; height: 16px; }

    .roster-add {
      display: flex; gap: 8px; margin-top: 12px;
      padding: 12px 14px;
      background: var(--paper-warm);
      border: 1px dashed var(--line-2);
      border-radius: 10px;
    }
    .roster-add input {
      flex: 1;
      border: none; background: transparent;
      font-family: inherit; font-size: 0.92rem;
      color: var(--ink); padding: 6px 0;
    }
    .roster-add input:focus { outline: none; }
    .roster-add input::placeholder { color: var(--ink-5); }
    .btn-secondary {
      padding: 8px 16px;
      background: var(--ink);
      color: var(--white);
      border: none; border-radius: 8px;
      font-size: 0.84rem; font-weight: 700;
      cursor: pointer;
      transition: all 0.15s;
    }
    .btn-secondary:hover { background: var(--navy); }
    .btn-secondary:disabled { background: var(--ink-5); cursor: not-allowed; }

    /* ── GENERATING ── */
    .generating-state {
      padding: 40px 32px; text-align: center;
    }
    .generating-spinner {
      width: 36px; height: 36px;
      border: 3px solid var(--line);
      border-top-color: var(--sagan);
      border-radius: 50%;
      margin: 0 auto 18px;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .generating-title { font-weight: 700; color: var(--ink); margin-bottom: 4px; font-size: 1rem; }
    .generating-sub { font-size: 0.86rem; color: var(--ink-4); }
    .scanner-head {
      padding: 28px 32px 20px;
      border-bottom: 1px solid var(--line);
      background: linear-gradient(180deg, var(--white) 0%, var(--paper) 100%);
    }
    .scanner-title {
      font-size: 1.05rem; font-weight: 700; color: var(--ink);
      margin-bottom: 4px; letter-spacing: -0.01em;
    }
    .scanner-sub { font-size: 0.88rem; color: var(--ink-4); }

    .scanner-tabs {
      display: flex; gap: 4px; padding: 8px 12px 0;
      border-bottom: 1px solid var(--line);
      background: var(--paper);
    }
    .tab {
      padding: 10px 18px; font-size: 0.85rem; font-weight: 600;
      color: var(--ink-4); background: transparent; border: none;
      cursor: pointer; border-radius: 8px 8px 0 0;
      border-bottom: 2px solid transparent;
      transition: all 0.15s;
      display: flex; align-items: center; gap: 8px;
    }
    .tab:hover { color: var(--ink); }
    .tab.active {
      color: var(--sagan); background: var(--white);
      border-bottom-color: var(--sagan);
    }
    .tab svg { width: 14px; height: 14px; }

    .scanner-body { padding: 24px 32px 28px; }
    .tab-panel { display: none; animation: fadeIn 0.25s ease; }
    .tab-panel.active { display: block; }

    textarea.roles-input {
      width: 100%;
      min-height: 220px;
      padding: 16px 18px;
      border: 1px solid var(--line-2);
      border-radius: 12px;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 0.88rem;
      line-height: 1.7;
      color: var(--ink);
      resize: vertical;
      background: var(--paper);
      transition: all 0.15s;
    }
    textarea.roles-input:focus {
      outline: none; border-color: var(--sagan);
      box-shadow: 0 0 0 3px rgba(30,58,95,0.12);
      background: var(--white);
    }
    textarea.roles-input::placeholder { color: var(--ink-5); }

    .input-hint {
      margin-top: 10px; font-size: 0.78rem; color: var(--ink-5);
      display: flex; align-items: center; gap: 6px;
    }
    .input-hint .kbd {
      display: inline-block; padding: 2px 6px; background: var(--paper-warm);
      border: 1px solid var(--line-2); border-radius: 4px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.74rem;
      color: var(--ink-3);
    }

    .upload-zone {
      border: 2px dashed var(--line-2);
      border-radius: 12px;
      padding: 40px 20px;
      text-align: center;
      background: var(--paper);
      transition: all 0.15s;
      cursor: pointer;
    }
    .upload-zone:hover, .upload-zone.dragover {
      border-color: var(--sagan); background: var(--sagan-light);
    }
    .upload-zone svg { width: 34px; height: 34px; color: var(--ink-5); margin-bottom: 10px; }
    .upload-zone-title { font-weight: 600; color: var(--ink); margin-bottom: 4px; }
    .upload-zone-sub { font-size: 0.82rem; color: var(--ink-5); }
    .upload-zone input[type="file"] { display: none; }
    .upload-zone.has-file { border-color: var(--green); background: var(--green-bg); }
    .upload-zone.has-file svg { color: var(--green); }
    .upload-zone.has-file .upload-zone-title { color: var(--green-ink); }

    .scanner-footer {
      padding: 20px 32px 24px;
      background: var(--paper);
      border-top: 1px solid var(--line);
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 12px;
    }
    .count-pill {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 12px;
      background: var(--white);
      border: 1px solid var(--line-2);
      border-radius: 999px;
      font-size: 0.82rem; color: var(--ink-3); font-weight: 500;
    }
    .count-pill strong { color: var(--ink); font-weight: 700; }
    .count-pill-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--ink-5);
    }
    .count-pill.has-roles .count-pill-dot { background: var(--green); }

    /* ── LOADING ── */
    .loading {
      max-width: 860px; margin: 0 auto; padding: 48px 32px;
      text-align: center;
      background: var(--white);
      border: 1px solid var(--line); border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
      display: none;
    }
    .loading.active { display: block; animation: fadeIn 0.3s ease; }
    .loading-title { font-weight: 700; font-size: 1.1rem; color: var(--ink); margin-bottom: 8px; }
    .loading-sub { color: var(--ink-4); font-size: 0.9rem; }
    .loading-rows { margin-top: 28px; display: flex; flex-direction: column; gap: 10px; }
    .loading-row {
      height: 44px;
      background: linear-gradient(90deg, var(--paper-warm) 0%, var(--paper) 50%, var(--paper-warm) 100%);
      background-size: 200% 100%;
      animation: shimmer 1.4s linear infinite;
      border-radius: 8px;
    }

    /* ── RESULTS SUMMARY ── */
    .results {
      max-width: 1120px; margin: 0 auto;
      display: none;
    }
    .results.active { display: block; animation: fadeIn 0.35s ease; }

    .results-header {
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      padding: 32px 36px;
      margin-bottom: 22px;
      box-shadow: var(--shadow-md);
    }
    .results-eyebrow {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em;
      color: var(--ink-5); text-transform: uppercase; margin-bottom: 14px;
    }
    .results-verdict {
      font-size: clamp(1.4rem, 2.6vw, 1.95rem);
      font-weight: 800; color: var(--ink);
      letter-spacing: -0.02em; line-height: 1.25;
      margin-bottom: 8px;
    }
    .results-verdict em {
      font-family: 'Newsreader', Georgia, serif;
      font-style: italic; font-weight: 500;
      color: var(--sagan);
    }
    .results-verdict-sub {
      color: var(--ink-4); font-size: 0.98rem; line-height: 1.55;
    }

    .results-stats {
      display: grid; grid-template-columns: 0.9fr 0.9fr 1.6fr;
      gap: 14px; margin-top: 26px;
      position: relative;
    }
    @media (max-width: 720px) { .results-stats { grid-template-columns: 1fr; } }

    .stat-card {
      padding: 22px 22px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: var(--paper);
      position: relative;
    }
    .stat-card.current { background: var(--white); border-color: var(--line-2); }
    .stat-card.sagan { background: var(--sagan-light); border-color: #bfdcff; }

    /* ── THE MONEY SHOT ── */
    .stat-card.save {
      padding: 26px 26px;
      background:
        radial-gradient(ellipse 120% 80% at 90% 10%, rgba(251,191,36,0.18) 0%, transparent 55%),
        radial-gradient(ellipse 80% 60% at 10% 100%, rgba(239,68,68,0.12) 0%, transparent 60%),
        linear-gradient(135deg, var(--ink) 0%, var(--navy) 100%);
      border: 1px solid rgba(251,191,36,0.28);
      color: var(--white);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.08),
        0 20px 40px -12px rgba(239,68,68,0.18),
        0 8px 16px rgba(11,18,32,0.22);
      overflow: hidden;
      isolation: isolate;
    }
    /* Rotating conic-gradient halo */
    .stat-card.save::before {
      content: ""; position: absolute; inset: -60%;
      background: conic-gradient(from 0deg, transparent 60%, rgba(251,191,36,0.4) 75%, rgba(239,68,68,0.5) 85%, transparent 100%);
      animation: halo-rotate 8s linear infinite;
      pointer-events: none;
      z-index: 0;
    }
    /* Inner mask so the halo only shows at the edges */
    .stat-card.save::after {
      content: ""; position: absolute; inset: 1px;
      background:
        radial-gradient(ellipse 120% 80% at 90% 10%, rgba(251,191,36,0.18) 0%, transparent 55%),
        radial-gradient(ellipse 80% 60% at 10% 100%, rgba(239,68,68,0.12) 0%, transparent 60%),
        linear-gradient(135deg, #111a2e 0%, #0b1220 100%);
      border-radius: 13px;
      pointer-events: none;
      z-index: 1;
    }
    .stat-card.save > * { position: relative; z-index: 2; }
    @keyframes halo-rotate {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @media (prefers-reduced-motion: reduce) {
      .stat-card.save::before { animation: none; display: none; }
    }

    /* Label stays subtle but alive */
    .stat-card.save .stat-label-dot {
      background: #fbbf24;
      animation: pulse-dot 1.8s ease-in-out infinite;
      box-shadow: 0 0 8px rgba(251,191,36,0.7);
    }

    .stat-label {
      font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--ink-5); margin-bottom: 8px;
      display: flex; align-items: center; gap: 6px;
    }
    .stat-card.sagan .stat-label { color: var(--sagan-deep); }
    .stat-card.save .stat-label { color: rgba(255,255,255,0.6); }
    .stat-label-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

    .stat-value {
      font-size: 2rem; font-weight: 900; color: var(--ink);
      line-height: 1.02; letter-spacing: -0.03em;
      font-variant-numeric: tabular-nums;
    }
    .stat-card.sagan .stat-value { color: var(--sagan-deep); }
    .stat-card.save .stat-value {
      font-size: clamp(2.6rem, 5vw, 3.6rem);
      font-weight: 900;
      letter-spacing: -0.04em;
      line-height: 1;
      background: linear-gradient(100deg, #fde68a 0%, #fbbf24 28%, #f97316 62%, #ef4444 100%);
      background-size: 220% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
      animation: shimmer-text 5s linear infinite;
      filter: drop-shadow(0 4px 18px rgba(251,191,36,0.28));
      display: inline-block;
      will-change: transform, background-position;
    }
    .stat-card.save.punch .stat-value {
      animation: shimmer-text 5s linear infinite, money-punch 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @keyframes shimmer-text {
      0% { background-position: 0% 50%; }
      100% { background-position: -220% 50%; }
    }
    @keyframes money-punch {
      0% { transform: scale(1); }
      35% { transform: scale(1.1) rotate(-0.5deg); }
      65% { transform: scale(0.98) rotate(0.25deg); }
      100% { transform: scale(1) rotate(0); }
    }
    .stat-unit { font-size: 0.82rem; font-weight: 500; color: var(--ink-5); margin-top: 4px; line-height: 1.45; }
    .stat-card.sagan .stat-unit { color: var(--sagan); opacity: 0.85; }
    .stat-card.save .stat-unit {
      color: rgba(251,191,36,0.85);
      font-weight: 600;
      margin-top: 8px;
    }

    .stats-breakdown {
      display: flex; gap: 10px; flex-wrap: wrap;
      margin-top: 18px;
      font-size: 0.82rem; color: var(--ink-4);
    }
    .stats-breakdown-item {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 12px;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 999px;
    }
    .stats-breakdown-item strong { color: var(--ink); font-weight: 700; }
    .stats-breakdown-dot { width: 7px; height: 7px; border-radius: 50%; }
    .stats-breakdown-dot.red { background: var(--red); }
    .stats-breakdown-dot.yellow { background: var(--amber); }
    .stats-breakdown-dot.green { background: var(--green); }
    .stats-breakdown-dot.local { background: var(--ink-4); }

    /* ── GATE OVERLAY ── */
    .gate-wrap {
      position: relative;
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-md);
      overflow: hidden;
      min-height: 620px;
    }
    @media (max-width: 640px) { .gate-wrap { min-height: 680px; } }
    .gate-preview {
      padding: 28px 36px;
      filter: blur(6px);
      pointer-events: none;
      user-select: none;
    }
    .gate-preview-rows { display: flex; flex-direction: column; gap: 10px; }
    .gate-preview-row {
      display: flex; align-items: center; gap: 14px;
      padding: 16px 18px;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 10px;
    }
    .gate-preview-bar {
      width: 6px; height: 32px; border-radius: 3px;
    }
    .gate-preview-bar.red { background: var(--red); }
    .gate-preview-bar.yellow { background: var(--amber); }
    .gate-preview-bar.green { background: var(--green); }
    .gate-preview-text {
      flex: 1; height: 10px; border-radius: 3px;
      background: linear-gradient(90deg, var(--ink-5) 0%, var(--line-2) 100%);
    }

    .gate-overlay {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      padding: 32px;
      background: linear-gradient(180deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.98) 55%);
    }
    .gate-card {
      max-width: 460px; width: 100%;
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      padding: 32px 32px 28px;
      box-shadow: var(--shadow-xl);
    }
    .gate-card-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 5px 12px;
      background: var(--ink);
      color: var(--white);
      border-radius: 999px;
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      margin-bottom: 16px;
    }
    .gate-card-badge svg { width: 12px; height: 12px; }
    .gate-card h3 {
      font-size: 1.35rem; font-weight: 800; color: var(--ink);
      letter-spacing: -0.02em; line-height: 1.25; margin-bottom: 8px;
    }
    .gate-card p {
      font-size: 0.92rem; color: var(--ink-4); line-height: 1.6; margin-bottom: 20px;
    }
    .form-row { display: flex; flex-direction: column; gap: 12px; }
    .form-field { display: flex; flex-direction: column; gap: 6px; }
    .form-label {
      font-size: 0.78rem; font-weight: 600; color: var(--ink-3);
      display: flex; justify-content: space-between;
    }
    .form-input {
      padding: 11px 14px;
      border: 1px solid var(--line-2);
      border-radius: 8px;
      font-family: 'Geist', sans-serif;
      font-size: 0.93rem;
      color: var(--ink);
      background: var(--paper);
      transition: all 0.15s;
    }
    .form-input:focus {
      outline: none; border-color: var(--sagan);
      box-shadow: 0 0 0 3px rgba(30,58,95,0.12);
      background: var(--white);
    }
    .form-error {
      color: var(--red); font-size: 0.82rem; margin-top: 4px;
      display: none;
    }
    .form-error.active { display: block; }
    .btn-submit {
      width: 100%;
      padding: 14px 20px; margin-top: 6px;
      background: var(--ink); color: var(--white);
      border: none; border-radius: 10px;
      font-size: 0.96rem; font-weight: 700;
      cursor: pointer;
      transition: all 0.18s;
      display: flex; justify-content: center; align-items: center; gap: 8px;
    }
    .btn-submit:hover { background: var(--navy); }
    .btn-submit:disabled { background: var(--ink-5); cursor: wait; }
    .gate-fine {
      font-size: 0.74rem; color: var(--ink-5);
      margin-top: 14px; text-align: center; line-height: 1.5;
    }

    /* ── FULL RESULTS LIST ── */
    .role-group { margin-bottom: 28px; }
    .role-group-head {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 18px; margin-bottom: 10px;
      border-radius: 12px;
    }
    .role-group-head.red { background: var(--red-bg); }
    .role-group-head.yellow { background: var(--amber-bg); }
    .role-group-head.green { background: var(--green-bg); }
    .role-group-bar {
      width: 4px; height: 28px; border-radius: 2px;
    }
    .role-group-bar.red { background: var(--red); }
    .role-group-bar.yellow { background: var(--amber); }
    .role-group-bar.green { background: var(--green); }
    .role-group-title {
      font-weight: 800; font-size: 1.02rem; letter-spacing: -0.01em;
      color: var(--ink);
    }
    .role-group-count {
      margin-left: auto; font-size: 0.82rem; font-weight: 600;
      padding: 4px 10px; border-radius: 999px;
      background: var(--white);
    }
    .role-group-desc {
      font-size: 0.84rem; color: var(--ink-4);
      margin-left: 16px; flex: 1;
    }
    @media (max-width: 640px) { .role-group-desc { display: none; } }

    .role-card {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 20px; align-items: start;
      padding: 18px 22px;
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: 12px;
      margin-bottom: 8px;
      transition: all 0.15s;
      animation: slideUp 0.35s ease backwards;
    }
    .role-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
    @media (max-width: 720px) {
      .role-card { grid-template-columns: 1fr; gap: 10px; }
    }

    .role-main { min-width: 0; }
    .role-head {
      display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
      margin-bottom: 6px;
    }
    .role-name {
      font-weight: 700; font-size: 1.02rem; color: var(--ink);
      letter-spacing: -0.01em;
    }
    .role-count {
      font-size: 0.82rem; font-weight: 600; color: var(--ink-5);
      background: var(--paper-warm); padding: 2px 8px; border-radius: 5px;
      font-variant-numeric: tabular-nums;
    }
    .role-sol-chip {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 3px 10px;
      background: var(--sagan-light); color: var(--sagan-deep);
      border-radius: 6px;
      font-size: 0.78rem; font-weight: 700;
      letter-spacing: 0;
    }
    .role-sol-chip.physical { background: var(--paper-warm); color: var(--ink-3); }
    .role-sol-chip.self { background: #fef3c7; color: #78350f; }
    .role-why {
      font-size: 0.86rem; color: var(--ink-4);
      line-height: 1.55; margin-bottom: 10px;
    }
    .role-math {
      display: inline-flex; gap: 10px; align-items: center;
      font-size: 0.82rem; color: var(--ink-4);
      font-variant-numeric: tabular-nums;
      flex-wrap: wrap;
    }
    .role-math strong { color: var(--ink); font-weight: 700; }
    .role-math .arrow { color: var(--ink-5); font-weight: 700; }
    .role-math .was {
      text-decoration: line-through; text-decoration-color: var(--ink-5);
      text-decoration-thickness: 1.5px;
      color: var(--ink-5);
    }

    .role-savings-box {
      text-align: right;
      min-width: 110px;
      padding: 8px 0 0;
    }
    @media (max-width: 720px) {
      .role-savings-box { text-align: left; padding: 10px 0 0; border-top: 1px dashed var(--line); }
    }
    .role-savings-label {
      font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--ink-5);
      margin-bottom: 2px;
    }
    .role-savings-value {
      font-size: 1.3rem; font-weight: 900; color: var(--green-ink);
      font-variant-numeric: tabular-nums;
      letter-spacing: -0.02em;
      line-height: 1.1;
    }
    .role-savings-value.neutral { color: var(--ink-4); font-size: 1.02rem; font-weight: 700; }
    .role-savings-sub {
      font-size: 0.72rem; color: var(--ink-5); margin-top: 2px;
      font-weight: 500;
    }

    /* ── PROOF ── */
    .proof {
      padding: 88px 24px; background: var(--ink);
      color: var(--white);
      position: relative; overflow: hidden;
    }
    .proof::before {
      content: ""; position: absolute; inset: 0;
      background-image:
        radial-gradient(ellipse 40% 50% at 20% 20%, rgba(30,58,95,0.3) 0%, transparent 50%),
        radial-gradient(ellipse 40% 50% at 80% 80%, rgba(220,38,38,0.12) 0%, transparent 50%);
      pointer-events: none;
    }
    .proof-inner { max-width: 960px; margin: 0 auto; position: relative; }
    .proof-eyebrow {
      font-size: 0.74rem; font-weight: 700; letter-spacing: 0.14em;
      text-transform: uppercase; color: rgba(255,255,255,0.5);
      margin-bottom: 16px;
    }
    .proof h2 {
      font-size: clamp(1.8rem, 3.6vw, 2.6rem);
      font-weight: 800; line-height: 1.15;
      letter-spacing: -0.032em; margin-bottom: 24px; color: var(--white);
    }
    .proof h2 em {
      font-family: 'Newsreader', serif; font-style: italic; font-weight: 500;
      color: #94c5ff;
    }
    .proof-number {
      font-size: clamp(3rem, 6vw, 5rem);
      font-weight: 900; line-height: 1;
      letter-spacing: -0.04em;
      background: linear-gradient(135deg, #ffffff 0%, #94c5ff 100%);
      -webkit-background-clip: text;
      background-clip: text; color: transparent;
      margin-bottom: 4px;
    }
    .proof-number-label {
      font-size: 0.88rem; color: rgba(255,255,255,0.6);
      font-weight: 500; margin-bottom: 32px;
    }
    .proof-body {
      font-size: 1.04rem; line-height: 1.75;
      color: rgba(255,255,255,0.78);
      max-width: 680px;
    }
    .proof-body p { margin-bottom: 16px; }
    .proof-body strong { color: var(--white); font-weight: 600; }

    .proof-grid {
      display: grid;
      grid-template-columns: 1.35fr 1fr;
      grid-template-rows: auto auto;
      gap: 14px;
      margin-top: 44px;
    }
    @media (max-width: 720px) { .proof-grid { grid-template-columns: 1fr; grid-template-rows: auto; } }
    .proof-card {
      padding: 24px 26px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
      display: flex; flex-direction: column; justify-content: flex-end;
    }
    .proof-card.feature {
      grid-row: 1 / 3;
      background: linear-gradient(135deg, rgba(148,197,255,0.10) 0%, rgba(255,255,255,0.03) 100%);
      border-color: rgba(148,197,255,0.18);
      min-height: 200px;
    }
    @media (max-width: 720px) { .proof-card.feature { grid-row: auto; min-height: 0; } }
    .proof-card .proof-card-eyebrow {
      font-size: 0.68rem; font-weight: 700; letter-spacing: 0.16em;
      text-transform: uppercase; color: rgba(148,197,255,0.8);
      margin-bottom: 10px;
    }
    .proof-card-stat {
      font-size: 2rem; font-weight: 900; color: var(--white);
      letter-spacing: -0.03em; line-height: 1; margin-bottom: 8px;
      font-variant-numeric: tabular-nums;
    }
    .proof-card.feature .proof-card-stat { font-size: 2.8rem; }
    .proof-card-stat em {
      font-family: 'Newsreader', serif; font-style: italic; font-weight: 500;
      color: #94c5ff;
    }
    .proof-card-label {
      font-size: 0.9rem; color: rgba(255,255,255,0.7);
      line-height: 1.55;
    }
    .proof-card.feature .proof-card-label { font-size: 1rem; }

    /* ── FINAL CTA ── */
    .cta-final {
      padding: 96px 24px; text-align: center;
      background: var(--paper-warm);
      border-top: 1px solid var(--line);
    }
    .cta-final h2 {
      font-size: clamp(1.8rem, 3.4vw, 2.4rem);
      font-weight: 800; letter-spacing: -0.03em;
      line-height: 1.18; color: var(--ink);
      margin-bottom: 16px;
    }
    .cta-final h2 em {
      font-family: 'Newsreader', serif; font-style: italic; font-weight: 500;
      color: var(--sagan);
    }
    .cta-final p {
      color: var(--ink-4); font-size: 1.04rem;
      max-width: 560px; margin: 0 auto 28px;
      line-height: 1.65;
    }

    /* ── FOOTER ── */
    footer {
      padding: 32px 24px 40px;
      background: var(--paper);
      border-top: 1px solid var(--line);
      text-align: center;
      font-size: 0.82rem; color: var(--ink-5);
    }
    footer a { color: var(--ink-3); text-decoration: none; font-weight: 500; }
    footer a:hover { color: var(--sagan); }

    /* ── SUCCESS MODAL ── */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(11,18,32,0.64);
      backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
      display: none; align-items: center; justify-content: center;
      z-index: 2000; padding: 24px;
    }
    .modal-overlay.active { display: flex; animation: fadeIn 0.2s ease; }
    .modal-card {
      background: var(--white);
      border-radius: 20px;
      max-width: 480px; width: 100%;
      padding: 40px 36px 32px;
      text-align: center;
      box-shadow: 0 40px 80px rgba(11,18,32,0.5);
      animation: modalIn 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      position: relative;
    }
    @keyframes modalIn {
      from { opacity: 0; transform: translateY(20px) scale(0.95); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .modal-close {
      position: absolute; top: 16px; right: 16px;
      width: 34px; height: 34px;
      border: none; background: var(--paper);
      border-radius: 8px; cursor: pointer;
      display: grid; place-items: center;
      color: var(--ink-4);
      transition: all 0.15s;
    }
    .modal-close:hover { background: var(--paper-warm); color: var(--ink); }
    .modal-check {
      width: 64px; height: 64px; border-radius: 50%;
      background: linear-gradient(135deg, #10b981 0%, #047857 100%);
      display: grid; place-items: center;
      margin: 0 auto 22px;
