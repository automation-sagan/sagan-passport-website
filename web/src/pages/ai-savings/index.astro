      { keys: ['social media scheduler', 'social scheduler', 'social media assistant', 'social media coordinator'], color: 'red', us: 3800, sag: 60, sol: 'Social Ops Agent', why: 'Schedules posts, handles basic responses, repurposes winners. Your social ops in the background for sixty bucks.' },
      { keys: ['cold caller', 'telemarketer'], color: 'red', us: 4500, sag: 400, sol: 'Voice Outreach Agent', why: 'Voice AI that hits 80% of human cold-caller performance at 5% of the cost. No burnout. No turnover. No calling in sick on a Tuesday.' },
