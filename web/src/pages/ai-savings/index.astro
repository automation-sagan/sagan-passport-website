              <span class="role-sol-chip ${chipClass}">${escapeHtml(sol)}</span>
            </div>
            <div class="role-why">${escapeHtml(item.why)}</div>
            ${mathLine}
          </div>
          <div class="role-savings-box">${saveBox}</div>
