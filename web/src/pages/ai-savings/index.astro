      { keys: ['data scraper', 'web scraper', 'research assistant', 'research associate'], color: 'red', us: 4200, sag: 120, sol: 'Deep Research Agent', why: 'Four-hour research projects, finished in ten minutes. For any task an analyst used to spend an afternoon on.' },
