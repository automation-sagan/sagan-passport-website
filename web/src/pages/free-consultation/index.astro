---
export const prerender = true;
import LandingLayout from '../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Hire Global Talent in 14 Days | Sagan"
  description="Sagan finds you outstanding full-time global talent that costs 80% less than US equivalents. Book a free 30-minute consultation."
>
  <!-- Microsoft Clarity -->
  <script is:inline type="text/javascript">
    (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "vny08rxcwk");
  </script>
  <!-- End Microsoft Clarity -->

  <!-- Google Tag Manager (noscript) -->
  <!--
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KV7HKVSJ"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  -->
  <!-- End Google Tag Manager (noscript) -->

  <!-- Top Bar -->
  <nav class="topbar">
    <a href="#hero" class="topbar-logo"><img src="/free-consultation/img/sagan-logo-blue.png" alt="Sagan" /></a>
    <div class="topbar-nav">
      <div class="topbar-trust">
        <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        Trusted by 600+ companies
      </div>
      <a href="#calendly" class="topbar-cta">
        Book Free Consultation
        <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero" id="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="hero-badge reveal"><span class="dot"></span> LIMITED SPOTS - ACCEPTING 8 NEW MEMBERS THIS MONTH</div>
          <h1 class="reveal reveal-delay-1">Your next senior hire doesn't cost $12,000/mo.<br /> It costs $2,500.</h1>
          <p class="hero-sub reveal reveal-delay-2">Full-time, pre-vetted professionals from Latin America, Philippines, South Africa & beyond. They work your hours, integrate into your team for ~80% less than a US equivalent.</p>
          <div class="hero-proof reveal reveal-delay-3">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            600+ companies since 2022 &nbsp;·&nbsp; 4.9/5 on Clutch &nbsp;·&nbsp; Talent in 30+ countries
          </div>
        </div>

        <!-- Embedded Calendly (Direct Booking) -->
        <div class="calendly-card reveal reveal-delay-2" id="calendly">
          <div class="calendly-loading"><div class="spinner"></div>Loading scheduler&hellip;</div>
          <iframe src="https://calendly.com/d/5j7-3xv-p5k/global-talent-hiring-consultation?utm_source=linkedin&utm_term=profile&hide_gdpr_banner=1&hide_event_type_details=1"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="trust-bar">
    <div class="container">
      <div class="trust-inner reveal">
        <div class="trust-item">
          <strong>600+</strong> companies served since 2019
        </div>
        <div class="trust-divider"></div>
        <div class="clutch-badge">
          <span class="clutch-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          4.9/5 on Clutch
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 9c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 9c0-.778.099-1.533.284-2.253"/></svg>
          Talent in <strong>30+</strong> countries
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="stats">
    <div class="container">
      <div class="stats-grid">
        <div class="reveal">
          <div class="stat-num">600+</div>
          <div class="stat-label">Companies served</div>
        </div>
        <div class="reveal reveal-delay-1">
          <div class="stat-num">14</div>
          <div class="stat-label">Days average time-to-hire</div>
        </div>
        <div class="reveal reveal-delay-2">
          <div class="stat-num">80%</div>
          <div class="stat-label">Cost savings vs. US equivalent</div>
        </div>
        <div class="reveal reveal-delay-3">
          <div class="stat-num">4.9/5</div>
          <div class="stat-label">Member satisfaction</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits (reduced from 6 to 4) -->
  <section class="benefits">
    <div class="container">
      <p class="section-label reveal">Why Sagan</p>
      <h2 class="section-title reveal">Everything you need to hire globally, without the headache</h2>
      <div class="benefits-grid">

        <div class="benefit-card reveal">
          <div class="benefit-icon">
            <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3>Kickoff to signed offer in 14 days</h3>
          <p>We don't start recruiting when you call. The pipeline is already built. Pre-screened candidates, ready to interview this week.</p>
        </div>

        <div class="benefit-card reveal reveal-delay-1">
          <div class="benefit-icon">
            <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
          </div>
          <h3>Senior Marketing Manager: $2,500/mo</h3>
          <p>The US equivalent: $12,000. Same seniority, same hours, same tools. The difference is where they live.</p>
        </div>

        <div class="benefit-card reveal reveal-delay-2">
          <div class="benefit-icon">
            <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
          </div>
          <h3>Doesn't work out? We replace them. No cost.</h3>
          <p>Every placement comes with an unlimited replacement guarantee. No extra fees, no re-recruiting from scratch.</p>
        </div>

        <div class="benefit-card reveal reveal-delay-3">
          <div class="benefit-icon">
            <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
          </div>
          <h3>Pre-Vetted &amp; Full-Time</h3>
          <p>Skills tests, English proficiency, cultural fit assessment. Full-time, 100% dedicated to your company. Not contractors. Not freelancers.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="how-it-works">
    <div class="container">
      <p class="section-label reveal">How it works</p>
      <h2 class="section-title reveal">Three steps to your next great hire</h2>
      <div class="steps-grid">
        <div class="step-card reveal">
          <div class="step-num">1</div>
          <h3>Book a call</h3>
          <p>30-minute consultation to understand your needs, team structure, and ideal candidate profile.</p>
        </div>
        <div class="step-card reveal reveal-delay-1">
          <div class="step-num">2</div>
          <h3>Meet your candidates</h3>
          <p>We send you vetted, interview-ready candidates within days — not weeks.</p>
        </div>
        <div class="step-card reveal reveal-delay-2">
          <div class="step-num">3</div>
          <h3>Hire with confidence</h3>
          <p>Make your hire backed by our unlimited replacement guarantee. Zero risk.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Candidate Salary Cards -->
  <section class="candidates">
    <div class="container">
      <p class="section-label reveal">Real talent, real savings</p>
      <h2 class="section-title reveal">See what $2,000–$3,500/mo gets you</h2>
      <div class="candidates-grid">

        <div class="candidate-card reveal">
          <div class="candidate-avatar" style="background: #2197ff;">SM</div>
          <h4>Senior Marketing Manager</h4>
          <p class="candidate-role">8 years experience</p>
          <div class="candidate-detail">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z"/></svg>
            Colombia
          </div>
          <div class="candidate-tags">
            <span class="candidate-tag">HubSpot</span>
            <span class="candidate-tag">SEO</span>
            <span class="candidate-tag">Paid Ads</span>
          </div>
          <div class="candidate-salary">
            <div class="amount">$2,500<span class="period">/mo</span></div>
            <div class="comparison">vs. $12,000/mo US equivalent</div>
          </div>
        </div>

        <div class="candidate-card reveal reveal-delay-1">
          <div class="candidate-avatar" style="background: #093a3e;">EA</div>
          <h4>Executive Assistant</h4>
          <p class="candidate-role">5 years experience</p>
          <div class="candidate-detail">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z"/></svg>
            Philippines
          </div>
          <div class="candidate-tags">
            <span class="candidate-tag">Calendar Mgmt</span>
            <span class="candidate-tag">Notion</span>
          </div>
          <div class="candidate-salary">
            <div class="amount">$1,800<span class="period">/mo</span></div>
            <div class="comparison">vs. $7,500/mo US equivalent</div>
          </div>
        </div>

        <div class="candidate-card reveal reveal-delay-2">
          <div class="candidate-avatar" style="background: #22c55e;">SD</div>
          <h4>SDR / Sales Development</h4>
          <p class="candidate-role">4 years experience</p>
          <div class="candidate-detail">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z"/></svg>
            South Africa
          </div>
          <div class="candidate-tags">
            <span class="candidate-tag">Salesforce</span>
            <span class="candidate-tag">Cold Outreach</span>
          </div>
          <div class="candidate-salary">
            <div class="amount">$2,200<span class="period">/mo</span></div>
            <div class="comparison">vs. $8,500/mo US equivalent</div>
          </div>
        </div>

        <div class="candidate-card reveal reveal-delay-3">
          <div class="candidate-avatar" style="background: #e67e22;">BK</div>
          <h4>Bookkeeper</h4>
          <p class="candidate-role">6 years experience</p>
          <div class="candidate-detail">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z"/></svg>
            Mexico
          </div>
          <div class="candidate-tags">
            <span class="candidate-tag">QuickBooks</span>
            <span class="candidate-tag">Xero</span>
          </div>
          <div class="candidate-salary">
            <div class="amount">$2,000<span class="period">/mo</span></div>
            <div class="comparison">vs. $6,500/mo US equivalent</div>
          </div>
        </div>

      </div>

      <div class="candidates-cta reveal">
        <a href="#calendly">
          Book a Call to See Candidates Like These
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <p>We'll pull sample profiles matched to your role before the call.</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials">
    <div class="container">
      <h2 class="section-title reveal">Real reviews from Clutch.co</h2>
      <div class="testimonials-grid">

        <div class="testimonial-card reveal">
          <p class="testimonial-text">"They challenge you to think differently about global talent. Sagan helped us find people we never would have found on our own."</p>
          <div class="testimonial-context">Hired: Operations &amp; Admin team</div>
          <div class="testimonial-author">
            <div class="testimonial-avatar" style="background: #2197ff;">GV</div>
            <div>
              <div class="testimonial-name">Greg Van Horn</div>
              <div class="testimonial-role">Owner, Bumble Roofing</div>
            </div>
          </div>
        </div>

        <div class="testimonial-card reveal reveal-delay-1">
          <p class="testimonial-text">"You get a lot of great hires for a great price from all over the globe. The quality of candidates they present is consistently high."</p>
          <div class="testimonial-context">Hired: Admin &amp; support staff</div>
          <div class="testimonial-author">
            <div class="testimonial-avatar" style="background: #093a3e;">DE</div>
            <div>
              <div class="testimonial-name">David Ensley</div>
              <div class="testimonial-role">Partner, Celebrate Dental</div>
            </div>
          </div>
        </div>

        <div class="testimonial-card reveal reveal-delay-2">
          <p class="testimonial-text">"They always try to go above and beyond. When a placement didn't work out, they had a replacement ready within a week."</p>
          <div class="testimonial-context">Hired: Virtual assistants &amp; care coordinators</div>
          <div class="testimonial-author">
            <div class="testimonial-avatar" style="background: #22c55e;">GK</div>
            <div>
              <div class="testimonial-name">Greg K.</div>
              <div class="testimonial-role">CEO, Home Care Company</div>
            </div>
          </div>
        </div>

      </div>
      <p class="testimonials-source reveal">All reviews verified on <a href="https://clutch.co/profile/sagan" target="_blank" rel="noopener">Clutch.co</a></p>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="case-studies">
    <div class="container">
      <h2 class="section-title reveal">What changes when you stop hiring the old way</h2>
      <div class="case-grid">
        <div class="case-card reveal">
          <div class="case-metric">$180K saved/year</div>
          <h3>Marketing agency replaced 3 US contractors with full-time Sagan hires</h3>
          <p>Cut marketing operations cost by 70% while increasing content output. Three full-time professionals placed within 3 weeks, all working US business hours.</p>
          <div class="case-roles">
            <span class="case-role">Content Writer</span>
            <span class="case-role">Graphic Designer</span>
            <span class="case-role">Marketing Coordinator</span>
          </div>
        </div>
        <div class="case-card reveal reveal-delay-1">
          <div class="case-metric">6 hires in 8 weeks</div>
          <h3>B2B SaaS startup scaled customer support across 3 time zones</h3>
          <p>Went from 2-person support to 8-person team with 18-hour coverage. Customer satisfaction scores increased 22% in the first quarter after placement.</p>
          <div class="case-roles">
            <span class="case-role">Customer Success</span>
            <span class="case-role">Technical Support</span>
            <span class="case-role">QA Analyst</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <div class="container">
      <p class="section-label reveal">Common questions</p>
      <h2 class="section-title reveal">Everything you need to know</h2>
      <div class="faq-list">

        <div class="faq-item reveal">
          <button class="faq-question">
            What happens if the hire doesn't work out?
            <svg class="faq-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">We replace them at no extra cost — unlimited times. Our replacement guarantee means you're never stuck with a bad fit. Most replacements are delivered within 7-10 business days.</div>
          </div>
        </div>

        <div class="faq-item reveal reveal-delay-1">
          <button class="faq-question">
            How is this different from Upwork or freelancer platforms?
            <svg class="faq-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">Sagan hires are full-time, dedicated employees — not freelancers juggling multiple clients. We handle sourcing, vetting, and screening so you only meet interview-ready candidates. Think of us as your recruiting team for global talent.</div>
          </div>
        </div>

        <div class="faq-item reveal reveal-delay-2">
          <button class="faq-question">
            What roles can you fill?
            <svg class="faq-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">Marketing, sales, customer success, executive assistants, bookkeeping, operations, design, and more. If the role can be done remotely and doesn't require a US-specific license, we can likely fill it. Our sweet spot is $2,000–$3,500/mo roles.</div>
          </div>
        </div>

        <div class="faq-item reveal reveal-delay-3">
          <button class="faq-question">
            Do they work US hours?
            <svg class="faq-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">Yes. We focus on talent in Latin America, Philippines, and South Africa — all in US-friendly time zones. Most candidates work full overlap with US business hours, and many have years of experience working with American companies.</div>
          </div>
        </div>

        <div class="faq-item reveal reveal-delay-4">
          <button class="faq-question">
            How much does it cost?
            <svg class="faq-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">We charge a one-time placement fee — no monthly markups, no hidden costs. You pay the candidate's salary directly. Book a call and we'll give you exact pricing based on the role you need to fill.</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Guarantee Block -->
  <section class="guarantee">
    <div class="container">
      <div class="guarantee-card reveal">
        <div class="guarantee-icon">
          <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        </div>
        <h3>Unlimited Replacement Guarantee</h3>
        <p>If your hire doesn't work out for any reason, we'll find you a replacement at no additional cost. No time limits. No fine print. We don't get paid unless you're happy.</p>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="container">
      <h2 class="reveal">Zero risk. Unlimited replacements.<br />Your next great hire is 14 days away.</h2>
      <p class="reveal reveal-delay-1">Book a free 30-minute call. We'll map out exactly who you need, show you sample candidates, and give you transparent pricing.</p>
      <a href="#hero" class="cta-button reveal reveal-delay-2">
        Book My Free Consultation
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <div class="cta-guarantees reveal reveal-delay-3">
        <div class="cta-guarantee-item">
