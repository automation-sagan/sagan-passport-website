---
/* 404 / Not Found — Astro build of saganpassport.com's 404 page: a centered
 * message on the BG surface with the primary "Back to home" button. Reuses the
 * shared Layout / Navbar / Footer and the native ButtonFill. Astro serves this
 * file automatically for any unmatched route. */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ButtonFill from '../components/homepage/ButtonFill.astro';
import { getNotFound } from '../lib/notFound';

const data = await getNotFound();
const button = data.button ?? {};
---

<Layout title={data.seoTitle ?? 'Page Not Found — Sagan Passport'}>
  <Navbar />
  <div class="home">
    <section class="section nf">
      <div class="nf__content">
        <h1 class="t-h2">{data.heading}</h1>
        <p class="t-body">{data.body}</p>
        <ButtonFill label={button.label ?? 'Back to home'} href={button.href ?? '/'} external={button.external} />
      </div>
    </section>
  </div>
  <Footer />
</Layout>

<style>
  /* Ported from the React .nf classes (home.css), using Astro tokens. */
  .nf {
    background: var(--bg);
    min-height: 100vh;
    padding: 140px 64px 80px;
    /* Center the content vertically within the full-height section (the
       shared .section sets flex-column + align-items:center, but defaults to
       justify-content:flex-start, which pinned the content to the top). */
    justify-content: center;
  }
  .nf__content {
    width: 100%;
    max-width: 700px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }
  @media (max-width: 810px) {
    .nf { padding: 112px 32px 56px; }
  }
  @media (max-width: 480px) {
    .nf { padding: 96px 20px 40px; }
  }
</style>
