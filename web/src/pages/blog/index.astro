---
/* /blog — light-blue hero header followed by a 3-up grid of post cards. */
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import { getBlogList, getBlogIndex } from '../../lib/blog';
import '../../styles/resources.css';
import '../../styles/blog.css';

/* Featured posts lead the grid; within each group keep the newest-first order
 * from the query. */
const posts = (await getBlogList()).sort(
  (a, b) => Number(b.featured ?? false) - Number(a.featured ?? false),
);
const seo = await getBlogIndex();
---

<Layout
  title={seo.seoTitle ?? 'Blog — Sagan Passport'}
  description={seo.seoDescription}
  ogImage={seo.ogImage}
>
  <Navbar />
  <div class="home">
    <section class="section blog-hero">
      <div class="blog-hero__inner">
        <p class="blog-hero__eyebrow">SAGAN PASSPORT BLOG</p>
        <h1 class="t-h1" style="margin:0">Global Hiring Resources for Small Business Owners</h1>
        <p class="blog-hero__intro">
          The Sagan Passport blog covers everything small business owners need to know about hiring
          international remote employees, from cost breakdowns and offshore staffing basics to
          management advice and team-building strategy. No fluff, no jargon. Just practical guidance
          from a team that does this every day.
        </p>
        <div class="blog-hero__line" aria-hidden="true"></div>
      </div>
    </section>

    <section class="section blog-feed">
      <div class="res-grid">
        {posts.map((p) => <BlogCard post={p} />)}
      </div>
    </section>
  </div>
  <Footer />
</Layout>
