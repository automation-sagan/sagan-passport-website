---
/* /blog/[slug] — blog article, rebuilt to match the live Framer saganpassport
 * blog post template. The article markup lives in BlogArticle.astro (shared
 * with the draft-preview route /preview/blog/[slug]); this page owns the data
 * fetch, SEO head, and chrome. */
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import BlogArticle from '../../components/blog/BlogArticle.astro';
import { getBlogSlugs, getBlog, getBlogList } from '../../lib/blog';
import '../../styles/resources.css';
import '../../styles/blog.css';
import '../../styles/blog-article.css';

export async function getStaticPaths() {
  const slugs = await getBlogSlugs();
  return Promise.all(
    slugs.map(async (slug) => ({ params: { slug }, props: { post: (await getBlog(slug))! } })),
  );
}

const { post } = Astro.props;
const showSidebar = post.showSidebar !== false;
const more = showSidebar
  ? (await getBlogList()).filter((p) => p.slug !== post.slug).slice(0, 3)
  : [];

/* JSON-LD from the Studio "Schema Markup" field. The parse/stringify round-trip
 * rejects invalid JSON and neutralizes any </script> breakout before set:html. */
let jsonLd: string | undefined;
if (post.schemaMarkup) {
  try {
    jsonLd = JSON.stringify(JSON.parse(post.schemaMarkup));
  } catch {
    /* invalid JSON in Studio — skip rather than break the page */
  }
}
---

<Layout
  title={post.seoTitle || `${post.title} — Sagan Passport`}
  description={post.seoDescription}
  ogImage={post.ogImage}
>
  {jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} slot="head" />}
  <Navbar />
  <div class="home">
    <BlogArticle post={post} more={more} />
  </div>
  <Footer />
</Layout>
