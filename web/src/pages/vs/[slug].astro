---
/* /vs/[slug] — competitor comparison pages. Each competitor has its own bespoke
 * page component (different layout/copy per page); this route maps a slug to its
 * component and feeds it the key fields from the matching `comparison` Sanity
 * document. Only slugs with a registered component are built. */
import LandingLayout from '../../layouts/LandingLayout.astro';
import AthenaVs from '../../components/vs/AthenaVs.astro';
import { getAllComparisonSlugs, getComparisonBySlug, type ComparisonData } from '../../lib/comparisons';

export const prerender = true;

// slug → page component. Add an entry here AND to BUILT_SLUGS (in
// getStaticPaths) as each vs page is ported. getStaticPaths runs in an isolated
// scope and can't see this const, hence the duplicated list.
const TEMPLATES: Record<string, any> = {
  'athena-vs-sagan': AthenaVs,
};

export async function getStaticPaths() {
  // Keep in sync with the keys of TEMPLATES above.
  const BUILT_SLUGS = ['athena-vs-sagan'];
  const slugs = await getAllComparisonSlugs();
  const built = slugs.filter((s) => BUILT_SLUGS.includes(s));
  return Promise.all(
    built.map(async (slug) => ({
      params: { slug },
      props: { data: (await getComparisonBySlug(slug))! },
    })),
  );
}

const { data } = Astro.props as { data: ComparisonData };
const Template = TEMPLATES[data.slug];
---

<LandingLayout
  title={data.seoTitle ?? `${data.competitor ?? 'Comparison'} vs Sagan`}
  description={data.seoDescription}
  canonical={data.canonical}
>
  <Template data={data} />
</LandingLayout>
