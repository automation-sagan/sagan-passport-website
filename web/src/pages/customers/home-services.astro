---
/* /customers/home-services — Astro build of the home-services customer vertical.
 * Uses the shared CustomerTemplate driven by the homeServices data config, so
 * every future vertical is just another data object + thin page like this one. */
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CustomerTemplate from '../../components/customer/CustomerTemplate.astro';
import { homeServices } from '../../data/customers';
import '../../styles/customer.css';
---

<Layout title="Home Services — Sagan Passport">
  <Navbar />
  <CustomerTemplate data={homeServices} />
  <Footer />
</Layout>
