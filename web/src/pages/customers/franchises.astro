---
/* /customers/franchises — Astro build of the Franchises customer vertical.
 * Shares CustomerTemplate, driven by the franchises data config. */
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CustomerTemplate from '../../components/customer/CustomerTemplate.astro';
import { franchises } from '../../data/customers';
import '../../styles/customer.css';
---

<Layout title="Franchises — Sagan Passport">
  <Navbar />
  <CustomerTemplate data={franchises} />
  <Footer />
</Layout>
