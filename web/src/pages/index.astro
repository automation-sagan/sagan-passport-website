---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/homepage/Hero.astro';
import TalentTicker from '../components/homepage/TalentTicker.astro';
import LogoWall from '../components/homepage/LogoWall.astro';
import InfoSection from '../components/homepage/InfoSection.astro';
import FeatureCards from '../components/homepage/FeatureCards.astro';
import Testimonials from '../components/homepage/Testimonials.astro';
import CTA from '../components/homepage/CTA.astro';
import { getHomepage } from '../lib/homepage';
import '../styles/homepage.css';

const home = await getHomepage();
---

<Layout title={home.seoTitle ?? 'Sagan Passport'}>
  <Navbar />
  <div class="home">
    <Hero data={home.hero} />
    <TalentTicker items={home.talent} />
    <LogoWall tagline={home.logosTagline} logos={home.logos} />
    <InfoSection rows={home.infoRows} />
    <FeatureCards bigCard={home.bigCard} features={home.features} />
    <Testimonials slides={home.slides} testimonials={home.testimonials} />
    <CTA data={home.cta} />
  </div>
  <Footer />
</Layout>
